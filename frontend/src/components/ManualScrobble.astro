---
interface Props {
  tmdbId: number | null | undefined;
  mediaType: string;
  runtime?: number | null;
  title?: string | null;
  showTmdbId?: number | null;
  seasonNumber?: number | null;
  episodeNumber?: number | null;
}
const { tmdbId, mediaType, runtime, title, showTmdbId, seasonNumber, episodeNumber } = Astro.props;
---

{tmdbId && (
  <div
    id="manual-scrobble"
    data-tmdb-id={tmdbId}
    data-media-type={mediaType}
    data-runtime={runtime ?? 0}
    data-title={title ?? ''}
    data-show-tmdb-id={showTmdbId ?? 0}
    data-season={seasonNumber ?? 0}
    data-episode={episodeNumber ?? 0}
    class="mb-4"
  >
    <button id="ms-start" class="flex items-center gap-2 px-4 py-2 text-sm font-bold leading-none text-white bg-blue-600 hover:bg-blue-500 rounded-lg transition-colors cursor-pointer">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 shrink-0">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.641 0-8.573-3.007-9.963-7.178Z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
      </svg>
      Start watching session
    </button>
  </div>
)}

<script>
(function () {
  const container = document.getElementById('manual-scrobble');
  if (!container) return;

  const TOKEN = () => (window as any).__AUTH_TOKEN__ ?? '';
  const API = '/api/proxy';

  const tmdbId    = parseInt(container.dataset.tmdbId ?? '0', 10);
  const mediaType = container.dataset.mediaType ?? '';
  const runtime   = parseInt(container.dataset.runtime ?? '0', 10);   // minutes
  const title     = container.dataset.title ?? '';
  const showTmdbId   = parseInt(container.dataset.showTmdbId ?? '0', 10) || null;
  const seasonNumber = parseInt(container.dataset.season ?? '0', 10) || null;
  const episodeNumber = parseInt(container.dataset.episode ?? '0', 10) || null;

  if (!tmdbId || !mediaType) return;

  // ── State ─────────────────────────────────────────────────────────────────
  let sessionKey: string | null = null;
  let state: 'playing' | 'paused' | null = null;
  let progressSeconds = 0;
  let displayTimer: ReturnType<typeof setInterval> | null = null;
  let lastTickAt: number | null = null;

  // ── UI helpers ─────────────────────────────────────────────────────────────
  function fmt(seconds: number): string {
    const h = Math.floor(seconds / 3600);
    const m = Math.floor((seconds % 3600) / 60);
    const s = Math.floor(seconds % 60);
    if (h > 0) return `${h}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
    return `${m}:${String(s).padStart(2, '0')}`;
  }

  function pct(): number {
    const total = runtime * 60;
    if (!total) return 0;
    return Math.min(100, Math.floor((progressSeconds / total) * 100));
  }

  function renderIdle(): void {
    container!.innerHTML = `
      <button id="ms-start" class="flex items-center gap-2 px-4 py-2 text-sm font-bold leading-none text-white bg-blue-600 hover:bg-blue-500 rounded-lg transition-colors cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 shrink-0">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.641 0-8.573-3.007-9.963-7.178Z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
        </svg>
        Start watching session
      </button>
    `;
    document.getElementById('ms-start')?.addEventListener('click', startSession);
  }

  function renderActive(): void {
    const p = pct();
    const total = runtime * 60;
    const elapsed = fmt(progressSeconds);
    const totalFmt = total > 0 ? fmt(total) : '--:--';
    const isPlaying = state === 'playing';
    const barColor = isPlaying ? '#4ade80' : '#facc15';
    const dotAnim = isPlaying
      ? `<span class="relative flex w-2 h-2 shrink-0">
           <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
           <span class="relative inline-flex rounded-full w-2 h-2 bg-green-400"></span>
         </span>`
      : `<span class="w-2 h-2 rounded-full bg-yellow-400 shrink-0"></span>`;

    container!.innerHTML = `
      <div class="bg-zinc-900/60 border border-zinc-800 rounded-xl overflow-hidden">
        <div class="flex items-center gap-3 px-4 py-3">
          ${dotAnim}
          <span class="text-xs font-bold ${isPlaying ? 'text-green-400' : 'text-yellow-400'} uppercase tracking-widest">
            ${isPlaying ? 'Watching' : 'Paused'}
          </span>
          <span class="text-xs text-zinc-500 tabular-nums ml-auto" id="ms-time">
            ${elapsed} / ${totalFmt}
          </span>
          <span class="text-xs font-bold text-zinc-300 tabular-nums" id="ms-pct">${p}%</span>
        </div>
        <div class="bg-zinc-950/50 h-1.5 w-full">
          <div id="ms-bar" style="height:100%;width:${p}%;background:${barColor};transition:width 1s linear"></div>
        </div>
        <div class="flex items-center gap-2 px-4 py-3">
          <button id="ms-toggle"
            class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold text-zinc-300
                   bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 rounded-lg transition-colors cursor-pointer">
            ${isPlaying
              ? `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25v13.5m-7.5-13.5v13.5" /></svg> Pause`
              : `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z" /></svg> Resume`}
          </button>
          <button id="ms-stop"
            class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold text-zinc-400
                   hover:text-zinc-100 bg-zinc-900 hover:bg-zinc-800 border border-zinc-800
                   hover:border-zinc-700 rounded-lg transition-colors cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 7.5A2.25 2.25 0 0 1 7.5 5.25h9a2.25 2.25 0 0 1 2.25 2.25v9a2.25 2.25 0 0 1-2.25 2.25h-9a2.25 2.25 0 0 1-2.25-2.25v-9Z" /></svg>
            Stop
          </button>
          <button id="ms-complete"
            class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold text-green-400
                   hover:text-green-300 bg-zinc-900 hover:bg-zinc-800 border border-zinc-800
                   hover:border-green-700 rounded-lg transition-colors cursor-pointer ml-auto">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
            Mark as watched
          </button>
        </div>
      </div>
    `;

    document.getElementById('ms-toggle')?.addEventListener('click', togglePause);
    document.getElementById('ms-stop')?.addEventListener('click', stopSession);
    document.getElementById('ms-complete')?.addEventListener('click', completeSession);
  }

  // ── Timer ──────────────────────────────────────────────────────────────────
  function startDisplayTimer(): void {
    lastTickAt = Date.now();
    displayTimer = setInterval(() => {
      if (state !== 'playing') return;
      const now = Date.now();
      const delta = (now - (lastTickAt ?? now)) / 1000;
      lastTickAt = now;
      progressSeconds = Math.min(progressSeconds + delta, runtime * 60 || Infinity);
      const total = runtime * 60;
      const p = total > 0 ? Math.min(100, Math.floor((progressSeconds / total) * 100)) : 0;
      const bar = document.getElementById('ms-bar');
      const pctEl = document.getElementById('ms-pct');
      const timeEl = document.getElementById('ms-time');
      if (bar) bar.style.width = p + '%';
      if (pctEl) pctEl.textContent = p + '%';
      if (timeEl) timeEl.textContent = `${fmt(progressSeconds)} / ${total ? fmt(total) : '--:--'}`;
    }, 1000);
  }

  function stopDisplayTimer(): void {
    if (displayTimer) { clearInterval(displayTimer); displayTimer = null; }
  }

  // ── API calls ─────────────────────────────────────────────────────────────
  async function startSession(): Promise<void> {
    const btn = document.getElementById('ms-start') as HTMLButtonElement | null;
    if (btn) { btn.disabled = true; btn.textContent = 'Starting session…'; }
    try {
      const res = await fetch(`${API}/history/session/start`, {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${TOKEN()}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({
          tmdb_id: tmdbId,
          media_type: mediaType,
          title,
          runtime: runtime || null,
          show_tmdb_id: showTmdbId,
          season_number: seasonNumber,
          episode_number: episodeNumber,
        }),
      });
      if (!res.ok) throw new Error(await res.text());
      const data = await res.json();
      sessionKey = data.session_key;
      state = 'playing';
      progressSeconds = 0;
      lastTickAt = Date.now();
      renderActive();
      startDisplayTimer();
    } catch (e) {
      if (btn) { btn.disabled = false; btn.textContent = 'Start watching session'; }
      console.error('Failed to start session', e);
    }
  }

  async function togglePause(): Promise<void> {
    if (!sessionKey) return;
    const newState = state === 'playing' ? 'paused' : 'playing';
    await fetch(`${API}/history/session/${sessionKey}`, {
      method: 'PATCH',
      headers: { 'Authorization': `Bearer ${TOKEN()}`, 'Content-Type': 'application/json' },
      body: JSON.stringify({ progress_seconds: Math.floor(progressSeconds), state: newState }),
    }).catch(() => {});
    state = newState;
    if (newState === 'playing') { lastTickAt = Date.now(); }
    renderActive();
    // Timers keep running; display timer checks state
  }

  async function stopSession(): Promise<void> {
    if (!sessionKey) return;
    stopDisplayTimer();
    await fetch(`${API}/history/session/${sessionKey}`, {
      method: 'DELETE',
      headers: { 'Authorization': `Bearer ${TOKEN()}` },
    }).catch(() => {});
    sessionKey = null;
    state = null;
    progressSeconds = 0;
    renderIdle();
  }

  function markPageWatched(): void {
    const btn = document.querySelector('[data-action="watched"]') as HTMLElement | null;
    if (!btn || btn.getAttribute('data-watched') === 'true') return;
    btn.setAttribute('data-watched', 'true');
    btn.setAttribute('data-state', 'active');
    btn.setAttribute('title', 'Mark as unwatched');
    btn.classList.remove('bg-zinc-800', 'text-zinc-500', 'hover:bg-green-500/10', 'hover:text-green-400');
    btn.classList.add('bg-green-500/50', 'text-green-300', 'hover:bg-green-400/50');
    btn.querySelector('circle')?.setAttribute('fill', 'currentColor');
  }

  async function completeSession(): Promise<void> {
    if (!sessionKey) return;
    stopDisplayTimer();
    const key = sessionKey;
    sessionKey = null;
    state = null;
    progressSeconds = 0;
    const btn = document.getElementById('ms-complete') as HTMLButtonElement | null;
    if (btn) { btn.disabled = true; btn.textContent = 'Saving…'; }
    try {
      await fetch(`${API}/history/session/${key}/complete`, {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${TOKEN()}` },
      });
      markPageWatched();
    } catch {}
    renderIdle();
  }

  // ── Init: check for existing session ──────────────────────────────────────
  async function init(): Promise<void> {
    try {
      const res = await fetch(`${API}/history/now-playing`, {
        headers: { 'Authorization': `Bearer ${TOKEN()}` },
      });
      if (!res.ok) { renderIdle(); return; }
      const data = await res.json();
      const existing = (data.now_playing ?? []).find(
        (s: any) => s.source === 'manual' && s.media?.tmdb_id === tmdbId && s.media?.type === mediaType
      );
      if (existing) {
        sessionKey = existing.session_key;
        state = existing.state as 'playing' | 'paused';
        // updated_at is the reference point: progress_seconds was accurate at that moment.
        // Append 'Z' so the browser treats it as UTC, not local time.
        const updatedMs = new Date(existing.updated_at + 'Z').getTime();
        const elapsedSinceUpdate = existing.state === 'playing'
          ? Math.max(0, (Date.now() - updatedMs) / 1000)
          : 0;
        const total = runtime * 60;
        progressSeconds = Math.min((existing.progress_seconds ?? 0) + elapsedSinceUpdate, total || Infinity);
        lastTickAt = Date.now();
        renderActive();
        startDisplayTimer();
      } else {
        // Button is already in the SSR HTML — just wire up the click handler.
        document.getElementById('ms-start')?.addEventListener('click', startSession);
      }
    } catch {
      document.getElementById('ms-start')?.addEventListener('click', startSession);
    }
  }

  init();
})();
</script>
