---
interface Props {
  tmdbId: number;
  mediaType: string;
  watched: boolean;
  inLists: number[];
  inLibrary: boolean;
  collectionPct: number;
  watchPct?: number;
  showTmdbId?: number;
  seasonNumber?: number;
  episodeNumber?: number;
  hideRequest?: boolean;
  hideLists?: boolean;
  isMonitored?: boolean;
  requestEnabled?: boolean;
  requestStatus?: string | null;
  mediaId?: number | null;
  userRating?: number | null;
  listOnly?: boolean;
}

const {
  tmdbId,
  mediaType,
  watched,
  inLists,
  inLibrary,
  collectionPct,
  watchPct = 0,
  showTmdbId,
  seasonNumber,
  episodeNumber,
  hideRequest = false,
  hideLists = false,
  isMonitored = false,
  requestEnabled = false,
  requestStatus = null,
  mediaId = null,
  userRating = null,
  listOnly = false,
} = Astro.props;

const isSeries = mediaType === "series";
const showRequest = !hideRequest && requestEnabled && (mediaType === "movie" || mediaType === "series");
const ratingLabel = userRating != null ? userRating.toFixed(1) : "Rate";

// Shared button classes
const btn = "flex flex-col items-center justify-center gap-0.5 md:gap-1.5 px-2 py-3 md:py-3.5 transition-all cursor-pointer";
const btnW = "w-[52px] min-w-[52px] md:w-[85px] md:min-w-[85px]";
const label = "hidden md:block text-[10px] font-bold uppercase tracking-wider leading-none";

// Consistent state classes per button colour — inactive / active
// inactive: bg-zinc-800 text-zinc-500 hover:bg-[c]-500/10 hover:text-[c]-400
// active:   bg-[c]-500/20 text-[c]-400 hover:bg-[c]-500/30
const watchActive = isSeries ? watchPct > 0 : watched;
const watchedCls  = watchActive
  ? "bg-green-500/50  text-green-300  hover:bg-green-400/50"
  : "bg-zinc-800 text-zinc-500 hover:bg-green-400/50 hover:text-green-400";

const listsCls    = inLists.length > 0
  ? "bg-sky-500/50 text-sky-300 hover:bg-sky-400/50"
  : "bg-zinc-800 text-zinc-500 hover:bg-sky-400/50 hover:text-sky-300";

const rateCls     = userRating != null
  ? "bg-amber-500/50  text-amber-300  hover:bg-amber-400/50"
  : "bg-zinc-800 text-zinc-500 hover:bg-amber-400/50  hover:text-amber-400";

const collectedCls = inLibrary
  ? "bg-purple-500/50 text-purple-300 hover:bg-purple-400/50"
  : "bg-zinc-800 text-zinc-500 hover:bg-purple-500/50 hover:text-purple-400";

const needsCheck  = !requestStatus && !isMonitored;
const requestBlocked = isMonitored || !!requestStatus;
const requestCls  = requestBlocked
  ? "bg-orange-500/50 text-orange-300 hover:bg-orange-400/50"
  : "bg-zinc-800 text-zinc-500 hover:bg-orange-300/60 hover:text-orange-400";
const requestTitle = isMonitored
  ? (isSeries ? "Already in Sonarr" : "Already in Radarr")
  : requestStatus === "pending"
    ? "Awaiting admin approval"
    : requestStatus === "rejected"
      ? "Request rejected"
      : (isSeries ? "Request on Sonarr" : "Request on Radarr");
---

<div
  data-card
  data-tmdb-id={String(tmdbId)}
  data-media-type={mediaType}
  data-show-tmdb-id={showTmdbId ? String(showTmdbId) : ""}
  data-season={seasonNumber != null ? String(seasonNumber) : ""}
  data-episode-number={episodeNumber != null ? String(episodeNumber) : ""}
  data-media-id={mediaId != null ? String(mediaId) : ""}
  class="flex w-fit"
>
  <div class="flex flex-row rounded-2xl overflow-hidden border border-zinc-800 shadow-lg min-h-[52px] md:min-h-[64px] w-fit">

    <!-- Watched (green) -->
    {!listOnly && (
      <button
        data-action="watched"
        data-watched={String(watched)}
        data-watch-pct={String(watchPct)}
        data-state={watchActive ? "active" : "inactive"}
        title={isSeries ? `${watchPct}% watched` : (watched ? "Mark as unwatched" : "Mark as watched")}
        class={`${btn} ${btnW} border-r border-zinc-800/60 ${watchedCls}`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
          <circle cx="12" cy="12" r="3" fill={watchActive ? "currentColor" : "none"}/>
        </svg>
        <span class={label}>{isSeries ? `${watchPct}%` : "Watched"}</span>
        {isSeries && <span class="md:hidden text-[9px] font-bold leading-none">{watchPct}%</span>}
      </button>
    )}

    <!-- Lists (sky) -->
    {!hideLists && (
      <button
        data-action="list"
        data-in-lists={JSON.stringify(inLists)}
        data-state={inLists.length > 0 ? "active" : "inactive"}
        title="Add to list"
        class={`${btn} ${btnW} ${!listOnly ? "border-r border-zinc-800/60" : ""} ${listsCls}`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="8" y1="6" x2="21" y2="6"/>
          <line x1="8" y1="12" x2="21" y2="12"/>
          <line x1="8" y1="18" x2="21" y2="18"/>
          <line x1="3" y1="6" x2="3.01" y2="6"/>
          <line x1="3" y1="12" x2="3.01" y2="12"/>
          <line x1="3" y1="18" x2="3.01" y2="18"/>
        </svg>
        <span class={label}>Lists</span>
      </button>
    )}

    <!-- Rate (amber) -->
    {!listOnly && (
      <button
        data-action="rate"
        data-user-rating={userRating != null ? String(userRating) : ""}
        data-state={userRating != null ? "active" : "inactive"}
        title={userRating != null ? `Your rating: ${ratingLabel}/10` : "Rate this"}
        class={`${btn} ${btnW} border-r border-zinc-800/60 ${rateCls}`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill={userRating != null ? "currentColor" : "none"} stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
        </svg>
        <span class={label}>{ratingLabel}</span>
        {userRating != null && <span class="md:hidden text-[9px] font-bold leading-none">{ratingLabel}</span>}
      </button>
    )}

    <!-- Collected (purple) -->
    {!listOnly && (
      <button
        data-action="collected"
        data-in-library={String(inLibrary)}
        data-collection-pct={String(collectionPct)}
        data-state={inLibrary ? "active" : "inactive"}
        title={isSeries ? `${collectionPct}% in library` : (inLibrary ? "In collection" : "Add to collection")}
        class={`${btn} ${btnW} relative overflow-hidden ${collectedCls} ${showRequest ? "border-r border-zinc-800/60" : ""}`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m2 7 4.41-4.41A2 2 0 0 1 7.83 2h8.34a2 2 0 0 1 1.42.59L22 7"/>
          <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
          <path d="M15 22v-4a3 3 0 0 0-6 0v4"/>
          <path d="M2 7h20"/>
        </svg>
        <span class={label}>{isSeries ? `${collectionPct}%` : "Collected"}</span>
        {isSeries && <span class="md:hidden text-[9px] font-bold leading-none">{collectionPct}%</span>}
      </button>
    )}

    <!-- Request (orange) -->
    {!listOnly && showRequest && (
      <button
        data-action="request"
        data-state={(requestBlocked || collectionPct === 100 || (inLibrary && !isSeries)) ? "active" : "inactive"}
        data-request-loading={needsCheck ? "true" : undefined}
        title={requestTitle}
        disabled={requestBlocked || needsCheck || collectionPct === 100 || (inLibrary && !isSeries)}
        class={`${btn} ${btnW} disabled:cursor-not-allowed ${requestCls}`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        <span class={label}>{isSeries ? "Sonarr" : "Radarr"}</span>
      </button>
    )}
  </div>
</div>
