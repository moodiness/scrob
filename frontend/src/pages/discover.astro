---
import Base from "../layouts/Base.astro";
import { api } from "../lib/api";
export const prerender = false;

const { token } = Astro.locals;
Astro.response.headers.set("Cache-Control", "no-store");
const [settings, profileData] = await Promise.all([
  api.auth.getSettings(token!),
  api.profile.get(token!).catch(() => null),
]);
const hasTmdbKey = !!settings?.has_effective_tmdb_key;
const watchRegion: string = profileData?.country ?? 'US';
const hasProfileData = !!(
  profileData?.country ||
  (profileData?.movie_genres?.length ?? 0) > 0 ||
  (profileData?.show_genres?.length ?? 0) > 0 ||
  (profileData?.streaming_services?.length ?? 0) > 0
);

const topMovieGenres = (profileData?.movie_genres ?? []).slice(0, 3);
const topShowGenres  = (profileData?.show_genres  ?? []).slice(0, 3);

const PROVIDER_NAMES: Record<string, string> = {
  "8": "Netflix", "9": "Prime Video", "337": "Disney+",
  "350": "Apple TV+", "1899": "Max", "15": "Hulu",
};

const userServices = (profileData?.streaming_services ?? []).filter(id => id in PROVIDER_NAMES);
const hasMediaServer = !!(settings?.plex_url || settings?.jellyfin_url || settings?.emby_url);
const canPick = hasTmdbKey && (userServices.length > 0 || hasMediaServer);

// Grab a random backdrop for the "Feeling lucky?" banner
let luckyBackdropUrl: string | null = null;
if (canPick) {
  try {
    const trending = await api.media.trendingMovies(1, token!);
    const pool = (trending?.results ?? []).filter((m: any) => m.backdrop_path);
    if (pool.length > 0) {
      const pick = pool[Math.floor(Math.random() * pool.length)];
      const bp = pick.backdrop_path as string;
      luckyBackdropUrl = bp.startsWith('http') ? bp : `https://image.tmdb.org/t/p/w1280${bp}`;
    }
  } catch { /* no backdrop, fallback to gradient */ }
}

const MOVIE_GENRES = [
  { label: "Action", emoji: "💥" },
  { label: "Adventure", emoji: "🗺️" },
  { label: "Animation", emoji: "🎨" },
  { label: "Comedy", emoji: "😂" },
  { label: "Crime", emoji: "🔍" },
  { label: "Documentary", emoji: "🎥" },
  { label: "Drama", emoji: "🎭" },
  { label: "Fantasy", emoji: "🧙" },
  { label: "Horror", emoji: "👻" },
  { label: "Mystery", emoji: "🕵️" },
  { label: "Romance", emoji: "💕" },
  { label: "Science Fiction", emoji: "🚀" },
  { label: "Thriller", emoji: "😰" },
  { label: "War", emoji: "⚔️" },
  { label: "Western", emoji: "🤠" },
];

const TV_GENRES = [
  { label: "Action & Adventure", emoji: "💥" },
  { label: "Animation", emoji: "🎨" },
  { label: "Comedy", emoji: "😂" },
  { label: "Crime", emoji: "🔍" },
  { label: "Documentary", emoji: "🎥" },
  { label: "Drama", emoji: "🎭" },
  { label: "Kids", emoji: "🧸" },
  { label: "Mystery", emoji: "🕵️" },
  { label: "Reality", emoji: "📺" },
  { label: "Sci-Fi & Fantasy", emoji: "🚀" },
  { label: "Thriller", emoji: "😰" },
  { label: "War & Politics", emoji: "⚔️" },
  { label: "Western", emoji: "🤠" },
];

// Poster skeleton (2:3, for movies)
function skeleton() {
  return Array.from({ length: 8 }).map(() => `
    <div class="flex-shrink-0 w-40 animate-pulse">
      <div class="aspect-[2/3] rounded-2xl bg-zinc-800/80 mb-2"></div>
      <div class="h-2.5 bg-zinc-800 rounded-full w-3/4 mb-1.5"></div>
      <div class="h-2.5 bg-zinc-800 rounded-full w-1/2"></div>
    </div>
  `).join('');
}

// Backdrop skeleton (3:2, for shows)
function skeletonWide() {
  return Array.from({ length: 6 }).map(() => `
    <div class="flex-shrink-0 w-56 animate-pulse">
      <div class="aspect-[3/2] rounded-xl bg-zinc-800/80"></div>
    </div>
  `).join('');
}
---

<Base title="Discover">
  <div class="mb-10">
    <h1 class="text-3xl font-black text-zinc-100 tracking-tight">Discover</h1>
  </div>

  {!hasTmdbKey && (
    <div class="p-10 bg-zinc-900/50 border border-zinc-800 rounded-2xl text-center mb-10">
      <h2 class="text-xl font-bold text-zinc-100 mb-2">TMDB API Key Required</h2>
      <p class="text-zinc-400 mb-5 max-w-md mx-auto">Add your TMDB API key in settings to unlock Discover.</p>
      <a href="/settings" class="inline-flex px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-xl transition-all">
        Go to Settings
      </a>
    </div>
  )}

  <!-- Pick for me modal -->
  <div id="pick-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div id="pick-modal-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>
    <div class="relative w-full max-w-lg max-h-[90vh] bg-zinc-900 border border-zinc-700 rounded-2xl shadow-2xl overflow-hidden flex flex-col">
      <button id="pick-modal-close" class="absolute top-4 right-4 z-10 p-1.5 bg-zinc-800 hover:bg-zinc-700 text-zinc-400 hover:text-zinc-100 rounded-full transition active:scale-95 cursor-pointer" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>

      <!-- Loading -->
      <div id="pick-loading" class="flex flex-col items-center justify-center py-20 px-8 gap-6">
        <div id="pick-emoji" class="text-6xl"></div>
        <p id="pick-phrase" class="text-zinc-300 text-center font-medium text-lg leading-snug"></p>
      </div>

      <!-- Result -->
      <div id="pick-result" class="hidden flex-col overflow-y-auto">
        <div id="pick-backdrop-wrap" class="relative h-48 bg-zinc-800 shrink-0 overflow-hidden">
          <img id="pick-backdrop-img" src="" alt="" class="w-full h-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-zinc-900 via-zinc-900/30 to-transparent"></div>
        </div>
        <div class="p-6 flex flex-col gap-4">
          <div>
            <h2 id="pick-title" class="text-2xl font-black text-zinc-100 leading-tight"></h2>
            <div id="pick-meta" class="flex items-center gap-3 mt-1.5 text-sm text-zinc-400"></div>
          </div>
          <p id="pick-overview" class="text-zinc-300 text-sm leading-relaxed line-clamp-4"></p>
          <div id="pick-genres" class="flex flex-wrap gap-2"></div>
          <div id="pick-sources" class="flex flex-wrap gap-2"></div>
          <div class="flex gap-3 pt-1">
            <button id="pick-again-btn" class="flex items-center gap-2 px-4 py-2.5 bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 text-zinc-200 font-bold text-sm rounded-xl transition-all active:scale-95 active:opacity-70 cursor-pointer">
              Pick again
            </button>
            <a id="pick-view-link" href="#" class="flex-1 flex items-center justify-center gap-2 px-4 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-bold text-sm rounded-xl transition-all active:scale-95">
              View details →
            </a>
          </div>
        </div>
      </div>

      <!-- Error -->
      <div id="pick-error" class="hidden flex-col items-center justify-center py-20 px-8 gap-4 text-center">
        <span class="text-5xl">🤷</span>
        <p id="pick-error-msg" class="text-zinc-300 font-medium"></p>
        <button id="pick-error-retry" class="px-4 py-2 bg-zinc-800 hover:bg-zinc-700 text-zinc-200 font-bold text-sm rounded-xl transition-all active:scale-95 cursor-pointer">
          Try again
        </button>
      </div>
    </div>
  </div>

  {hasTmdbKey && (
    <>
      <!-- For You -->
      {hasProfileData && (topMovieGenres.length > 0 || topShowGenres.length > 0) && (
        <section data-section class="mb-10">
          <div class="flex items-baseline gap-3 mb-5">
            <h2 class="text-2xl font-black text-zinc-100 tracking-tight">For You</h2>
            <span class="text-xs text-zinc-500 font-medium">Based on your favourite genres</span>
          </div>
          <div id="for-you" class="flex gap-3 overflow-x-auto pb-3 scrollbar-none -mx-6 px-6 md:mx-0 md:px-0">
            <Fragment set:html={skeleton()} />
          </div>
        </section>
      )}

      {canPick && (
        <section class="relative mb-10 rounded-3xl overflow-hidden h-48 sm:h-56 flex items-center">
          {luckyBackdropUrl
            ? <img src={luckyBackdropUrl} alt="" class="absolute inset-0 w-full h-full object-cover" loading="lazy" decoding="async" />
            : <div class="absolute inset-0 bg-zinc-800"></div>
          }
          <div class="absolute inset-0 bg-gradient-to-r from-zinc-950/90 via-zinc-950/60 to-zinc-950/20"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-zinc-950/60 via-transparent to-transparent"></div>
          <div class="relative px-8 sm:px-12">
            <p class="text-xs font-black uppercase tracking-[0.2em] text-zinc-400 mb-2">Feeling lucky?</p>
            <h2 class="text-2xl sm:text-3xl font-black text-zinc-100 mb-5 leading-tight">Let us pick something<br class="hidden sm:block" /> for you to watch.</h2>
            <div class="flex gap-3">
              <button
                id="pick-movie-btn"
                class="inline-flex items-center gap-2 px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white font-black rounded-2xl transition-all shadow-xl shadow-blue-900/40 active:scale-95 text-sm uppercase tracking-wider cursor-pointer"
              >
                Pick a Movie
              </button>
              <button
                id="pick-show-btn"
                class="inline-flex items-center gap-2 px-6 py-3 bg-zinc-900/70 hover:bg-zinc-700 text-zinc-100 font-black rounded-2xl transition-all active:scale-95 text-sm uppercase tracking-wider cursor-pointer backdrop-blur-sm"
              >
                Pick a Show
              </button>
            </div>
          </div>
        </section>
      )}

      <!-- Now Playing -->
      <section data-section class="mb-10">
        <h2 class="text-2xl font-black text-zinc-100 tracking-tight mb-5">Now Playing in Theaters</h2>
        <div id="now-playing" class="flex gap-3 overflow-x-auto pb-3 scrollbar-none -mx-6 px-6 md:mx-0 md:px-0">
          <Fragment set:html={skeleton()} />
        </div>
      </section>

      <!-- Trending Trailers -->
      <section data-section class="mb-10">
        <h2 class="text-2xl font-black text-zinc-100 tracking-tight mb-5">Trending Trailers</h2>
        <div id="trending-trailers" class="flex gap-4 overflow-x-auto pb-3 scrollbar-none -mx-6 px-6 md:mx-0 md:px-0">
          <Fragment set:html={skeletonWide()} />
        </div>
      </section>

      <!-- Movie Genres (static) -->
      <section class="mb-10">
        <h2 class="text-sm font-black text-zinc-400 uppercase tracking-widest mb-4">Discover Movies</h2>
        <div class="flex flex-wrap gap-2">
          {MOVIE_GENRES.map(g => (
            <a
              href={`/movies?genre=${encodeURIComponent(g.label)}`}
              class="flex items-center gap-2 px-5 py-3 bg-zinc-900 border border-zinc-800 hover:border-zinc-600 hover:bg-zinc-800 text-zinc-300 hover:text-zinc-100 text-base font-medium rounded-xl transition-all active:scale-95 active:opacity-70"
            >
              <span>{g.emoji}</span>
              <span>{g.label}</span>
            </a>
          ))}
        </div>
      </section>

      <!-- Favourite movie genre rows (poster) -->
      {hasProfileData && topMovieGenres.map((genre, i) => (
        <section data-section class="mb-10">
          <div class="flex items-baseline gap-3 mb-5">
            <h2 class="text-2xl font-black text-zinc-100 tracking-tight">{genre} Movies</h2>
            <a href={`/movies?genre=${encodeURIComponent(genre)}`} class="text-xs text-blue-400 hover:text-blue-300 font-medium transition-colors">See all →</a>
          </div>
          <div id={`movie-genre-${i}`} class="flex gap-3 overflow-x-auto pb-3 scrollbar-none -mx-6 px-6 md:mx-0 md:px-0">
            <Fragment set:html={skeleton()} />
          </div>
        </section>
      ))}

      <!-- Coming Soon -->
      <section data-section class="mb-10">
        <h2 class="text-2xl font-black text-zinc-100 tracking-tight mb-5">Coming Soon</h2>
        <div id="coming-soon" class="flex gap-3 overflow-x-auto pb-3 scrollbar-none -mx-6 px-6 md:mx-0 md:px-0">
          <Fragment set:html={skeleton()} />
        </div>
      </section>

      <!-- Top Rated Movies -->
      <section data-section class="mb-10">
        <h2 class="text-2xl font-black text-zinc-100 tracking-tight mb-5">Top Rated Movies</h2>
        <div id="top-rated-movies" class="flex gap-3 overflow-x-auto pb-3 scrollbar-none -mx-6 px-6 md:mx-0 md:px-0">
          <Fragment set:html={skeleton()} />
        </div>
      </section>

      {!hasProfileData && (
        <section class="relative mb-16 rounded-3xl overflow-hidden flex items-center" id="profile-banner">
          <div class="absolute inset-0 bg-gradient-to-r from-zinc-950 via-zinc-950/95 to-zinc-900"></div>
          <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_left,_rgba(59,130,246,0.12)_0%,_transparent_50%)]"></div>
          <div class="absolute left-0 top-0 bottom-0 w-1 bg-blue-500 rounded-l-3xl"></div>
          <div class="relative px-8 py-8 sm:px-12 flex flex-col md:flex-row md:items-center justify-between w-full gap-5">
            <div>
              <p class="text-xs font-black uppercase tracking-[0.2em] text-blue-400 mb-1.5">Personalise your experience</p>
              <h2 class="text-lg font-black text-zinc-100 leading-tight">Add your region, genres and streaming services to unlock personalised recommendations.</h2>
            </div>
            <a
              href="/user-settings"
              class="shrink-0 self-start md:self-auto inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-500 text-zinc-100 font-black rounded-2xl transition-all shadow-xl shadow-blue-900/40 active:scale-95 text-sm uppercase tracking-wider"
            >
              Update profile
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
              </svg>
            </a>
          </div>
        </section>
      )}

      <!--
        Streaming: each service gets its movies row + shows row adjacent.
        Personalised (user's services) or fallback (Netflix + Prime / Netflix + Disney+).
      -->
      {hasProfileData && userServices.length > 0
        ? userServices.map((id, i) => (
            <Fragment>
              <section data-section class="mb-6">
                <h2 class="text-2xl font-black text-zinc-100 tracking-tight mb-5">On {PROVIDER_NAMES[id]}</h2>
                <div id={`streaming-movie-${i}`} class="flex gap-3 overflow-x-auto pb-3 scrollbar-none -mx-6 px-6 md:mx-0 md:px-0">
                  <Fragment set:html={skeleton()} />
                </div>
              </section>
              <section data-section class="mb-10">
                <h2 class="text-2xl font-black text-zinc-100 tracking-tight mb-5">{PROVIDER_NAMES[id]} Shows</h2>
                <div id={`streaming-show-${i}`} class="flex gap-3 overflow-x-auto pb-3 scrollbar-none -mx-6 px-6 md:mx-0 md:px-0">
                  <Fragment set:html={skeletonWide()} />
                </div>
              </section>
            </Fragment>
          ))
        : !hasProfileData && (
            <Fragment>
              <section data-section class="mb-6">
                <h2 class="text-2xl font-black text-zinc-100 tracking-tight mb-5">On Netflix</h2>
                <div id="fallback-movie-0" class="flex gap-3 overflow-x-auto pb-3 scrollbar-none -mx-6 px-6 md:mx-0 md:px-0">
                  <Fragment set:html={skeleton()} />
                </div>
              </section>
              <section data-section class="mb-10">
                <h2 class="text-2xl font-black text-zinc-100 tracking-tight mb-5">Netflix Shows</h2>
                <div id="fallback-show-0" class="flex gap-3 overflow-x-auto pb-3 scrollbar-none -mx-6 px-6 md:mx-0 md:px-0">
                  <Fragment set:html={skeletonWide()} />
                </div>
              </section>
              <section data-section class="mb-6">
                <h2 class="text-2xl font-black text-zinc-100 tracking-tight mb-5">On Prime Video</h2>
                <div id="fallback-movie-1" class="flex gap-3 overflow-x-auto pb-3 scrollbar-none -mx-6 px-6 md:mx-0 md:px-0">
                  <Fragment set:html={skeleton()} />
                </div>
              </section>
              <section data-section class="mb-10">
                <h2 class="text-2xl font-black text-zinc-100 tracking-tight mb-5">Disney+ Shows</h2>
                <div id="fallback-show-1" class="flex gap-3 overflow-x-auto pb-3 scrollbar-none -mx-6 px-6 md:mx-0 md:px-0">
                  <Fragment set:html={skeletonWide()} />
                </div>
              </section>
            </Fragment>
          )
      }

      <!-- TV Show Genres (static) -->
      <section class="mb-10">
        <h2 class="text-sm font-black text-zinc-400 uppercase tracking-widest mb-4">Discover TV Shows</h2>
        <div class="flex flex-wrap gap-2">
          {TV_GENRES.map(g => (
            <a
              href={`/shows?genre=${encodeURIComponent(g.label)}`}
              class="flex items-center gap-2 px-5 py-3 bg-zinc-900 border border-zinc-800 hover:border-zinc-600 hover:bg-zinc-800 text-zinc-300 hover:text-zinc-100 text-base font-medium rounded-xl transition-all active:scale-95 active:opacity-70"
            >
              <span>{g.emoji}</span>
              <span>{g.label}</span>
            </a>
          ))}
        </div>
      </section>

      <!-- Favourite show genre rows (backdrop) -->
      {hasProfileData && topShowGenres.map((genre, i) => (
        <section data-section class="mb-10">
          <div class="flex items-baseline gap-3 mb-5">
            <h2 class="text-2xl font-black text-zinc-100 tracking-tight">{genre} Shows</h2>
            <a href={`/shows?genre=${encodeURIComponent(genre)}`} class="text-xs text-blue-400 hover:text-blue-300 font-medium transition-colors">See all →</a>
          </div>
          <div id={`show-genre-${i}`} class="flex gap-3 overflow-x-auto pb-3 scrollbar-none -mx-6 px-6 md:mx-0 md:px-0">
            <Fragment set:html={skeletonWide()} />
          </div>
        </section>
      ))}

      <!-- On Air This Week (backdrop) -->
      <section data-section class="mb-10">
        <h2 class="text-2xl font-black text-zinc-100 tracking-tight mb-5">On Air This Week</h2>
        <div id="on-air-this-week" class="flex gap-3 overflow-x-auto pb-3 scrollbar-none -mx-6 px-6 md:mx-0 md:px-0">
          <Fragment set:html={skeletonWide()} />
        </div>
      </section>

      <!-- Top Rated Shows (backdrop) -->
      <section data-section class="mb-10">
        <h2 class="text-2xl font-black text-zinc-100 tracking-tight mb-5">Top Rated Shows</h2>
        <div id="top-rated-shows" class="flex gap-3 overflow-x-auto pb-3 scrollbar-none -mx-6 px-6 md:mx-0 md:px-0">
          <Fragment set:html={skeletonWide()} />
        </div>
      </section>

      <!-- Hidden Gems (poster) -->
      <section data-section class="mb-10">
        <div class="flex items-baseline gap-3 mb-5">
          <h2 class="text-2xl font-black text-zinc-100 tracking-tight">Hidden Gems</h2>
          <span class="text-xs text-zinc-500 font-medium">Critically acclaimed · under the radar</span>
        </div>
        <div id="hidden-gems" class="flex gap-3 overflow-x-auto pb-3 scrollbar-none -mx-6 px-6 md:mx-0 md:px-0">
          <Fragment set:html={skeleton()} />
        </div>
      </section>
    </>
  )}
</Base>

<script define:vars={{ token, watchRegion, hasProfileData, topMovieGenres, topShowGenres, userServices, canPick }}>
  function esc(str) {
    if (str == null) return '';
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function itemUrl(item) {
    if (item.type === 'series') return '/show/' + item.tmdb_id;
    return '/media/movie/' + item.tmdb_id;
  }

  // 2:3 poster card — movies
  function posterCard(item) {
    const url = itemUrl(item);
    const year = item.release_date ? item.release_date.slice(0, 4) : '';
    const rating = item.tmdb_rating ? Number(item.tmdb_rating).toFixed(1) : '';
    return `<a href="${esc(url)}" class="flex-shrink-0 w-40 group active:scale-95 active:opacity-70 transition-all duration-150">
      <div class="relative aspect-[2/3] rounded-2xl overflow-hidden bg-zinc-800 mb-2 ring-1 ring-white/5 group-hover:ring-white/20 transition-all duration-300">
        ${item.poster_path
          ? `<img src="${esc(item.poster_path)}" alt="${esc(item.title)}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy">`
          : `<div class="w-full h-full flex items-center justify-center text-zinc-400 text-xs text-center px-2">${esc(item.title)}</div>`
        }
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
      </div>
      <p class="text-sm font-bold text-zinc-500 dark:text-zinc-300 truncate group-hover:text-zinc-900 dark:group-hover:text-zinc-100 transition-colors leading-snug">${esc(item.title)}</p>
      <p class="text-xs text-zinc-500 mt-0.5">${rating ? '★ ' + esc(rating) : ''}${rating && year ? ' · ' : ''}${esc(year)}</p>
    </a>`;
  }

  // 3:2 backdrop card — shows (title overlaid inside)
  function backdropCard(item) {
    const url = itemUrl(item);
    const year = item.release_date ? item.release_date.slice(0, 4) : '';
    const rating = item.tmdb_rating ? Number(item.tmdb_rating).toFixed(1) : '';
    const img = item.backdrop_path || item.poster_path;
    const meta = [rating ? '★ ' + rating : '', year].filter(Boolean).join(' · ');
    return `<a href="${esc(url)}" class="flex-shrink-0 w-56 group active:scale-95 active:opacity-70 transition-all duration-150">
      <div class="relative aspect-[3/2] rounded-xl overflow-hidden bg-zinc-800 ring-1 ring-white/5 group-hover:ring-white/20 transition-all duration-300">
        ${img
          ? `<img src="${esc(img)}" alt="${esc(item.title)}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy">`
          : `<div class="w-full h-full bg-zinc-800"></div>`
        }
        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-3">
          <p class="text-sm font-bold text-white leading-snug line-clamp-2">${esc(item.title)}</p>
          ${meta ? `<p class="text-xs text-white/60 mt-0.5">${esc(meta)}</p>` : ''}
        </div>
      </div>
    </a>`;
  }

  // Trailer card — YouTube thumbnail with play button, opens YouTube in new tab
  function trailerCard(item) {
    const year = item.release_date ? item.release_date.slice(0, 4) : '';
    const thumb = `https://img.youtube.com/vi/${esc(item.trailer_key)}/hqdefault.jpg`;
    const ytUrl = `https://www.youtube.com/watch?v=${esc(item.trailer_key)}`;
    return `<a href="${ytUrl}" target="_blank" rel="noopener noreferrer" class="flex-shrink-0 w-64 group active:scale-95 active:opacity-70 transition-all duration-150">
      <div class="relative aspect-video rounded-xl overflow-hidden bg-zinc-800 ring-1 ring-white/5 group-hover:ring-white/20 transition-all duration-300 mb-2">
        <img src="${thumb}" alt="${esc(item.title)}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy">
        <div class="absolute inset-0 bg-black/30 group-hover:bg-black/20 transition-colors duration-300 flex items-center justify-center">
          <div class="w-12 h-12 rounded-full bg-red-600 group-hover:bg-red-500 transition-colors duration-200 flex items-center justify-center shadow-xl">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" class="w-5 h-5 translate-x-0.5"><path d="M8 5v14l11-7z"/></svg>
          </div>
        </div>
      </div>
      <p class="text-sm font-bold text-zinc-300 truncate group-hover:text-zinc-100 transition-colors leading-snug">${esc(item.title)}</p>
      <p class="text-xs text-zinc-500 mt-0.5 truncate">${esc(item.trailer_name)}${item.trailer_name && year ? ' · ' : ''}${esc(year)}</p>
    </a>`;
  }

  async function loadTrailers(containerId) {
    const container = document.getElementById(containerId);
    if (!container) return;
    try {
      const res = await fetch('/api/proxy/media/trending/trailers', {
        headers: { Authorization: `Bearer ${token}` },
      });
      if (!res.ok) throw new Error();
      const data = await res.json();
      const items = (data.results || []).slice(0, 16);
      if (!items.length) {
        container.closest('[data-section]')?.remove();
        return;
      }
      container.innerHTML = items.map(trailerCard).join('');
    } catch {
      container.closest('[data-section]')?.remove();
    }
  }

  // Static sections
  async function loadSection(containerId, url, mode = 'poster') {
    const container = document.getElementById(containerId);
    if (!container) return;
    try {
      const res = await fetch(`/api/proxy${url}`, {
        headers: { Authorization: `Bearer ${token}` },
      });
      if (!res.ok) throw new Error();
      const data = await res.json();
      const items = (data.results || []).slice(0, 16);
      if (!items.length) {
        container.closest('[data-section]')?.remove();
        return;
      }
      container.innerHTML = items.map(item => mode === 'backdrop' ? backdropCard(item) : posterCard(item)).join('');
    } catch {
      container.closest('[data-section]')?.remove();
    }
  }

  // Static sections
  loadSection('now-playing',      '/media/now-playing');
  loadTrailers('trending-trailers');
  loadSection('coming-soon',      '/media/upcoming');
  loadSection('top-rated-movies', '/media/top-rated-movies');
  loadSection('on-air-this-week', '/media/on-air-this-week', 'backdrop');
  loadSection('top-rated-shows',  '/media/top-rated-shows',  'backdrop');
  loadSection('hidden-gems',      '/media/hidden-gems?type=movie');

  // For You (poster — consistent in a mixed row)
  if (document.getElementById('for-you')) {
    loadSection('for-you', '/media/for-you');
  }

  // Favourite genre rows
  topMovieGenres.forEach((genre, i) => {
    loadSection(`movie-genre-${i}`, `/media/tmdb/list?type=movie&genre=${encodeURIComponent(genre)}&category=popular`);
  });
  topShowGenres.forEach((genre, i) => {
    loadSection(`show-genre-${i}`, `/media/tmdb/list?type=series&genre=${encodeURIComponent(genre)}&category=popular`, 'backdrop');
  });

  // Streaming rows (movies + shows paired per service)
  if (hasProfileData && userServices.length > 0) {
    userServices.forEach((id, i) => {
      loadSection(`streaming-movie-${i}`, `/media/streaming?provider_id=${id}&type=movie&watch_region=${encodeURIComponent(watchRegion)}`);
      loadSection(`streaming-show-${i}`,  `/media/streaming?provider_id=${id}&type=series&watch_region=${encodeURIComponent(watchRegion)}`, 'backdrop');
    });
  } else if (!hasProfileData) {
    loadSection('fallback-movie-0', `/media/streaming?provider_id=8&type=movie&watch_region=${encodeURIComponent(watchRegion)}`);
    loadSection('fallback-show-0',  `/media/streaming?provider_id=8&type=series&watch_region=${encodeURIComponent(watchRegion)}`, 'backdrop');
    loadSection('fallback-movie-1', `/media/streaming?provider_id=9&type=movie&watch_region=${encodeURIComponent(watchRegion)}`);
    loadSection('fallback-show-1',  `/media/streaming?provider_id=337&type=series&watch_region=${encodeURIComponent(watchRegion)}`, 'backdrop');
  }

  // ── Pick for me ──────────────────────────────────────────────────────────────
  if (canPick) {
    const PHRASES = [
      { emoji: '🔮', text: 'Consulting the crystal ball…' },
      { emoji: '🎩', text: 'Pulling something out of the hat…' },
      { emoji: '🧝', text: 'Assembling Santa\'s elves…' },
      { emoji: '🌌', text: 'Scanning the multiverse for options…' },
      { emoji: '🎲', text: 'Rolling the cosmic dice…' },
      { emoji: '📚', text: 'Arguing with the film critics…' },
      { emoji: '🍿', text: 'Asking the popcorn oracle…' },
      { emoji: '🤖', text: 'Bribing the recommendation algorithm…' },
      { emoji: '🦉', text: 'Consulting a very wise owl…' },
      { emoji: '🗺️', text: 'Mapping the cinematic universe…' },
      { emoji: '🌟', text: 'Aligning the stars for you…' },
      { emoji: '🧙', text: 'Checking the Tome of Great Films…' },
      { emoji: '🕵️', text: 'Calculating the millionth digit of pi…' },
      { emoji: '⚡', text: 'Harnessing the power of lightning…' },
    ];

    const modal = document.getElementById('pick-modal');
    const backdrop = document.getElementById('pick-modal-backdrop');
    const closeBtn = document.getElementById('pick-modal-close');
    const loadingEl = document.getElementById('pick-loading');
    const resultEl = document.getElementById('pick-result');
    const errorEl = document.getElementById('pick-error');
    const emojiEl = document.getElementById('pick-emoji');
    const phraseEl = document.getElementById('pick-phrase');
    const errorMsgEl = document.getElementById('pick-error-msg');
    const pickAgainBtn = document.getElementById('pick-again-btn');
    const pickErrorRetry = document.getElementById('pick-error-retry');
    const movieBtn = document.getElementById('pick-movie-btn');
    const showBtn = document.getElementById('pick-show-btn');

    let phraseInterval = null;
    let currentType = 'movie';

    function openModal() {
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
      if (phraseInterval) { clearInterval(phraseInterval); phraseInterval = null; }
    }

    function showLoading() {
      loadingEl.classList.remove('hidden');
      loadingEl.classList.add('flex');
      resultEl.classList.remove('flex');
      resultEl.classList.add('hidden');
      errorEl.classList.remove('flex');
      errorEl.classList.add('hidden');

      let idx = Math.floor(Math.random() * PHRASES.length);
      emojiEl.textContent = PHRASES[idx].emoji;
      phraseEl.textContent = PHRASES[idx].text;
      if (phraseInterval) clearInterval(phraseInterval);
      phraseInterval = setInterval(() => {
        idx = (idx + 1) % PHRASES.length;
        emojiEl.textContent = PHRASES[idx].emoji;
        phraseEl.textContent = PHRASES[idx].text;
      }, 1800);
    }

    function showError(msg) {
      if (phraseInterval) { clearInterval(phraseInterval); phraseInterval = null; }
      loadingEl.classList.add('hidden');
      loadingEl.classList.remove('flex');
      resultEl.classList.add('hidden');
      resultEl.classList.remove('flex');
      errorEl.classList.remove('hidden');
      errorEl.classList.add('flex');
      errorMsgEl.textContent = msg || 'Nothing found. Try adjusting your profile preferences.';
    }

    function sourceLabel(src) {
      let logoHtml;
      if (src.logo) {
        logoHtml = `<img src="${esc(src.logo)}" alt="" class="w-5 h-5 rounded object-contain" />`;
      } else if (src.type === 'plex' || src.type === 'jellyfin' || src.type === 'emby') {
        logoHtml = `<img src="/icons/${esc(src.type)}.svg" alt="" class="w-5 h-5 rounded object-contain" />`;
      } else {
        logoHtml = '<span class="text-zinc-400 text-xs">▶</span>';
      }
      return `<span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-zinc-800 border border-zinc-700 rounded-lg text-sm font-medium text-zinc-200">${logoHtml} ${esc(src.name)}</span>`;
    }

    function showResult(data) {
      if (phraseInterval) { clearInterval(phraseInterval); phraseInterval = null; }
      loadingEl.classList.add('hidden');
      loadingEl.classList.remove('flex');
      errorEl.classList.add('hidden');
      errorEl.classList.remove('flex');
      resultEl.classList.remove('hidden');
      resultEl.classList.add('flex');

      const backdropImg = document.getElementById('pick-backdrop-img');
      const backdropWrap = document.getElementById('pick-backdrop-wrap');
      if (data.backdrop_path) {
        backdropImg.src = data.backdrop_path;
        backdropImg.alt = data.title || '';
        backdropWrap.classList.remove('hidden');
      } else if (data.poster_path) {
        backdropImg.src = data.poster_path;
        backdropImg.alt = data.title || '';
        backdropWrap.classList.remove('hidden');
      } else {
        backdropWrap.classList.add('hidden');
      }

      document.getElementById('pick-title').textContent = data.title || '';

      const year = data.release_date ? data.release_date.slice(0, 4) : '';
      const rating = data.tmdb_rating ? '★ ' + Number(data.tmdb_rating).toFixed(1) : '';
      const metaParts = [year, rating].filter(Boolean);
      document.getElementById('pick-meta').textContent = metaParts.join(' · ');

      document.getElementById('pick-overview').textContent = data.overview || '';

      const genresEl = document.getElementById('pick-genres');
      const genres = data.genres || [];
      genresEl.innerHTML = genres.map(g => `<span class="px-3 py-1 bg-zinc-800 border border-zinc-700 text-zinc-400 text-xs font-bold rounded-full uppercase tracking-wider">${esc(g)}</span>`).join('');

      const sourcesEl = document.getElementById('pick-sources');
      const sources = data.sources || [];
      sourcesEl.innerHTML = sources.length
        ? sources.map(sourceLabel).join('')
        : '<span class="text-sm text-zinc-500">No streaming source found</span>';

      const viewLink = document.getElementById('pick-view-link');
      if (data.type === 'series') {
        viewLink.href = '/show/' + data.tmdb_id;
      } else {
        viewLink.href = '/media/movie/' + data.tmdb_id;
      }
    }

    async function doPick(type) {
      currentType = type;
      openModal();
      showLoading();
      try {
        const res = await fetch(`/api/proxy/media/pick?type=${type}`, {
          headers: { Authorization: `Bearer ${token}` },
        });
        if (res.status === 404) {
          showError('No unwatched titles found. Watch something first, or adjust your profile.');
          return;
        }
        if (!res.ok) throw new Error();
        const data = await res.json();
        showResult(data);
      } catch {
        showError('Something went wrong. Please try again.');
      }
    }

    movieBtn?.addEventListener('click', () => doPick('movie'));
    showBtn?.addEventListener('click', () => doPick('series'));
    pickAgainBtn?.addEventListener('click', () => doPick(currentType));
    pickErrorRetry?.addEventListener('click', () => doPick(currentType));
    closeBtn?.addEventListener('click', closeModal);
    backdrop?.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
  }

</script>

