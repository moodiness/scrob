---
import Base from "../layouts/Base.astro";
import MediaCard from "../components/MediaCard.astro";
import Pagination from "../components/Pagination.astro";
import { api, type MediaItem, type UserSearchResult } from "../lib/api";

const { token, user: currentUser } = Astro.locals;
Astro.response.headers.set("Cache-Control", "no-store");
const q = Astro.url.searchParams.get("q") || "";
const type = Astro.url.searchParams.get("type") || undefined;
const page = parseInt(Astro.url.searchParams.get("page") || "1");
const year = Astro.url.searchParams.get("year") ? Number(Astro.url.searchParams.get("year")) : undefined;
const inLibrary = Astro.url.searchParams.get("in_library") === "true";

const isUserSearch = type === "user";
const showYearFilter = (type === "movie" || type === "series") && !inLibrary;

const settings = await api.auth.getSettings(token!);
const hasTmdbKey = !!settings?.has_effective_tmdb_key;

let results: MediaItem[] = [];
let userResults: UserSearchResult[] = [];
let totalPages = 1;
let totalResults = 0;
let error = "";

if (q.length >= 2) {
  try {
    if (isUserSearch) {
      const data = await api.profile.searchUsers(q, token);
      userResults = data.results;
      totalResults = userResults.length;
    } else {
      const data = await api.media.search(q, type, page, showYearFilter ? year : undefined, token, inLibrary);
      results = data.results;
      totalPages = data.total_pages;
      totalResults = data.total_results;
    }
  } catch (e: unknown) {
    error = e instanceof Error ? e.message : String(e);
  }
}

const baseUrl = `/search?q=${encodeURIComponent(q)}${type ? `&type=${type}` : ""}${showYearFilter && year ? `&year=${year}` : ""}${inLibrary ? "&in_library=true" : ""}`;
const currentYear = new Date().getFullYear();
const years = Array.from({ length: currentYear - 1899 }, (_, i) => currentYear - i);

const tabs: [string | undefined, string][] = [
  [undefined,      "Movies & Shows"],
  ["movie",        "Movies"],
  ["series",       "Shows"],
  ["episode",      "Episodes"],
  ["person",       "People"],
  ["collection",   "Collections"],
  ["user",         "Users"],
];
---

<Base title={q ? `Search: ${q}` : "Search"}>
  <div id="app-data" data-token={token} class="hidden" aria-hidden="true"></div>

  <div class="mb-8">
    <h1 class="text-3xl font-bold text-zinc-100 mb-2">
      {q ? `Search results for "${q}"` : "Search"}
    </h1>
    <p class="text-zinc-500">{totalResults} results found</p>
  </div>

  <!-- Tab bar -->
  <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
    <div class="flex flex-wrap gap-2">
      {tabs.map(([value, label]) => (
        <a
          href={`/search?q=${encodeURIComponent(q)}${value ? `&type=${value}` : ""}`}
          class={`px-4 py-1.5 rounded-full text-sm font-medium transition ${type === value ? 'bg-zinc-100 text-zinc-900' : 'bg-zinc-900 text-zinc-400 hover:bg-zinc-800 hover:text-zinc-100'}`}
        >
          {label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-2">
      {!isUserSearch && type !== "person" && type !== "collection" && (
        <a
          href={`/search?q=${encodeURIComponent(q)}${type ? `&type=${type}` : ""}${!inLibrary ? "&in_library=true" : ""}`}
          class={`flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-medium border transition ${inLibrary ? 'bg-blue-600/20 border-blue-500/40 text-blue-400' : 'bg-zinc-900 border-zinc-800 text-zinc-400 hover:bg-zinc-800 hover:text-zinc-100'}`}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
          </svg>
          In My Collection
        </a>
      )}
      {!hasTmdbKey && q.length >= 2 && !isUserSearch && (
        <div class="text-xs text-zinc-500 bg-zinc-900/50 px-3 py-1.5 rounded-lg border border-zinc-800">
          Showing local results only. <a href="/settings" class="text-blue-500 hover:underline">Add TMDB Key</a> for more.
        </div>
      )}
    </div>
  </div>

  <!-- Year filter (media only) -->
  {showYearFilter && (
    <div class="flex items-center gap-3 mb-6">
      <select id="filter-year" class="bg-zinc-900 border border-zinc-700 text-zinc-300 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-blue-500">
        <option value="">All Years</option>
        {years.map(y => (
          <option value={y} selected={year === y}>{y}</option>
        ))}
      </select>
      {year && (
        <a href={`/search?q=${encodeURIComponent(q)}&type=${type}`} class="text-sm text-zinc-500 hover:text-zinc-300 transition">Clear</a>
      )}
    </div>
  )}

  {error && (
    <div class="bg-red-500/10 border border-red-500 text-red-500 p-4 rounded-lg mb-8">{error}</div>
  )}

  {!q && (
    <div class="text-center py-20">
      <p class="text-zinc-500">Type something in the search bar to find movies, shows, episodes, people, collections, or users.</p>
    </div>
  )}

  <!-- User results -->
  {isUserSearch && q && userResults.length === 0 && !error && (
    <div class="text-center py-20">
      <p class="text-zinc-500">No users found for "{q}".</p>
    </div>
  )}

  {isUserSearch && userResults.length > 0 && (
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {userResults.map((user) => (
        <div class="bg-zinc-900/60 border border-zinc-800 rounded-2xl p-5 flex flex-col gap-4 hover:border-zinc-600 transition-all">
          <!-- Top row: avatar + name + follow -->
          <div class="flex items-center gap-4">
            <a href={`/profile/${user.id}`} class="shrink-0">
              <div class="w-14 h-14 rounded-xl overflow-hidden bg-zinc-800 border border-zinc-700 flex items-center justify-center">
                {user.avatar_url ? (
                  <img src={`/api/proxy${user.avatar_url}`} alt={user.display_name} class="w-full h-full object-cover" loading="lazy" />
                ) : (
                  <span class="text-xl font-black text-zinc-400">{user.display_name[0].toUpperCase()}</span>
                )}
              </div>
            </a>

            <div class="flex-1 min-w-0">
              <a href={`/profile/${user.id}`} class="block">
                <p class="font-bold text-zinc-100 truncate leading-tight">{user.display_name}</p>
                <p class="text-xs text-zinc-500 truncate">@{user.username}{user.country ? ` · ${user.country.toUpperCase()}` : ""}</p>
              </a>
            </div>

            {!user.is_self && currentUser && (
              <button
                class={`follow-btn cursor-pointer shrink-0 px-3 py-1.5 rounded-full text-xs font-bold border transition-all ${user.is_following ? "bg-zinc-800 hover:bg-red-900/40 text-zinc-300 hover:text-red-300 border-zinc-700 hover:border-red-500/40" : "bg-blue-600/80 hover:bg-blue-500 text-white border-blue-500/40"}`}
                data-user-id={user.id}
                data-following={user.is_following ? "true" : "false"}
              >
                {user.is_following ? "Following" : "Follow"}
              </button>
            )}
          </div>

          <!-- Stats row -->
          <div class="grid grid-cols-4 gap-2 pt-1 border-t border-zinc-800">
            <div class="text-center">
              <p class="text-base font-black text-zinc-100 leading-none">{user.movies_watched}</p>
              <p class="text-[10px] text-zinc-400 font-bold uppercase tracking-wide mt-1">Movies</p>
            </div>
            <div class="text-center">
              <p class="text-base font-black text-zinc-100 leading-none">{user.shows_watched}</p>
              <p class="text-[10px] text-zinc-400 font-bold uppercase tracking-wide mt-1">Shows</p>
            </div>
            <div class="text-center">
              <p class="text-base font-black text-zinc-100 leading-none">{user.total_rated}</p>
              <p class="text-[10px] text-zinc-400 font-bold uppercase tracking-wide mt-1">Rated</p>
            </div>
            <div class="text-center">
              <p class="text-base font-black text-zinc-100 leading-none">{user.follower_count}</p>
              <p class="text-[10px] text-zinc-400 font-bold uppercase tracking-wide mt-1">Followers</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  )}

  <!-- Media results -->
  {!isUserSearch && q && results.length === 0 && !error && (
    <div class="text-center py-20">
      <p class="text-zinc-500">No results found for "{q}".</p>
    </div>
  )}

  {!isUserSearch && (
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-6">
      {results.map((item) => (
        <MediaCard item={item} />
      ))}
    </div>
  )}

  {!isUserSearch && totalPages > 1 && (
    <Pagination currentPage={page} totalPages={totalPages} baseUrl={baseUrl} />
  )}
</Base>

<script>
  function setup() {
    const token = (document.getElementById('app-data') as HTMLElement | null)?.dataset.token ?? '';

    document.querySelectorAll<HTMLButtonElement>('.follow-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const userId = Number(btn.dataset.userId);
        const isFollowing = btn.dataset.following === 'true';
        btn.disabled = true;

        try {
          const res = await fetch(`/api/proxy/profile/${userId}/follow`, {
            method: isFollowing ? 'DELETE' : 'POST',
            headers: { 'Authorization': `Bearer ${token}` },
          });
          if (!res.ok) throw new Error();

          const nowFollowing = !isFollowing;
          btn.dataset.following = nowFollowing ? 'true' : 'false';
          btn.textContent = nowFollowing ? 'Following' : 'Follow';
          btn.className = btn.className.replace(
            nowFollowing
              ? 'bg-blue-600/80 hover:bg-blue-500 text-white border-blue-500/40'
              : 'bg-zinc-800 hover:bg-red-900/40 text-zinc-300 hover:text-red-300 border-zinc-700 hover:border-red-500/40',
            nowFollowing
              ? 'bg-zinc-800 hover:bg-red-900/40 text-zinc-300 hover:text-red-300 border-zinc-700 hover:border-red-500/40'
              : 'bg-blue-600/80 hover:bg-blue-500 text-white border-blue-500/40'
          );
        } catch {
          // silently ignore
        } finally {
          btn.disabled = false;
        }
      });
    });
  }

  setup();
  document.addEventListener('astro:after-swap', setup);
</script>

{showYearFilter && (
  <script define:vars={{ q, type, year }}>
    document.getElementById("filter-year")?.addEventListener("change", (e) => {
      const y = (e.target as HTMLSelectElement).value;
      const params = new URLSearchParams();
      params.set("q", q);
      if (type) params.set("type", type);
      if (y) params.set("year", y);
      window.location.href = `/search?${params.toString()}`;
    });
  </script>
)}
