---
import Base from "../../layouts/Base.astro";
import MediaCard from "../../components/MediaCard.astro";
import { api, type CollectionDetail } from "../../lib/api";
export const prerender = false;

const { id } = Astro.params;
const { token } = Astro.locals;

let collection: CollectionDetail | null = null;
let error = "";

try {
  collection = await api.media.getCollection(Number(id), token);
} catch (e: any) {
  error = e.message;
}

if (!collection && !error) {
  return Astro.redirect("/404");
}
---

<Base title={collection?.name || "Collection"}>
  {error && !collection && (
    <div class="max-w-md mx-auto mt-20 text-center">
      <div class="bg-red-500/10 border border-red-500/20 text-red-500 p-6 rounded-2xl mb-6">
        <p class="font-bold text-lg mb-2">Oops!</p>
        <p class="text-sm opacity-80">{error}</p>
      </div>
      <a href="/" class="text-blue-500 hover:underline">Return to Dashboard</a>
    </div>
  )}

  {collection && (
    <div class="relative">
      <!-- Backdrop -->
      {collection.backdrop_path && (
        <div class="absolute -top-8 left-1/2 -translate-x-1/2 w-screen h-[500px] overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/40 to-transparent z-10"></div>
          <img
            src={collection.backdrop_path}
            alt=""
            class="w-full h-full object-cover opacity-50 blur-[1px]"
            loading="eager"
            decoding="async"
          />
        </div>
      )}

      <div class="relative z-20">
        <button onclick="history.back()" class="inline-flex items-center gap-2 text-sm text-zinc-400 hover:text-zinc-100 transition mb-8 group cursor-pointer bg-transparent border-none p-0">
          <span class="group-hover:-translate-x-1 transition-transform">←</span> Back
        </button>

        <div class="flex flex-col md:flex-row gap-8 lg:gap-12 mb-16">
          <!-- Poster -->
          <div class="w-56 shrink-0 mx-auto md:mx-0">
            <div class="aspect-[2/3] rounded-2xl overflow-hidden shadow-2xl border border-zinc-800 bg-zinc-900 ring-1 ring-white/10 relative">
              {collection.poster_path ? (
                <button id="poster-zoom-btn" class="w-full h-full group/poster block cursor-zoom-in" aria-label={`Enlarge poster for ${collection.name}`}>
                  <img
                    src={collection.poster_path}
                    alt={collection.name}
                    class="w-full h-full object-cover transition-transform duration-300 group-hover/poster:scale-105"
                    loading="eager"
                    decoding="async"
                  />
                  <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover/poster:opacity-100 transition-opacity duration-200 bg-black/30">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-8 h-8 text-white drop-shadow-lg">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607ZM10.5 7.5v6m3-3h-6" />
                    </svg>
                  </div>
                </button>
              ) : (
                <div class="w-full h-full flex flex-col items-center justify-center text-zinc-400 p-4 text-center">
                  <span class="text-4xl mb-2">🎬</span>
                  <span class="text-sm font-medium">No Poster</span>
                </div>
              )}
            </div>
          </div>

          <!-- Info -->
          <div class="flex-1 min-w-0 pt-4">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-blue-600/10 border border-blue-600/30 text-blue-400 text-xs font-bold rounded-full mb-4 uppercase tracking-wider">
              Collection · {collection.parts.length} {collection.parts.length === 1 ? "film" : "films"}
            </div>

            <h1 class="text-4xl md:text-5xl font-black text-zinc-100 mb-6 tracking-tight leading-none">
              {collection.name}
            </h1>

            {collection.overview && (
              <div class="mb-6">
                <h2 class="text-xl font-black text-zinc-100 mb-3 flex items-center gap-2 uppercase tracking-tight">
                  <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
                  Overview
                </h2>
                <p class="text-zinc-300 leading-relaxed text-base max-w-3xl font-medium opacity-90">
                  {collection.overview}
                </p>
              </div>
            )}

            {collection.genres?.length > 0 && (
              <div class="flex flex-wrap gap-2 mt-6">
                {collection.genres.map((g: string) => (
                  <span class="px-4 py-1.5 bg-zinc-900/80 border border-zinc-800 hover:border-zinc-700 transition-colors text-zinc-400 text-xs rounded-full font-bold uppercase tracking-widest">
                    {g}
                  </span>
                ))}
              </div>
            )}
          </div>
        </div>

        <!-- Parts -->
        {collection.parts.length > 0 && (
          <div class="mb-20">
            <h2 class="section-headline mb-6">Films in this Collection</h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-6">
              {collection.parts.map((part) => (
                <MediaCard item={part} />
              ))}
            </div>
          </div>
        )}

        <!-- Cast -->
        {collection.cast?.length > 0 && (
          <div class="border-t border-zinc-900 pt-16">
            <h2 class="text-3xl font-black text-zinc-100 tracking-tighter uppercase mb-10">Top Cast</h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
              {collection.cast.map((person) => (
                <a href={`/person/${person.tmdb_id}`} class="group/cast bg-zinc-900/20 border border-zinc-800/40 p-4 rounded-3xl hover:bg-zinc-800/40 hover:border-blue-500/50 transition-all duration-500 hover:shadow-2xl hover:shadow-blue-900/10">
                  <div class="aspect-square w-full rounded-2xl overflow-hidden mb-5 ring-2 ring-zinc-800/50 group-hover/cast:ring-blue-500 transition-all duration-500 shadow-lg">
                    {person.profile_path ? (
                      <img
                        src={person.profile_path}
                        alt={person.name}
                        class="w-full h-full object-cover group-hover/cast:scale-110 transition-transform duration-700"
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <div class="w-full h-full bg-zinc-800 flex items-center justify-center text-zinc-400 text-4xl">
                        👤
                      </div>
                    )}
                  </div>
                  <div class="text-center">
                    <p class="text-sm font-black text-zinc-100 group-hover/cast:text-blue-400 transition-colors line-clamp-1 leading-tight">{person.name}</p>
                    {person.appearances > 1 && (
                      <p class="text-[11px] text-zinc-500 font-bold uppercase tracking-wider mt-1">{person.appearances} films</p>
                    )}
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  )}
</Base>

{collection?.poster_path && (
  <div id="poster-modal" class="fixed inset-0 z-[999] flex items-center justify-center hidden" role="dialog" aria-modal="true">
    <div id="poster-modal-backdrop" class="absolute inset-0 bg-black/90 backdrop-blur-sm cursor-pointer"></div>
    <img
      src={collection.poster_path}
      alt={collection.name}
      class="relative max-h-[90vh] max-w-[85vw] md:max-w-[50vw] object-contain rounded-2xl shadow-2xl ring-1 ring-white/10"
    />
    <button
      id="poster-modal-close"
      class="absolute top-4 right-4 p-2 rounded-full bg-black/60 hover:bg-black/80 text-white/70 hover:text-white transition-all duration-200 cursor-pointer"
      aria-label="Close"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
)}

<script>
  const zoomBtn = document.getElementById('poster-zoom-btn');
  const modal = document.getElementById('poster-modal');
  const backdrop = document.getElementById('poster-modal-backdrop');
  const closeBtn = document.getElementById('poster-modal-close');
  if (zoomBtn && modal) {
    function openModal() { modal.classList.remove('hidden'); document.body.style.overflow = 'hidden'; }
    function closeModal() { modal.classList.add('hidden'); document.body.style.overflow = ''; }
    zoomBtn.addEventListener('click', openModal);
    backdrop?.addEventListener('click', closeModal);
    closeBtn?.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
  }
</script>
