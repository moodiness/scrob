---
import Base from "../../layouts/Base.astro";
import MediaCard from "../../components/MediaCard.astro";
import ListCard from "../../components/ListCard.astro";
import { api, type ListDetail, type UserList, type PublicList, type MediaItem } from "../../lib/api";
export const prerender = false;

const { id } = Astro.params;
const { token, user } = Astro.locals;

let list: ListDetail | null = null;
let otherLists: UserList[] = [];
let publicLists: PublicList[] = [];
let error = "";

try {
  [list, { lists: otherLists }, { lists: publicLists }] = await Promise.all([
    api.lists.get(Number(id), token!),
    api.lists.getAll(token!),
    api.lists.getPublic(token!),
  ]);
  otherLists = otherLists.filter((l) => l.id !== Number(id));
  publicLists = publicLists.filter((l) => l.username !== user?.username);
} catch (e: unknown) {
  error = e instanceof Error ? e.message : String(e);
}

if (!list && !error) {
  return Astro.redirect("/lists");
}

Astro.response.headers.set("Cache-Control", "no-store");
---

<Base title={list?.name || "List"}>
  {error && !list && (
    <div class="max-w-md mx-auto mt-20 text-center">
      <div class="bg-red-500/10 border border-red-500/20 text-red-500 p-6 rounded-2xl mb-6">
        <p class="font-bold text-lg mb-2">Oops!</p>
        <p class="text-sm opacity-80">{error}</p>
      </div>
      <a href="/lists" class="text-blue-500 hover:underline">Back to Lists</a>
    </div>
  )}

  {list && (
    <div class="max-w-6xl mx-auto">
      <!-- Header -->
      <div class="mb-10">
        <nav class="flex items-center gap-2 text-sm text-zinc-400 mb-6">
          <a href="/lists" class="hover:text-zinc-100 transition">Lists</a>
          <span class="text-zinc-700">/</span>
          <span class="text-zinc-100 font-bold truncate">{list.name}</span>
        </nav>

        <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
          <div class="min-w-0">
            <div class="flex items-center gap-3 mb-2 flex-wrap">
              <h1 id="list-title" class="text-4xl font-black text-zinc-100 tracking-tight"><span id="list-title-text">{list.name}</span></h1>
              {list.privacy_level === "public" && (
                <span id="list-privacy-badge" class="text-[10px] font-black text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-2.5 py-1 rounded-full uppercase tracking-widest">
                  Public
                </span>
              )}
              {list.privacy_level === "friends_only" && (
                <span id="list-privacy-badge" class="text-[10px] font-black text-amber-400 bg-amber-500/10 border border-amber-500/20 px-2.5 py-1 rounded-full uppercase tracking-widest">
                  Friends
                </span>
              )}
            </div>
            {list.description && (
              <p id="list-desc" class="text-zinc-400 text-base leading-relaxed max-w-2xl">{list.description}</p>
            )}
            <p class="text-xs font-bold text-zinc-400 uppercase tracking-widest mt-3">
              {list.item_count} {list.item_count === 1 ? "item" : "items"}
            </p>
          </div>

          <div class="flex gap-2 shrink-0">
            {list.is_owner && (
              <>
                <button
                  id="edit-list-btn"
                  class="flex items-center gap-2 px-4 py-2.5 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 font-bold rounded-xl transition-all text-sm border border-zinc-700 cursor-pointer"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125" />
                  </svg>
                  Edit
                </button>
                <button
                  id="delete-list-btn"
                  class="flex items-center gap-2 px-4 py-2.5 bg-red-500/10 hover:bg-red-500/20 text-red-400 font-bold rounded-xl transition-all text-sm border border-red-500/20 cursor-pointer"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                  </svg>
                  Delete
                </button>
              </>
            )}
          </div>
        </div>
      </div>

      <!-- Edit Modal -->
      <div id="edit-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
        <div id="edit-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>
        <div class="relative bg-zinc-900 border border-zinc-800 rounded-3xl p-8 w-full max-w-md shadow-2xl">
          <h2 class="text-xl font-black text-zinc-100 mb-6">Edit List</h2>
          <form id="edit-form" class="space-y-4">
            <div>
              <label for="edit-name" class="block text-xs font-bold text-zinc-400 uppercase tracking-widest mb-2">Name</label>
              <input
                type="text"
                id="edit-name"
                value={list.name}
                maxlength="255"
                required
                class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
              />
            </div>
            <div>
              <label for="edit-desc" class="block text-xs font-bold text-zinc-400 uppercase tracking-widest mb-2">Description</label>
              <textarea
                id="edit-desc"
                rows="2"
                class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all resize-none"
              >{list.description || ""}</textarea>
            </div>
            <div>
              <label class="block text-xs font-bold text-zinc-400 uppercase tracking-widest mb-3 text-center">Privacy</label>
              <div class="grid grid-cols-3 gap-2">
                <label class="relative flex flex-col items-center p-3 rounded-xl border border-zinc-800 bg-zinc-950 cursor-pointer transition-all hover:bg-zinc-900 group">
                  <input type="radio" name="edit-privacy" value="private" checked={list.privacy_level === "private"} class="sr-only peer" />
                  <div class="absolute inset-0 rounded-xl border-2 border-transparent peer-checked:border-blue-600 transition-all"></div>
                  <span class="text-[10px] font-black uppercase tracking-widest text-zinc-500 peer-checked:text-blue-400 mb-1">Private</span>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-zinc-400 peer-checked:text-blue-500">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                  </svg>
                </label>
                <label class="relative flex flex-col items-center p-3 rounded-xl border border-zinc-800 bg-zinc-950 cursor-pointer transition-all hover:bg-zinc-900 group">
                  <input type="radio" name="edit-privacy" value="friends_only" checked={list.privacy_level === "friends_only"} class="sr-only peer" />
                  <div class="absolute inset-0 rounded-xl border-2 border-transparent peer-checked:border-blue-600 transition-all"></div>
                  <span class="text-[10px] font-black uppercase tracking-widest text-zinc-500 peer-checked:text-blue-400 mb-1">Friends</span>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-zinc-400 peer-checked:text-blue-500">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.998 5.998 0 0 0-12 0m12 0c0-1.723-.699-3.283-1.838-4.412m-1.148-1.148A5.988 5.988 0 0 1 12 12c-1.353 0-2.585.449-3.568 1.206m8.114-1.83c.915 0 1.656-.74 1.656-1.656V6.142c0-.915-.74-1.656-1.656-1.656H12M8.114 11.372A5.988 5.988 0 0 0 12 12c1.353 0 2.585-.449 3.568-1.206m-8.114 1.83a6.062 6.062 0 0 1-1.062-1.062m1.062 1.062c-1.139 1.129-1.838 2.689-1.838 4.412m3.114-10.43c0-.915.74-1.656 1.656-1.656h3.114c.915 0 1.656.74 1.656 1.656V6.142c0 .915-.74 1.656-1.656 1.656H12" />
                  </svg>
                </label>
                <label class="relative flex flex-col items-center p-3 rounded-xl border border-zinc-800 bg-zinc-950 cursor-pointer transition-all hover:bg-zinc-900 group">
                  <input type="radio" name="edit-privacy" value="public" checked={list.privacy_level === "public"} class="sr-only peer" />
                  <div class="absolute inset-0 rounded-xl border-2 border-transparent peer-checked:border-blue-600 transition-all"></div>
                  <span class="text-[10px] font-black uppercase tracking-widest text-zinc-500 peer-checked:text-blue-400 mb-1">Public</span>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-zinc-400 peer-checked:text-blue-500">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-.778.099-1.533.284-2.253" />
                  </svg>
                </label>
              </div>
            </div>
            <div id="edit-error" class="hidden text-xs text-red-400 bg-red-500/10 border border-red-500/20 rounded-lg px-3 py-2"></div>
            <div class="flex gap-3 pt-2">
              <button type="button" id="edit-cancel-btn" class="flex-1 px-4 py-3 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 font-bold rounded-xl transition-all text-sm cursor-pointer">Cancel</button>
              <button type="submit" id="edit-submit-btn" class="flex-1 px-4 py-3 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-xl transition-all text-sm cursor-pointer disabled:opacity-50">Save Changes</button>
            </div>
          </form>
        </div>
      </div>

      <!-- Add Items Search (owner only) -->
      {list.is_owner && (
      <div class="mb-10 bg-zinc-900/40 border border-zinc-800/60 rounded-3xl p-6">
        <h2 class="text-sm font-black text-zinc-400 uppercase tracking-widest mb-4">Add Items</h2>
        <div class="flex flex-col sm:flex-row gap-3">
          <input
            type="text"
            id="search-input"
            placeholder="Search for a movie, show, or person to add..."
            class="flex-1 bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all placeholder:text-zinc-400"
          />
          <div class="flex gap-1.5 bg-zinc-950 border border-zinc-800 rounded-xl p-1 shrink-0">
            {[
              { value: "all", label: "All" },
              { value: "movie", label: "Movies" },
              { value: "series", label: "Shows" },
              { value: "person", label: "People" },
            ].map(f => (
              <button
                class="search-filter-btn px-3 py-1.5 text-xs font-bold rounded-lg transition-all cursor-pointer"
                class:list={[
                  f.value === "all"
                    ? "bg-zinc-800 text-zinc-100"
                    : "text-zinc-500 hover:text-zinc-300"
                ]}
                data-filter={f.value}
              >
                {f.label}
              </button>
            ))}
          </div>
        </div>
        <div id="search-results" class="mt-4 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4 hidden"></div>
        <div id="search-loading" class="hidden mt-4 flex items-center justify-center gap-2 py-6 text-zinc-500 text-sm">
          <svg class="animate-spin w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          Searching…
        </div>
        <p id="search-empty" class="hidden mt-4 text-sm text-zinc-400 text-center py-4">No results found.</p>
      </div>
      )}

      <!-- Items Grid -->
      <div>
        <h2 class="text-sm font-black text-zinc-400 uppercase tracking-widest mb-6">Items</h2>
        {list.items.length === 0 ? (
          <div id="empty-state" class="text-center py-16 bg-zinc-900/20 border border-zinc-800/50 border-dashed rounded-3xl">
            <div class="text-4xl mb-3">📋</div>
            <p class="text-zinc-500">{list.is_owner ? "This list is empty. Search above to add movies and shows." : "This list is empty."}</p>
          </div>
        ) : (
          <div id="items-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
            {list.items.map((entry) => (
              <div class="relative group/item" data-item-id={entry.id}>
                <MediaCard item={entry.media} />
                {list.is_owner && (
                  <button
                    class="remove-item-btn absolute top-2 left-2 bg-red-600/90 hover:bg-red-500 text-white rounded-full w-7 h-7 flex items-center justify-center shadow-lg cursor-pointer z-10 transition-colors"
                    data-item-id={entry.id}
                    aria-label="Remove from list"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3.5 h-3.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                    </svg>
                  </button>
                )}
              </div>
            ))}
          </div>
        )}
        {list.items.length === 0 && <div id="items-grid" class="hidden grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6"></div>}
      </div>

      <!-- Other Lists -->
      {otherLists.length > 0 && (
        <div class="mt-16 pt-10 border-t border-zinc-800/50">
          <h2 class="text-sm font-black text-zinc-400 uppercase tracking-widest mb-6">Your Other Lists</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {otherLists.map((l) => (
              <ListCard
                id={l.id}
                name={l.name}
                description={l.description}
                privacy_level={l.privacy_level}
                item_count={l.item_count}
                preview_posters={l.preview_posters}
              />
            ))}
          </div>
        </div>
      )}

      <!-- Community Lists -->
      {publicLists.length > 0 && (
        <div class="mt-16 pt-10 border-t border-zinc-800/50">
          <h2 class="text-sm font-black text-zinc-400 uppercase tracking-widest mb-6">From the Community</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {publicLists.map((l) => (
              <ListCard
                id={l.id}
                name={l.name}
                description={l.description}
                privacy_level={l.privacy_level}
                item_count={l.item_count}
                preview_posters={l.preview_posters}
                username={l.username}
              />
            ))}
          </div>
        </div>
      )}
    </div>
  )}
</Base>

<script define:vars={{ token, listId: list?.id }}>
  // Reload when restored from bfcache so DOM mutations (newly added items) aren't lost.

  function esc(str) {
    if (str == null) return '';
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }
  // --- Edit list ---
  const editModal = document.getElementById('edit-modal');
  const editForm = document.getElementById('edit-form');
  const editError = document.getElementById('edit-error');
  const editSubmitBtn = document.getElementById('edit-submit-btn');

  document.getElementById('edit-list-btn')?.addEventListener('click', () => {
    editModal.classList.remove('hidden');
    document.getElementById('edit-name').focus();
  });

  function closeEditModal() {
    editModal.classList.add('hidden');
    editError.classList.add('hidden');
  }
  document.getElementById('edit-cancel-btn')?.addEventListener('click', closeEditModal);
  document.getElementById('edit-backdrop')?.addEventListener('click', closeEditModal);

  editForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = document.getElementById('edit-name').value.trim();
    const description = document.getElementById('edit-desc').value.trim() || null;
    const privacyLevel = document.querySelector('input[name="edit-privacy"]:checked').value;

    editSubmitBtn.disabled = true;
    editSubmitBtn.textContent = 'Saving...';
    editError.classList.add('hidden');

    try {
      const res = await fetch(`/api/proxy/lists/${listId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
        body: JSON.stringify({ name, description, privacy_level: privacyLevel }),
      });
      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.detail || 'Failed to update list');
      }
      const updated = await res.json();
      document.getElementById('list-title-text').textContent = updated.name;
      const descEl = document.getElementById('list-desc');
      if (descEl) descEl.textContent = updated.description || '';

      // Update badge
      const headerTitle = document.querySelector('#list-title').parentElement;
      const oldBadge = document.getElementById('list-privacy-badge');
      oldBadge?.remove();

      if (updated.privacy_level !== 'private') {
        const badge = document.createElement('span');
        badge.id = 'list-privacy-badge';
        if (updated.privacy_level === 'public') {
          badge.className = 'text-[10px] font-black text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-2.5 py-1 rounded-full uppercase tracking-widest';
          badge.textContent = 'Public';
        } else {
          badge.className = 'text-[10px] font-black text-amber-400 bg-amber-500/10 border border-amber-500/20 px-2.5 py-1 rounded-full uppercase tracking-widest';
          badge.textContent = 'Friends';
        }
        headerTitle?.appendChild(badge);
      }

      closeEditModal();
    } catch (err) {
      editError.textContent = err.message;
      editError.classList.remove('hidden');
    } finally {
      editSubmitBtn.disabled = false;
      editSubmitBtn.textContent = 'Save Changes';
    }
  });

  // --- Delete list ---
  document.getElementById('delete-list-btn')?.addEventListener('click', async () => {
    const title = document.getElementById('list-title-text')?.textContent || 'this list';
    const ok = await window.showConfirm(`Delete "${title}"?`, 'This cannot be undone.');
    if (!ok) return;

    try {
      const res = await fetch(`/api/proxy/lists/${listId}`, {
        method: 'DELETE',
        headers: { 'Authorization': `Bearer ${token}` },
      });
      if (res.ok) window.location.href = '/lists';
    } catch (err) {
      console.error('Failed to delete list', err);
    }
  });

  // --- Remove items ---
  function bindRemoveButtons() {
    document.querySelectorAll('.remove-item-btn').forEach(btn => {
      if (btn.dataset.bound) return;
      btn.dataset.bound = 'true';
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        const itemId = btn.getAttribute('data-item-id');
        btn.disabled = true;
        btn.innerHTML = `<svg class="animate-spin w-3.5 h-3.5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>`;

        try {
          const res = await fetch(`/api/proxy/lists/${listId}/items/${itemId}`, {
            method: 'DELETE',
            headers: { 'Authorization': `Bearer ${token}` },
          });
          if (res.ok) {
            const card = document.querySelector(`[data-item-id="${itemId}"]`);
            card?.remove();
            // Show empty state if no items left
            const grid = document.getElementById('items-grid');
            if (grid && grid.children.length === 0) {
              document.getElementById('empty-state')?.classList.remove('hidden');
            }
          }
        } catch (err) {
          console.error('Failed to remove item', err);
          btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg>`;
          btn.disabled = false;
        }
      });
    });
  }
  bindRemoveButtons();

  // --- Search & Add ---
  const searchInput = document.getElementById('search-input');
  const searchResults = document.getElementById('search-results');
  const searchEmpty = document.getElementById('search-empty');
  const searchLoading = document.getElementById('search-loading');
  let searchTimeout = null;
  let activeFilter = 'all';
  let searchAbortController = null;

  searchInput?.addEventListener('focus', () => {
    setTimeout(() => {
      const y = searchInput.getBoundingClientRect().top + window.scrollY - 10;
      window.scrollTo({ top: y, behavior: 'smooth' });
    }, 100);
  });

  document.querySelectorAll('.search-filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      activeFilter = btn.getAttribute('data-filter');
      document.querySelectorAll('.search-filter-btn').forEach(b => {
        const isActive = b.getAttribute('data-filter') === activeFilter;
        b.classList.toggle('bg-zinc-800', isActive);
        b.classList.toggle('text-zinc-100', isActive);
        b.classList.toggle('text-zinc-500', !isActive);
      });
      const q = searchInput.value.trim();
      if (q.length >= 2) performSearch(q);
    });
  });

  searchInput?.addEventListener('input', () => {
    clearTimeout(searchTimeout);
    const q = searchInput.value.trim();
    if (q.length < 2) {
      searchResults.classList.add('hidden');
      searchEmpty.classList.add('hidden');
      searchLoading.classList.add('hidden');
      return;
    }
    searchTimeout = setTimeout(() => performSearch(q), 350);
  });

  async function performSearch(q) {
    if (searchAbortController) searchAbortController.abort();
    searchAbortController = new AbortController();
    const signal = searchAbortController.signal;

    searchLoading.classList.remove('hidden');
    searchResults.classList.add('hidden');
    searchEmpty.classList.add('hidden');
    try {
      const typeParam = activeFilter !== 'all' ? `&type=${activeFilter}` : '';
      const res = await fetch(`/api/proxy/media/search?q=${encodeURIComponent(q)}&page=1${typeParam}`, {
        headers: { 'Authorization': `Bearer ${token}` },
        signal,
      });
      if (!res.ok) return;
      const data = await res.json();
      const items = activeFilter === 'all'
        ? data.results.filter(i => i.type === 'movie' || i.type === 'series' || i.type === 'person')
        : data.results.filter(i => i.type === activeFilter);

      searchResults.innerHTML = '';
      searchLoading.classList.add('hidden');
      if (items.length === 0) {
        searchEmpty.classList.remove('hidden');
        searchResults.classList.add('hidden');
        return;
      }

      searchEmpty.classList.add('hidden');
      searchResults.classList.remove('hidden');

      items.slice(0, 12).forEach(item => {
        const poster = item.poster_path
          ? (item.poster_path.startsWith('http') ? item.poster_path : `https://image.tmdb.org/t/p/w300${item.poster_path}`)
          : null;
        const year = item.release_date?.slice(0, 4) || '';
        const isPerson = item.type === 'person';
        const rating = item.tmdb_rating ? Number(item.tmdb_rating).toFixed(1) : '';
        const meta = [rating ? '★ ' + rating : '', year].filter(Boolean).join(' · ');

        const el = document.createElement('button');
        el.className = 'group text-left w-full active:scale-95 active:opacity-70 transition-all duration-150 cursor-pointer';
        el.innerHTML = `
          <div class="relative aspect-[2/3] rounded-2xl overflow-hidden bg-zinc-800 mb-2 ring-1 ring-white/5 group-hover:ring-white/20 transition-all duration-300"${item.adult ? ' data-adult="true"' : ''}>
            ${poster
              ? `<img src="${esc(poster)}" alt="${esc(item.title)}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />`
              : `<div class="w-full h-full flex items-center justify-center text-zinc-400 text-xs p-2 text-center">${isPerson ? '👤' : esc(item.title)}</div>`
            }
            <div class="add-overlay absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end justify-center pb-3">
              <span class="text-white text-[10px] font-black uppercase tracking-widest bg-blue-600 px-2.5 py-1 rounded-full shadow">Add</span>
            </div>
          </div>
          <p class="text-sm font-bold text-zinc-300 truncate group-hover:text-zinc-100 transition-colors leading-snug">${esc(item.title)}</p>
          <p class="text-xs text-zinc-500 mt-0.5">${esc(meta) || (isPerson ? 'Person' : '')}</p>
        `;
        el.addEventListener('click', () => addItem(item.tmdb_id, item.type, el, item));
        searchResults.appendChild(el);
      });
    } catch (err) {
      if (err.name === 'AbortError') return;
      searchLoading.classList.add('hidden');
      console.error('Search failed', err);
    }
  }

  function buildCard(media) {
    const isPerson = media.type === 'person';
    const isSeries = media.type === 'series';
    const showActionBar = !isPerson && media.type !== 'collection';

    const href = isSeries
      ? `/show/${media.tmdb_id}`
      : isPerson
      ? `/person/${media.tmdb_id}`
      : `/media/${media.type}/${media.tmdb_id}`;

    const poster = media.poster_path
      ? (media.poster_path.startsWith('http') ? media.poster_path : `https://image.tmdb.org/t/p/w500${media.poster_path}`)
      : null;

    const rating = media.tmdb_rating ? Number(media.tmdb_rating).toFixed(1) : null;
    const year = media.release_date?.slice(0, 4) ?? '';
    const watched = media.watched ?? false;
    const inLists = media.in_lists ?? [];
    const inLibrary = media.in_library ?? false;
    const collectionPct = media.collection_pct ?? (inLibrary ? 100 : 0);
    const watchPct = media.watch_pct ?? (watched ? 100 : 0);
    const watchActive = isSeries ? watchPct > 0 : watched;
    const collectStyle = isSeries
      ? `background: linear-gradient(to right, rgba(168,85,247,0.2) ${collectionPct}%, transparent ${collectionPct}%)`
      : '';

    const actionBar = showActionBar ? `
      <div class="grid grid-cols-3 flex-shrink-0">
        <button
          data-action="watched"
          data-watched="${watched}"
          data-watch-pct="${watchPct}"
          data-state="${watchActive ? 'active' : 'inactive'}"
          title="${isSeries ? `${watchPct}% watched` : (watched ? 'Mark as unwatched' : 'Mark as watched')}"
          class="flex flex-col items-center justify-center gap-1 py-2.5 transition-all cursor-pointer border-r border-zinc-800/60 hover:brightness-125 ${watchActive ? 'bg-green-500/20 text-green-400' : 'bg-zinc-900 text-zinc-400 hover:bg-green-500/10 hover:text-green-500'}"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
            <circle cx="12" cy="12" r="3" fill="${watchActive ? 'currentColor' : 'none'}"/>
          </svg>
          <span class="text-[8px] font-bold uppercase tracking-wider leading-none">${isSeries ? `${watchPct}%` : 'Watched'}</span>
        </button>
        <button
          data-action="list"
          data-in-lists="${esc(JSON.stringify(inLists))}"
          data-state="${inLists.length > 0 ? 'active' : 'inactive'}"
          title="Add to list"
          class="flex flex-col items-center justify-center gap-1 py-2.5 transition-all cursor-pointer border-r border-zinc-800/60 hover:brightness-125 ${inLists.length > 0 ? 'bg-sky-500/20 text-sky-400' : 'bg-zinc-900 text-zinc-400 hover:bg-sky-500/10 hover:text-sky-400'}"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/>
            <line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/>
            <line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>
          </svg>
          <span class="text-[8px] font-bold uppercase tracking-wider leading-none">Lists</span>
        </button>
        <button
          data-action="collected"
          data-in-library="${inLibrary}"
          data-collection-pct="${collectionPct}"
          data-state="${(inLibrary || collectionPct > 0) ? 'active' : 'inactive'}"
          title="${isSeries ? `${collectionPct}% in library` : (inLibrary ? 'In collection' : 'Add to collection')}"
          style="${esc(collectStyle)}"
          class="relative flex flex-col items-center justify-center gap-1 py-2.5 transition-all cursor-pointer overflow-hidden hover:brightness-125 ${(inLibrary || collectionPct > 0) ? 'bg-purple-500/20 text-purple-400' : 'bg-zinc-900 text-zinc-400 hover:bg-purple-500/10 hover:text-purple-400'}"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m2 7 4.41-4.41A2 2 0 0 1 7.83 2h8.34a2 2 0 0 1 1.42.59L22 7"/>
            <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><path d="M15 22v-4a3 3 0 0 0-6 0v4"/>
            <path d="M2 7h20"/>
          </svg>
          <span class="text-[8px] font-bold uppercase tracking-wider leading-none">${isSeries ? `${collectionPct}%` : 'Collected'}</span>
        </button>
      </div>` : '';

    return `
      <div
        class="group relative flex flex-col rounded-2xl overflow-hidden bg-zinc-900 border border-zinc-800 hover:border-blue-500/50 hover:shadow-2xl hover:shadow-blue-900/20 transition-all duration-300 transform hover:-translate-y-1"
        data-card
        data-tmdb-id="${media.tmdb_id}"
        data-media-type="${esc(media.type)}"
        data-show-tmdb-id="${media.show_tmdb_id ?? ''}"
        data-season="${media.season_number ?? ''}"
      >
        <a href="${esc(href)}" class="block">
          <div class="aspect-[2/3] bg-zinc-950 relative overflow-hidden ring-1 ring-white/5 group-hover:ring-blue-500/30 transition-all duration-300"${media.adult ? ' data-adult="true"' : ''}>
            ${poster
              ? `<img src="${esc(poster)}" alt="${esc(media.title)}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" decoding="async" />`
              : `<div class="w-full h-full flex flex-col items-center justify-center text-zinc-700 bg-zinc-900 p-4 text-center"><span class="text-3xl mb-2 opacity-30">🎬</span><span class="text-xs font-bold uppercase tracking-widest">${esc(media.title)}</span></div>`
            }
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            ${rating ? `<div class="absolute top-2 right-2 bg-black/80 backdrop-blur-md text-yellow-400 text-[10px] font-black px-2 py-0.5 rounded-full shadow-lg border border-zinc-800 flex items-center gap-1"><span class="text-xs leading-none">★</span> ${esc(rating)}</div>` : ''}
          </div>
        </a>
        ${actionBar}
        <a href="${esc(href)}" class="block p-3 bg-gradient-to-b from-zinc-900 to-zinc-950 flex-1">
          <h3 class="text-sm font-bold text-zinc-100 truncate group-hover:text-blue-400 transition-colors leading-tight mb-1">${esc(media.title)}</h3>
          <div class="flex items-center justify-between">
            ${year ? `<span class="text-[11px] font-medium text-zinc-500 tracking-wide">${esc(year)}</span>` : '<span></span>'}
            <span class="text-[9px] font-black text-zinc-400 uppercase tracking-widest px-1.5 py-0.5 bg-zinc-800/50 rounded border border-zinc-800">${isSeries ? 'Show' : esc(media.type)}</span>
          </div>
        </a>
      </div>`;
  }

  async function addItem(tmdbId, mediaType, btn, searchItem) {
    btn.disabled = true;
    // Show spinner immediately
    const overlay = btn.querySelector('.add-overlay');
    if (overlay) {
      overlay.classList.remove('opacity-0', 'group-hover:opacity-100');
      overlay.classList.add('opacity-100');
      overlay.innerHTML = `<svg class="animate-spin w-7 h-7 text-white drop-shadow" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>`;
    }
    try {
      const res = await fetch(`/api/proxy/lists/${listId}/items`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
        body: JSON.stringify({ tmdb_id: tmdbId, media_type: mediaType }),
      });

      if (res.status === 409) {
        btn.style.opacity = '0.4';
        btn.title = 'Already in list';
        // Show "already added" check overlay
        if (overlay) {
          overlay.innerHTML = `<span class="text-white text-xl font-black">✓</span>`;
        }
        return;
      }
      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.detail || 'Failed to add item');
      }

      const entry = await res.json();

      // Swap spinner → green checkmark
      if (overlay) {
        overlay.classList.add('!bg-green-500/30');
        overlay.innerHTML = `<span class="text-white text-2xl font-black drop-shadow">✓</span>`;
      }
      btn.classList.add('pointer-events-none');
      btn.title = 'Added!';

      // Ensure items grid exists (it may not if list was empty)
      let grid = document.getElementById('items-grid');
      const emptyState = document.getElementById('empty-state');
      if (!grid) {
        grid = document.createElement('div');
        grid.id = 'items-grid';
        grid.className = 'grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6';
        emptyState?.parentNode?.insertBefore(grid, emptyState);
      }
      emptyState?.classList.add('hidden');
      grid.classList.remove('hidden');

      // Build the card from search result data (has reliable poster/year),
      // then use entry.id from API for the remove button.
      const cardMedia = {
        ...entry.media,
        poster_path: searchItem?.poster_path ?? entry.media.poster_path,
        release_date: searchItem?.release_date ?? entry.media.release_date,
        tmdb_rating: searchItem?.tmdb_rating ?? entry.media.tmdb_rating,
      };

      const wrapper = document.createElement('div');
      wrapper.className = 'relative group/item';
      wrapper.setAttribute('data-item-id', String(entry.id));
      wrapper.innerHTML = `
        ${buildCard(cardMedia)}
        <button class="remove-item-btn absolute top-2 left-2 bg-red-600/90 hover:bg-red-500 text-white rounded-full w-7 h-7 flex items-center justify-center shadow-lg cursor-pointer z-10 transition-colors"
          data-item-id="${esc(String(entry.id))}" aria-label="Remove from list">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3.5 h-3.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
      `;
      grid.appendChild(wrapper);
      bindRemoveButtons();
    } catch (err) {
      console.error('Failed to add item', err);
      // Restore overlay to "Add" state so the user can retry
      if (overlay) {
        overlay.classList.add('opacity-0', 'group-hover:opacity-100');
        overlay.classList.remove('opacity-100');
        overlay.innerHTML = `<span class="text-white text-[10px] font-black uppercase tracking-widest bg-blue-600 px-2.5 py-1 rounded-full shadow">Add</span>`;
      }
      btn.disabled = false;
    }
  }
</script>
