---
import Base from "../layouts/Base.astro";
import { api } from "../lib/api";
import type { UserPreferences, PrivacyLevel } from "../lib/api";

const { token } = Astro.locals;
const [profileData, me] = await Promise.all([
  api.profile.get(token!).catch(() => null),
  api.auth.me(token!),
]);

const prefs: UserPreferences = {
  display_name: null,
  bio: null,
  country: null,
  movie_genres: [],
  show_genres: [],
  disliked_genres: [],
  streaming_services: [],
  content_language: null,
  privacy_level: "private",
  ...(profileData ?? {}),
};

const PRIVACY_LEVELS: [PrivacyLevel, string, string][] = [
  ["private", "Private", "Only you can see your profile and activity."],
  ["friends_only", "Friends Only", "Only people you follow (and who follow you back) can see your activity."],
  ["public", "Public", "Anyone on this instance can see your profile and activity."],
];

const CONTENT_LANGUAGES: [string, string][] = [
  ["en", "English"],
  ["fr", "French"],
  ["de", "German"],
  ["es", "Spanish"],
  ["it", "Italian"],
  ["pt", "Portuguese"],
  ["ja", "Japanese"],
  ["ko", "Korean"],
  ["zh", "Chinese"],
  ["hi", "Hindi"],
  ["ar", "Arabic"],
];

const MOVIE_GENRES = [
  "Action","Adventure","Animation","Comedy","Crime",
  "Documentary","Drama","Family","Fantasy","History",
  "Horror","Music","Mystery","Romance","Science Fiction",
  "Thriller","War","Western",
];

const SHOW_GENRES = [
  "Action & Adventure","Animation","Comedy","Crime",
  "Documentary","Drama","Family","Kids","Mystery",
  "Reality","Sci-Fi & Fantasy","Soap","Talk",
  "War & Politics","Western",
];

const ALL_GENRES = [...new Set([...MOVIE_GENRES, ...SHOW_GENRES])].sort();

const STREAMING_SERVICES = [
  { id: "8",    name: "Netflix" },
  { id: "9",    name: "Prime Video" },
  { id: "337",  name: "Disney+" },
  { id: "350",  name: "Apple TV+" },
  { id: "1899", name: "Max" },
  { id: "15",   name: "Hulu" },
];

const COUNTRIES = [
  ["DZ","Algeria"],["AR","Argentina"],["AU","Australia"],["AT","Austria"],
  ["AZ","Azerbaijan"],["BH","Bahrain"],["BD","Bangladesh"],["BE","Belgium"],
  ["BO","Bolivia"],["BA","Bosnia and Herzegovina"],["BR","Brazil"],
  ["BG","Bulgaria"],["CA","Canada"],["CL","Chile"],["CN","China"],
  ["CO","Colombia"],["HR","Croatia"],["CY","Cyprus"],["CZ","Czech Republic"],
  ["DK","Denmark"],["EC","Ecuador"],["EG","Egypt"],["EE","Estonia"],
  ["FI","Finland"],["FR","France"],["GE","Georgia"],["DE","Germany"],
  ["GH","Ghana"],["GR","Greece"],["GT","Guatemala"],["HK","Hong Kong"],
  ["HU","Hungary"],["IS","Iceland"],["IN","India"],["ID","Indonesia"],
  ["IE","Ireland"],["IL","Israel"],["IT","Italy"],["JM","Jamaica"],
  ["JP","Japan"],["JO","Jordan"],["KZ","Kazakhstan"],["KE","Kenya"],
  ["KW","Kuwait"],["LV","Latvia"],["LB","Lebanon"],["LT","Lithuania"],
  ["LU","Luxembourg"],["MY","Malaysia"],["MT","Malta"],["MX","Mexico"],
  ["MA","Morocco"],["NL","Netherlands"],["NZ","New Zealand"],["NG","Nigeria"],
  ["NO","Norway"],["OM","Oman"],["PK","Pakistan"],["PA","Panama"],
  ["PY","Paraguay"],["PE","Peru"],["PH","Philippines"],["PL","Poland"],
  ["PT","Portugal"],["QA","Qatar"],["RO","Romania"],["RU","Russia"],
  ["SA","Saudi Arabia"],["RS","Serbia"],["SG","Singapore"],["SK","Slovakia"],
  ["SI","Slovenia"],["ZA","South Africa"],["KR","South Korea"],["ES","Spain"],
  ["LK","Sri Lanka"],["SE","Sweden"],["CH","Switzerland"],["TW","Taiwan"],
  ["TH","Thailand"],["TN","Tunisia"],["TR","Turkey"],["UA","Ukraine"],
  ["AE","United Arab Emirates"],["GB","United Kingdom"],["US","United States"],
  ["UY","Uruguay"],["VE","Venezuela"],["VN","Vietnam"],
];
---

<Base title="Profile">
  <div id="app-data" data-token={token} class="hidden" aria-hidden="true"></div>
  <div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold text-zinc-100 mb-8">Profile</h1>

    <div id="js-message" class="hidden p-4 rounded-lg mb-8"></div>

    <div class="space-y-12">

      <!-- Identity -->
      <section>
        <div class="flex items-center justify-between mb-4 border-b border-zinc-800 pb-2">
          <h2 class="text-xl font-semibold text-zinc-100">Identity</h2>
        </div>

        <!-- Avatar -->
        <div class="flex items-center gap-6 mb-8">
          <div id="avatar-preview" class="w-20 h-20 rounded-2xl overflow-hidden bg-zinc-800 border border-zinc-700 flex items-center justify-center shrink-0">
            {prefs.avatar_url ? (
              <img id="avatar-img" src={`/api/proxy${prefs.avatar_url}`} alt="Avatar" class="w-full h-full object-cover" />
            ) : (
              <span id="avatar-initials" class="text-2xl font-black text-zinc-400 select-none">
                {(prefs.display_name ?? me.username)[0].toUpperCase()}
              </span>
            )}
          </div>
          <div class="space-y-2">
            <p class="text-sm font-medium text-zinc-300">Profile Picture</p>
            <p class="text-xs text-zinc-500">JPEG, PNG or WebP · Max 5 MB</p>
            <div class="flex items-center gap-2 flex-wrap">
              <label class="cursor-pointer px-4 py-2 bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 hover:border-zinc-500 text-zinc-200 text-sm font-medium rounded-lg transition-all">
                <span id="upload-label">Choose file</span>
                <input id="avatar-input" type="file" accept="image/jpeg,image/png,image/webp" class="sr-only" />
              </label>
              {prefs.avatar_url && (
                <button id="remove-avatar-btn" type="button" class="px-4 py-2 bg-red-500/10 hover:bg-red-500/20 border border-red-500/30 text-red-400 text-sm font-medium rounded-lg transition-all">
                  Remove
                </button>
              )}
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label for="display_name" class="block text-sm font-medium text-zinc-400">Display Name</label>
            <input
              type="text"
              id="display_name"
              name="display_name"
              value={prefs.display_name ?? ""}
              placeholder={me.username}
              maxlength={64}
              class="w-full bg-zinc-900 border border-zinc-800 rounded-lg px-4 py-3 text-zinc-100 placeholder:text-zinc-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
            />
            <p class="text-xs text-zinc-500">Shown instead of your username where your name appears.</p>
          </div>
          <div class="space-y-2">
            <label for="bio" class="block text-sm font-medium text-zinc-400">Bio</label>
            <textarea
              id="bio"
              name="bio"
              maxlength={280}
              placeholder="A few words about yourself…"
              class="w-full bg-zinc-900 border border-zinc-800 rounded-lg px-4 py-3 text-zinc-100 placeholder:text-zinc-400 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all resize-none h-[94px]"
            >{prefs.bio ?? ""}</textarea>
          </div>
        </div>
      </section>

      <!-- Privacy -->
      <section>
        <div class="mb-4 border-b border-zinc-800 pb-2">
          <h2 class="text-xl font-semibold text-zinc-100">Privacy</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {PRIVACY_LEVELS.map(([value, label, desc]) => (
            <label class={`relative flex flex-col p-4 rounded-xl border cursor-pointer transition-all hover:bg-zinc-900/50 group ${prefs.privacy_level === value ? 'bg-blue-500/5 border-blue-500/50' : 'bg-zinc-900 border-zinc-800'}`}>
              <div class="flex items-center justify-between mb-1">
                <span class={`font-semibold ${prefs.privacy_level === value ? 'text-blue-400' : 'text-zinc-100 group-hover:text-zinc-200'}`}>{label}</span>
                <input
                  type="radio"
                  name="privacy_level"
                  value={value}
                  checked={prefs.privacy_level === value}
                  class="w-4 h-4 text-blue-500 bg-zinc-800 border-zinc-700 focus:ring-blue-500 focus:ring-offset-zinc-900"
                />
              </div>
              <span class="text-xs text-zinc-500 leading-relaxed">{desc}</span>
            </label>
          ))}
        </div>
      </section>

      <!-- Region -->
      <section>
        <div class="mb-4 border-b border-zinc-800 pb-2">
          <h2 class="text-xl font-semibold text-zinc-100">Region</h2>
        </div>
        <div class="space-y-2 max-w-xs">
          <label for="country" class="block text-sm font-medium text-zinc-400">Country</label>
          <select
            id="country"
            name="country"
            class="w-full bg-zinc-900 border border-zinc-800 rounded-lg px-4 py-3 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
          >
            <option value="">— Not set —</option>
            {COUNTRIES.map(([code, name]) => (
              <option value={code} selected={prefs.country === code}>{name}</option>
            ))}
          </select>
          <p class="text-xs text-zinc-500">
            Used to show relevant streaming availability on the Discover page and filter content for your region.
          </p>
        </div>
      </section>

      <!-- Content Language -->
      <section>
        <div class="mb-4 border-b border-zinc-800 pb-2">
          <h2 class="text-xl font-semibold text-zinc-100">Content Language</h2>
        </div>
        <div class="space-y-2 max-w-xs">
          <label for="content_language" class="block text-sm font-medium text-zinc-400">Preferred Language</label>
          <select
            id="content_language"
            name="content_language"
            class="w-full bg-zinc-900 border border-zinc-800 rounded-lg px-4 py-3 text-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
          >
            <option value="">— Any language —</option>
            {CONTENT_LANGUAGES.map(([code, name]) => (
              <option value={code} selected={prefs.content_language === code}>{name}</option>
            ))}
          </select>
          <p class="text-xs text-zinc-500">
            Filter Discover recommendations to your preferred original language.
          </p>
        </div>
      </section>

      <!-- Streaming Services -->
      <section>
        <div class="mb-4 border-b border-zinc-800 pb-2">
          <h2 class="text-xl font-semibold text-zinc-100">Streaming Services</h2>
        </div>
        <p class="text-sm text-zinc-400 mb-4">
          Select the services you subscribe to. The Discover page will highlight content available on your services.
        </p>
        <div id="streaming-chips" class="flex flex-wrap gap-2">
          {STREAMING_SERVICES.map(({ id, name }) => {
            const active = prefs.streaming_services.includes(id);
            return (
              <button
                type="button"
                data-chip="streaming"
                data-value={id}
                class={`chip px-5 py-3 rounded-full border text-base font-medium transition-all cursor-pointer active:scale-95 active:opacity-70 ${active ? "bg-blue-500/20 border-blue-500 text-blue-400" : "bg-zinc-900 border-zinc-700 text-zinc-400 hover:border-zinc-500 hover:text-zinc-200"}`}
              >
                {name}
              </button>
            );
          })}
        </div>
      </section>

      <!-- Favourite Movie Genres -->
      <section>
        <div class="mb-4 border-b border-zinc-800 pb-2">
          <h2 class="text-xl font-semibold text-zinc-100">Favourite Movie Genres</h2>
        </div>
        <p class="text-sm text-zinc-400 mb-4">
          Pick the genres you enjoy most. The Discover page will show dedicated rows for your favourites.
        </p>
        <div id="movie-genre-chips" class="flex flex-wrap gap-2">
          {MOVIE_GENRES.map((genre) => {
            const active = prefs.movie_genres.includes(genre);
            return (
              <button
                type="button"
                data-chip="movie-genre"
                data-value={genre}
                class={`chip px-5 py-3 rounded-full border text-base font-medium transition-all cursor-pointer active:scale-95 active:opacity-70 ${active ? "bg-blue-500/20 border-blue-500 text-blue-400" : "bg-zinc-900 border-zinc-700 text-zinc-400 hover:border-zinc-500 hover:text-zinc-200"}`}
              >
                {genre}
              </button>
            );
          })}
        </div>
      </section>

      <!-- Favourite Show Genres -->
      <section>
        <div class="mb-4 border-b border-zinc-800 pb-2">
          <h2 class="text-xl font-semibold text-zinc-100">Favourite Show Genres</h2>
        </div>
        <p class="text-sm text-zinc-400 mb-4">
          Pick the genres you enjoy most. The Discover page will show dedicated rows for your favourites.
        </p>
        <div id="show-genre-chips" class="flex flex-wrap gap-2">
          {SHOW_GENRES.map((genre) => {
            const active = prefs.show_genres.includes(genre);
            return (
              <button
                type="button"
                data-chip="show-genre"
                data-value={genre}
                class={`chip px-5 py-3 rounded-full border text-base font-medium transition-all cursor-pointer active:scale-95 active:opacity-70 ${active ? "bg-blue-500/20 border-blue-500 text-blue-400" : "bg-zinc-900 border-zinc-700 text-zinc-400 hover:border-zinc-500 hover:text-zinc-200"}`}
              >
                {genre}
              </button>
            );
          })}
        </div>
      </section>

      <!-- Disliked Genres -->
      <section>
        <div class="mb-4 border-b border-zinc-800 pb-2">
          <h2 class="text-xl font-semibold text-zinc-100">Disliked Genres</h2>
        </div>
        <p class="text-sm text-zinc-400 mb-4">
          Genres you want to avoid. Items that <em>only</em> have disliked genres are filtered out of recommendations and picks. Mixed items (some liked, some disliked) can still appear. A genre can't be in both lists — selecting one here removes it from your favourites.
        </p>
        <div id="disliked-genre-chips" class="flex flex-wrap gap-2">
          {ALL_GENRES.map((genre) => {
            const active = prefs.disliked_genres.includes(genre);
            return (
              <button
                type="button"
                data-chip="disliked-genre"
                data-value={genre}
                class={`chip px-5 py-3 rounded-full border text-base font-medium transition-all cursor-pointer active:scale-95 active:opacity-70 ${active ? "bg-red-500/20 border-red-500 text-red-400" : "bg-zinc-900 border-zinc-700 text-zinc-400 hover:border-zinc-500 hover:text-zinc-200"}`}
              >
                {genre}
              </button>
            );
          })}
        </div>
      </section>

      <!-- Save -->
      <div class="pt-6 pb-8">
        <button
          id="save-btn"
          type="button"
          class="w-full md:w-auto bg-zinc-100 text-zinc-950 font-bold px-8 py-3 rounded-xl hover:bg-zinc-200 transition-colors cursor-pointer disabled:opacity-50"
        >
          Save Changes
        </button>
      </div>

    </div>
  </div>
</Base>

<script>
  function setup() {
    const appData = document.getElementById('app-data');
    const token = appData?.dataset.token ?? '';

    function esc(s: unknown): string {
      if (s == null) return '';
      return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function showMessage(text: string, type: 'success' | 'error' = 'success') {
      const msg = document.getElementById('js-message');
      if (!msg) return;
      msg.textContent = text;
      msg.className = `p-4 rounded-lg mb-8 ${
        type === 'success'
          ? 'bg-green-500/10 border border-green-500 text-green-500'
          : 'bg-red-500/10 border border-red-500 text-red-500'
      }`;
      msg.classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
      if ((window as Window & { _msgTimeout?: ReturnType<typeof setTimeout> })._msgTimeout)
        clearTimeout((window as Window & { _msgTimeout?: ReturnType<typeof setTimeout> })._msgTimeout);
      (window as Window & { _msgTimeout?: ReturnType<typeof setTimeout> })._msgTimeout =
        setTimeout(() => msg.classList.add('hidden'), 4000);
    }

    // Avatar upload
    const avatarInput = document.getElementById('avatar-input') as HTMLInputElement | null;
    const uploadLabel = document.getElementById('upload-label');
    const removeBtn = document.getElementById('remove-avatar-btn') as HTMLButtonElement | null;

    function setAvatarPreview(src: string | null) {
      const preview = document.getElementById('avatar-preview');
      if (!preview) return;
      if (src) {
        preview.innerHTML = `<img id="avatar-img" src="${esc(src)}" alt="Avatar" class="w-full h-full object-cover" />`;
      } else {
        const initial = (document.getElementById('display_name') as HTMLInputElement | null)?.value.trim()[0]
          ?? (uploadLabel?.closest('section')?.querySelector('span')?.textContent?.trim()[0] ?? '?');
        preview.innerHTML = `<span class="text-2xl font-black text-zinc-400 select-none">${esc(initial.toUpperCase())}</span>`;
      }
    }

    avatarInput?.addEventListener('change', async () => {
      const file = avatarInput.files?.[0];
      if (!file) return;
      if (uploadLabel) uploadLabel.textContent = 'Uploading…';
      const form = new FormData();
      form.append('file', file);
      try {
        const res = await fetch('/api/proxy/profile/me/avatar', {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}` },
          body: form,
        });
        if (!res.ok) {
          const data = await res.json() as { detail?: string };
          throw new Error(data.detail ?? 'Upload failed');
        }
        const data = await res.json() as { avatar_url: string };
        setAvatarPreview(`/api/proxy${data.avatar_url}?t=${Date.now()}`);
        if (removeBtn) removeBtn.classList.remove('hidden');
        showMessage('Avatar updated.');
      } catch (e: unknown) {
        showMessage(e instanceof Error ? e.message : 'Upload failed.', 'error');
      } finally {
        if (uploadLabel) uploadLabel.textContent = 'Choose file';
        avatarInput.value = '';
      }
    });

    removeBtn?.addEventListener('click', async () => {
      removeBtn.disabled = true;
      try {
        const res = await fetch('/api/proxy/profile/me/avatar', {
          method: 'DELETE',
          headers: { 'Authorization': `Bearer ${token}` },
        });
        if (!res.ok) throw new Error('Failed to remove avatar');
        setAvatarPreview(null);
        removeBtn.classList.add('hidden');
        showMessage('Avatar removed.');
      } catch (e: unknown) {
        showMessage(e instanceof Error ? e.message : 'Failed to remove avatar.', 'error');
      } finally {
        removeBtn.disabled = false;
      }
    });

    const ACTIVE_BLUE = 'bg-blue-500/20 border-blue-500 text-blue-400';
    const ACTIVE_RED  = 'bg-red-500/20 border-red-500 text-red-400';
    const INACTIVE    = 'bg-zinc-900 border-zinc-700 text-zinc-400 hover:border-zinc-500 hover:text-zinc-200';

    function setChipActive(btn: HTMLButtonElement, active: boolean, isDislike = false) {
      const activeClass = isDislike ? ACTIVE_RED : ACTIVE_BLUE;
      btn.className = btn.className
        .replace(ACTIVE_BLUE, INACTIVE).replace(ACTIVE_RED, INACTIVE)
        .replace(INACTIVE, active ? activeClass : INACTIVE);
      // Normalise: remove duplicates that can appear from chained replaces
      if (active) {
        btn.classList.remove(...INACTIVE.split(' '));
        btn.classList.add(...activeClass.split(' '));
      } else {
        btn.classList.remove(...ACTIVE_BLUE.split(' '), ...ACTIVE_RED.split(' '));
        btn.classList.add(...INACTIVE.split(' '));
      }
    }

    // Chip toggle with mutual exclusivity between liked and disliked
    document.querySelectorAll<HTMLButtonElement>('button[data-chip]').forEach(btn => {
      btn.addEventListener('click', () => {
        const group = btn.dataset.chip!;
        const value = btn.dataset.value!;
        const isDislike = group === 'disliked-genre';
        const isActive = btn.classList.contains(isDislike ? 'bg-red-500/20' : 'bg-blue-500/20');

        setChipActive(btn, !isActive, isDislike);

        // Mutual exclusivity: remove the same genre from the opposite liked/disliked list
        if (!isActive && (group === 'disliked-genre' || group === 'movie-genre' || group === 'show-genre')) {
          const oppositeGroups = isDislike ? ['movie-genre', 'show-genre'] : ['disliked-genre'];
          for (const og of oppositeGroups) {
            document.querySelectorAll<HTMLButtonElement>(`button[data-chip="${og}"][data-value="${value}"]`).forEach(other => {
              setChipActive(other, false, og === 'disliked-genre');
            });
          }
        }
      });
    });

    // Privacy radio buttons
    document.querySelectorAll<HTMLInputElement>('input[name="privacy_level"]').forEach(radio => {
      radio.addEventListener('change', () => {
        document.querySelectorAll<HTMLInputElement>('input[name="privacy_level"]').forEach(r => {
          const label = r.closest('label');
          const span = label?.querySelector('.font-semibold');
          if (r.checked) {
            label?.classList.add('bg-blue-500/5', 'border-blue-500/50');
            label?.classList.remove('bg-zinc-900', 'border-zinc-800');
            span?.classList.add('text-blue-400');
            span?.classList.remove('text-zinc-100');
          } else {
            label?.classList.remove('bg-blue-500/5', 'border-blue-500/50');
            label?.classList.add('bg-zinc-900', 'border-zinc-800');
            span?.classList.remove('text-blue-400');
            span?.classList.add('text-zinc-100');
          }
        });
      });
    });

    // Save
    const saveBtn = document.getElementById('save-btn') as HTMLButtonElement | null;
    saveBtn?.addEventListener('click', async () => {
      saveBtn.disabled = true;
      const orig = saveBtn.textContent;
      saveBtn.textContent = 'Saving…';
      const displayName = (document.getElementById('display_name') as HTMLInputElement | null)?.value.trim() ?? '';
      const bio = (document.getElementById('bio') as HTMLTextAreaElement | null)?.value.trim() ?? '';
      const country = (document.getElementById('country') as HTMLSelectElement | null)?.value ?? '';
      const contentLanguage = (document.getElementById('content_language') as HTMLSelectElement | null)?.value ?? '';

      const activeChips = (group: string) => {
        const activeClass = group === 'disliked-genre' ? 'bg-red-500\\/20' : 'bg-blue-500\\/20';
        return Array.from(document.querySelectorAll<HTMLButtonElement>(`button[data-chip="${group}"].${activeClass}`))
          .map(b => b.dataset.value ?? '');
      };

      try {
        const res = await fetch('/api/proxy/profile/me', {
          method: 'PATCH',
          headers: {
            'Authorization': `Bearer ${token}`,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            display_name: displayName || null,
            bio: bio || null,
            country: country || null,
            content_language: contentLanguage || null,
            privacy_level: (document.querySelector('input[name="privacy_level"]:checked') as HTMLInputElement | null)?.value,
            streaming_services: activeChips('streaming'),
            movie_genres: activeChips('movie-genre'),
            show_genres: activeChips('show-genre'),
            disliked_genres: activeChips('disliked-genre'),
          }),
        });
        if (!res.ok) {
          const data = await res.json() as { detail?: string };
          throw new Error(data.detail ?? 'Failed to save');
        }
        showMessage('Profile saved successfully.');
      } catch (e: unknown) {
        showMessage(e instanceof Error ? e.message : 'Failed to save profile.', 'error');
      } finally {
        saveBtn.disabled = false;
        saveBtn.textContent = orig;
      }
    });
  }

  setup();
  document.addEventListener('astro:after-swap', setup);
</script>
