---
import Base from "../layouts/Base.astro";
import MediaRow from "../components/MediaRow.astro";
import MediaCard from "../components/MediaCard.astro";
import EpisodeCard from "../components/EpisodeCard.astro";
import ContinueWatchingCard from "../components/ContinueWatchingCard.astro";
import { api, type ContinueWatchingItem, type MediaItem } from "../lib/api";

const { token } = Astro.locals;
Astro.response.headers.set("Cache-Control", "no-store");
const apiUrl = import.meta.env.PUBLIC_API_URL ?? "http://localhost:8000";

// Fetch settings first to check for TMDB key
const settings = await api.auth.getSettings(token!);
const hasTmdbKey = !!settings?.has_effective_tmdb_key;

let recentMovies: { results: MediaItem[] } = { results: [] };
let recentShows: { results: MediaItem[] } = { results: [] };
let continueWatching: ContinueWatchingItem[] = [];
let nextUp: MediaItem[] = [];

if (token) {
  const results = await Promise.allSettled([
    api.media.recentlyAdded("movie", token),
    api.media.recentlyAdded("episode", token),
    api.history.continueWatching(token),
    api.history.nextUp(token, 10),
  ]);

  if (results[0].status === "fulfilled") recentMovies = results[0].value;
  if (results[1].status === "fulfilled") recentShows = results[1].value;
  if (results[2].status === "fulfilled")
    continueWatching = results[2].value?.continue_watching ?? [];
  if (results[3].status === "fulfilled") {
    const raw = results[3].value?.next_up ?? [];
    for (let i = raw.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [raw[i], raw[j]] = [raw[j], raw[i]];
    }
    nextUp = raw;
  }
}

const FALLBACK_BACKDROPS: string[] = [
  "https://image.tmdb.org/t/p/original/n4nGpp7VQJWJzZSKanpFkcxhsE4.jpg",
  "https://image.tmdb.org/t/p/original/cPaAXKa3QCgyfk5j848cVSrVs9p.jpg",
  "https://image.tmdb.org/t/p/original/5dQGAaAcX7MLtl1KcqXMjkBgTtg.jpg",
  "https://image.tmdb.org/t/p/original/rJFqKcmMSttdNP58l0dVzY2NcTA.jpg",
  "https://image.tmdb.org/t/p/original/r0Q6eeN9L1ORL9QsV0Sg8ZV3vnv.jpg",
  "https://image.tmdb.org/t/p/original/vZePKXaSO3537aJTxifE3Rrwobb.jpg",
  "https://image.tmdb.org/t/p/original/kfUWupX3phYp7AleZA2U1dmVcjX.jpg",
  "https://image.tmdb.org/t/p/original/ejdD20cdHNFAYAN2DlqPToXKyzx.jpg",
  "https://image.tmdb.org/t/p/original/dqK9Hag1054tghRQSqLSfrkvQnA.jpg",
  "https://image.tmdb.org/t/p/original/ctiw6FZK4N36LmkjSklWEbuvlq9.jpg",
  "https://image.tmdb.org/t/p/original/5kD1o6exM1RbauVLJjtNzseiM1Q.jpg",
  "https://image.tmdb.org/t/p/original/c6OLXfKAk5BKeR6broC8pYiCquX.jpg",
];

const backdropPool: MediaItem[] = [
  ...recentMovies.results.filter(m => !!m.backdrop_path),
  ...recentShows.results.filter(e => !!e.backdrop_path),
];
const discoverPick = backdropPool.length > 0
  ? backdropPool[Math.floor(Math.random() * backdropPool.length)]
  : null;
const discoverBackdropUrl = discoverPick?.backdrop_path
  ? (discoverPick.backdrop_path.startsWith("http")
      ? discoverPick.backdrop_path
      : `https://image.tmdb.org/t/p/w1280${discoverPick.backdrop_path}`)
  : FALLBACK_BACKDROPS[Math.floor(Math.random() * FALLBACK_BACKDROPS.length)];
---

<Base title="Dashboard">
  {!hasTmdbKey && (
    <div class="mb-12 p-8 bg-blue-600/10 border border-blue-600/20 rounded-2xl flex flex-col md:flex-row items-center gap-6 text-center md:text-left">
      <div class="w-16 h-16 bg-blue-600 rounded-2xl flex items-center justify-center text-3xl shrink-0 shadow-lg shadow-blue-600/20 text-zinc-100">
        🎬
      </div>
      <div class="flex-1">
        <h2 class="text-xl font-bold text-zinc-100 mb-1">Finish setting up your account</h2>
        <p class="text-zinc-400">To start using Scrob and explore movies and shows, you must add your TMDB API Key.</p>
      </div>
      <a href="/settings" class="px-6 py-3 bg-blue-600 hover:bg-blue-500 text-zinc-100 font-bold rounded-xl transition-all shadow-lg shadow-blue-600/20 active:scale-95">
        Go to Settings
      </a>
    </div>
  )}

  {nextUp.length > 0 && (() => {
    const hero = nextUp[0];
    const rest = nextUp.slice(1);
    const heroHref = hero.show_tmdb_id && hero.season_number != null && hero.episode_number != null
      ? `/show/${hero.show_tmdb_id}/season/${hero.season_number}/${hero.episode_number}`
      : hero.show_tvdb_id && hero.season_number != null && hero.episode_number != null
        ? `/show/tvdb/${hero.show_tvdb_id}/season/${hero.season_number}/${hero.episode_number}`
        : `/media/${hero.type}/${hero.tmdb_id}`;
    const episodeLabel = hero.season_number != null && hero.episode_number != null
      ? `S${hero.season_number} E${hero.episode_number}`
      : null;
    const rawBackdrop = hero.backdrop_path || hero.show_backdrop_path;
    const heroBackdrop = rawBackdrop
      ? (rawBackdrop.startsWith('http') ? rawBackdrop : `https://image.tmdb.org/t/p/w1280${rawBackdrop}`)
      : null;
    return (
      <section class="relative md:-mt-8 mb-16">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-screen overflow-hidden pointer-events-none" style="height: 100%;">
          {heroBackdrop ? (
            <img
              src={heroBackdrop}
              alt={hero.title}
              class="w-full h-full object-cover"
              loading="eager"
              decoding="async"
            />
          ) : (
            <div class="w-full h-full bg-zinc-900"></div>
          )}
          <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/60 to-zinc-950/20"></div>
          <div class="absolute inset-0 bg-gradient-to-r from-zinc-950/70 via-transparent to-transparent"></div>
        </div>

        <div class="relative aspect-[16/9] sm:aspect-[21/8] md:aspect-[21/5] flex flex-col">
          <div class="flex items-center justify-between pt-8 pb-0">
            <h2 class="text-2xl font-black text-zinc-100 tracking-tight flex items-center gap-3">
              <span class="w-1 h-6 bg-blue-600 rounded-full"></span>
              Next Up
            </h2>
            <a href="/next-up" class="text-sm font-bold uppercase tracking-widest text-zinc-400 hover:text-blue-400 transition-all flex items-center gap-2 group/all">
              See All
              <span class="group-hover/all:translate-x-1 transition-transform">→</span>
            </a>
          </div>

          <div class="flex-1 flex items-end pb-6 sm:pb-8">
            <a href={heroHref} class="block max-w-2xl group">
              {episodeLabel && (
                <span class="inline-block text-xs font-bold uppercase tracking-widest text-blue-400 bg-blue-500/10 border border-blue-500/20 px-3 py-1 rounded-full mb-3">
                  {episodeLabel}
                </span>
              )}
              <h3 class="text-2xl sm:text-4xl font-black text-zinc-100 leading-tight mb-1 drop-shadow-lg group-hover:text-blue-200 transition-colors">
                {hero.show_title ?? hero.title}
              </h3>
              {hero.show_title && (
                <p class="text-sm sm:text-base text-zinc-300 font-medium truncate">{hero.title}</p>
              )}
            </a>
          </div>
        </div>

        {rest.length > 0 && (
          <div class="relative flex gap-3 overflow-x-auto pb-3 scrollbar-none pt-6 -mx-6 px-6 md:mx-0 md:px-0">
            {rest.map((item) => <div class="flex-shrink-0 w-40"><MediaCard item={item} /></div>)}
          </div>
        )}
      </section>
    );
  })()}

  {continueWatching.length > 0 && (
    <section id="continue-watching-section" class="mb-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-black text-zinc-100 tracking-tight flex items-center gap-3">
          <span class="w-1 h-6 bg-blue-600 rounded-full"></span>
          Continue Watching
        </h2>
      </div>
      <div class="flex gap-3 overflow-x-auto pb-3 scrollbar-none -mx-6 px-6 md:mx-0 md:px-0">
        {continueWatching.slice(0, 12).map((item) => (
          <div class="flex-shrink-0 w-40"><ContinueWatchingCard item={item} /></div>
        ))}
      </div>
    </section>
  )}

  {recentMovies.results?.length > 0 && (
    <section class="mb-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-black text-zinc-100 tracking-tight flex items-center gap-3">
          <span class="w-1 h-6 bg-blue-600 rounded-full"></span>
          Recently Added Movies
        </h2>
        <a href="/collection/movies?sort=created_at" class="text-sm font-bold uppercase tracking-widest text-zinc-500 hover:text-blue-400 transition-all flex items-center gap-2 group/all">
          See All <span class="group-hover/all:translate-x-1 transition-transform">→</span>
        </a>
      </div>
      <div class="flex gap-3 overflow-x-auto pb-3 scrollbar-none -mx-6 px-6 md:mx-0 md:px-0">
        {recentMovies.results.map((item) => (
          <div class="flex-shrink-0 w-40"><MediaCard item={item} /></div>
        ))}
      </div>
    </section>
  )}

  {recentShows.results?.length > 0 && (
    <section class="mb-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-black text-zinc-100 tracking-tight flex items-center gap-3">
          <span class="w-1 h-6 bg-blue-600 rounded-full"></span>
          Recently Added Episodes
        </h2>
        <a href="/collection/shows?sort=created_at" class="text-sm font-bold uppercase tracking-widest text-zinc-500 hover:text-blue-400 transition-all flex items-center gap-2 group/all">
          See All <span class="group-hover/all:translate-x-1 transition-transform">→</span>
        </a>
      </div>
      <div class="flex gap-3 overflow-x-auto pb-3 scrollbar-none -mx-6 px-6 md:mx-0 md:px-0">
        {recentShows.results.map((item) => (
          <div class="flex-shrink-0 w-56"><EpisodeCard item={item} /></div>
        ))}
      </div>
    </section>
  )}

  {hasTmdbKey && (
    <section class="relative mb-16 rounded-3xl overflow-hidden h-48 sm:h-56 flex items-center">
      <img src={discoverBackdropUrl} alt="" class="absolute inset-0 w-full h-full object-cover" loading="lazy" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-zinc-950/90 via-zinc-950/60 to-zinc-950/20"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-zinc-950/60 via-transparent to-transparent"></div>
      <div class="relative px-8 sm:px-12">
        <p class="text-xs font-black uppercase tracking-[0.2em] text-zinc-400 mb-2">What to watch next?</p>
        <h2 class="text-2xl sm:text-3xl font-black text-zinc-100 mb-5 leading-tight">Explore movies & shows<br class="hidden sm:block" /> you haven't seen yet.</h2>
        <a
          href="/discover"
          class="inline-flex items-center gap-2 px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white font-black rounded-2xl transition-all shadow-xl shadow-blue-900/40 active:scale-95 text-sm uppercase tracking-wider"
        >
          Discover
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
          </svg>
        </a>
      </div>
    </section>
  )}

  {hasTmdbKey && (
    <>
      <!-- Trending Movies -->
      <section class="mb-16" id="section-trending-movies">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl font-black text-zinc-100 tracking-tight flex items-center gap-3">
            <span class="w-1 h-6 bg-blue-600 rounded-full"></span>
            Trending Movies
          </h2>
          <a href="/trending/movies" class="text-sm font-bold uppercase tracking-widest text-zinc-500 hover:text-blue-400 transition-all flex items-center gap-2 group/all">
            See All <span class="group-hover/all:translate-x-1 transition-transform">→</span>
          </a>
        </div>
        <div class="flex gap-3 overflow-x-auto pb-3 scrollbar-none -mx-6 px-6 md:mx-0 md:px-0" id="grid-trending-movies">
          {Array.from({ length: 10 }).map(() => (
            <div class="flex-shrink-0 w-40 animate-pulse rounded-2xl overflow-hidden bg-zinc-900 border border-zinc-800">
              <div class="aspect-[2/3] bg-zinc-800"></div>
              <div class="p-3 space-y-2">
                <div class="h-3 bg-zinc-800 rounded w-3/4"></div>
                <div class="h-2 bg-zinc-800 rounded w-1/4"></div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Trending Shows -->
      <section class="mb-16" id="section-trending-shows">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl font-black text-zinc-100 tracking-tight flex items-center gap-3">
            <span class="w-1 h-6 bg-blue-600 rounded-full"></span>
            Trending Shows
          </h2>
          <a href="/trending/shows" class="text-sm font-bold uppercase tracking-widest text-zinc-500 hover:text-blue-400 transition-all flex items-center gap-2 group/all">
            See All <span class="group-hover/all:translate-x-1 transition-transform">→</span>
          </a>
        </div>
        <div class="flex gap-3 overflow-x-auto pb-3 scrollbar-none -mx-6 px-6 md:mx-0 md:px-0" id="grid-trending-shows">
          {Array.from({ length: 10 }).map(() => (
            <div class="flex-shrink-0 w-40 animate-pulse rounded-2xl overflow-hidden bg-zinc-900 border border-zinc-800">
              <div class="aspect-[2/3] bg-zinc-800"></div>
              <div class="p-3 space-y-2">
                <div class="h-3 bg-zinc-800 rounded w-3/4"></div>
                <div class="h-2 bg-zinc-800 rounded w-1/4"></div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Airing Today -->
      <section class="mb-16" id="section-airing-today">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl font-black text-zinc-100 tracking-tight flex items-center gap-3">
            <span class="w-1 h-6 bg-blue-600 rounded-full"></span>
            Airing Today
          </h2>
          <a href="/airing-today" class="text-sm font-bold uppercase tracking-widest text-zinc-500 hover:text-blue-400 transition-all flex items-center gap-2 group/all">
            See All <span class="group-hover/all:translate-x-1 transition-transform">→</span>
          </a>
        </div>
        <div class="flex gap-3 overflow-x-auto pb-3 scrollbar-none -mx-6 px-6 md:mx-0 md:px-0" id="grid-airing-today">
          {Array.from({ length: 10 }).map(() => (
            <div class="flex-shrink-0 w-56 animate-pulse rounded-2xl overflow-hidden bg-zinc-900 border border-zinc-800">
              <div class="aspect-[3/2] bg-zinc-800"></div>
            </div>
          ))}
        </div>
      </section>

    </>
  )}
</Base>

<script define:vars={{ token }}>

  function esc(str) {
          if (str == null) return '';
          return String(str)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
        }

  // ─────────────────────────────────────────────────────────────────────────

        function mediaCardHtml(item) {
          const isSeries = item.type === 'series';
          const href = isSeries
            ? `/show/${item.tmdb_id}`
            : `/media/${item.type}/${item.tmdb_id}`;
          const year = item.release_date ? item.release_date.slice(0, 4) : null;
          const rating = item.tmdb_rating ? Number(item.tmdb_rating).toFixed(1) : null;
          const raw = item.poster_path;
          const posterUrl = raw
            ? (raw.startsWith('http') ? raw : `https://image.tmdb.org/t/p/w500${raw}`)
            : null;
          const typeLabel = isSeries ? 'Show' : 'Movie';
          const watched = item.watched ?? false;
          const inLists = item.in_lists ?? [];
          const inLibrary = item.in_library ?? false;
          const collectionPct = item.collection_pct ?? (inLibrary ? 100 : 0);
          const watchPct = item.watch_pct ?? (watched ? 100 : 0);
          const watchActive = isSeries ? watchPct > 0 : watched;
          const collectStyle = isSeries && collectionPct > 0
            ? `background: linear-gradient(to right, rgba(168,85,247,0.2) ${collectionPct}%, transparent ${collectionPct}%)`
            : '';
          const watchedFill = watched ? 'currentColor' : 'none';
          const collectedFill = 'none';

          return `<div
            class="flex-shrink-0 w-40 group relative flex flex-col rounded-2xl overflow-hidden bg-zinc-900 border border-zinc-800 hover:border-blue-500/50 hover:shadow-2xl hover:shadow-blue-900/20 transition-all duration-300 transform hover:-translate-y-1 active:scale-95 active:opacity-70"
            data-card
            data-tmdb-id="${esc(String(item.tmdb_id))}"
            data-media-type="${esc(item.type)}"
            data-show-tmdb-id=""
            data-season=""
          >
            <a href="${esc(href)}" class="block">
              <div class="aspect-[2/3] bg-zinc-950 relative overflow-hidden ring-1 ring-white/5 group-hover:ring-blue-500/30 transition-all duration-300">
                ${posterUrl
                  ? `<img src="${esc(posterUrl)}" alt="${esc(item.title)}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" decoding="async" />`
                  : `<div class="w-full h-full flex flex-col items-center justify-center text-zinc-700 bg-zinc-900 p-4 text-center"><span class="text-3xl mb-2 opacity-30">🎬</span><span class="text-xs font-bold uppercase tracking-widest">${esc(item.title)}</span></div>`
                }
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                ${rating ? `<div class="absolute top-2 right-2 bg-black/80 backdrop-blur-md text-yellow-400 text-[10px] font-black px-2 py-0.5 rounded-full shadow-lg border border-zinc-800 flex items-center gap-1"><span class="text-xs leading-none">★</span> ${esc(rating)}</div>` : ''}
              </div>
            </a>
            <div class="grid grid-cols-3 flex-shrink-0">
              <button data-action="watched" data-watched="${watched}" data-watch-pct="${watchPct}" data-state="${watchActive ? 'active' : 'inactive'}"
                title="${isSeries ? `${watchPct}% watched` : (watched ? 'Mark as unwatched' : 'Mark as watched')}"
                class="flex flex-col items-center justify-center gap-1 py-2.5 transition-all cursor-pointer border-r border-zinc-800/60 hover:brightness-125 ${watchActive ? 'bg-green-500/20 text-green-400' : 'bg-zinc-900 text-zinc-400 hover:bg-green-500/10 hover:text-green-500'}">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3" fill="${watchActive ? 'currentColor' : 'none'}"/>
                </svg>
                <span class="text-[8px] font-bold uppercase tracking-wider leading-none">${isSeries ? `${watchPct}%` : 'Watched'}</span>
              </button>
              <button data-action="list" data-in-lists="${esc(JSON.stringify(inLists))}" data-state="${inLists.length > 0 ? 'active' : 'inactive'}" title="Add to list"
                class="flex flex-col items-center justify-center gap-1 py-2.5 transition-all cursor-pointer border-r border-zinc-800/60 hover:brightness-125 ${inLists.length > 0 ? 'bg-sky-500/20 text-sky-400' : 'bg-zinc-900 text-zinc-400 hover:bg-sky-500/10 hover:text-sky-400'}">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/>
                  <line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>
                </svg>
                <span class="text-[8px] font-bold uppercase tracking-wider leading-none">Lists</span>
              </button>
              <button data-action="collected" data-in-library="${inLibrary}" data-collection-pct="${collectionPct}" data-state="${(inLibrary || collectionPct > 0) ? 'active' : 'inactive'}"
                title="${isSeries ? `${collectionPct}% in library` : (inLibrary ? 'In collection' : 'Add to collection')}"
                style="${esc(collectStyle)}"
                class="relative flex flex-col items-center justify-center gap-1 py-2.5 transition-all cursor-pointer overflow-hidden hover:brightness-125 ${(inLibrary || collectionPct > 0) ? 'bg-purple-500/20 text-purple-400' : 'bg-zinc-900 text-zinc-400 hover:bg-purple-500/10 hover:text-purple-400'}">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="${collectedFill}" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m2 7 4.41-4.41A2 2 0 0 1 7.83 2h8.34a2 2 0 0 1 1.42.59L22 7"/>
                  <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
                  <path d="M15 22v-4a3 3 0 0 0-6 0v4"/>
                  <path d="M2 7h20"/>
                </svg>
                <span class="text-[8px] font-bold uppercase tracking-wider leading-none">${isSeries ? `${collectionPct}%` : 'Collected'}</span>
              </button>
            </div>
            <a href="${esc(href)}" class="block p-3 bg-gradient-to-b from-zinc-900 to-zinc-950 flex-1">
              <h3 class="text-sm font-bold text-zinc-100 truncate group-hover:text-blue-400 transition-colors leading-tight mb-1">${esc(item.title)}</h3>
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                  ${year ? `<span class="text-[11px] font-medium text-zinc-500 tracking-wide">${esc(year)}</span>` : ''}
                </div>
                <span class="text-[9px] font-black text-zinc-400 uppercase tracking-widest px-1.5 py-0.5 bg-zinc-800/50 rounded border border-zinc-800">${typeLabel}</span>
              </div>
            </a>
          </div>`;
        }

        function episodeCardHtml(item) {
          const isSeries = item.type === 'series';
          const href = item.show_tmdb_id && item.season_number != null && item.episode_number != null
            ? `/show/${item.show_tmdb_id}/season/${item.season_number}/${item.episode_number}`
            : item.show_tvdb_id && item.season_number != null && item.episode_number != null
              ? `/show/tvdb/${item.show_tvdb_id}/season/${item.season_number}/${item.episode_number}`
              : isSeries
                ? `/show/${item.tmdb_id}`
                : `/media/${item.type}/${item.tmdb_id}`;
          const raw = isSeries ? (item.backdrop_path ?? item.poster_path) : item.poster_path;
          const imageUrl = raw
            ? (raw.startsWith('http') ? raw : `https://image.tmdb.org/t/p/w780${raw}`)
            : null;
          const sxe = item.season_number != null && item.episode_number != null
            ? `S${String(item.season_number).padStart(2, '0')}E${String(item.episode_number).padStart(2, '0')}`
            : null;

          return `<a href="${esc(href)}" class="flex-shrink-0 w-56 group relative block rounded-2xl overflow-hidden bg-zinc-900 border border-zinc-800 hover:border-blue-500/50 hover:shadow-2xl hover:shadow-blue-900/20 transition-all duration-300 transform hover:-translate-y-1 active:scale-95 active:opacity-70">
            <div class="aspect-[3/2] bg-zinc-950 relative overflow-hidden ring-1 ring-white/5 group-hover:ring-blue-500/30 transition-all duration-300">
              ${imageUrl
                ? `<img src="${esc(imageUrl)}" alt="${esc(item.show_title ?? item.title)}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async" />`
                : `<div class="w-full h-full flex flex-col items-center justify-center p-4 text-center bg-[#18181b]"><span class="text-3xl mb-2 opacity-30">📺</span><span class="text-xs font-bold uppercase tracking-widest text-[#52525b]">${esc(item.show_title ?? item.title)}</span></div>`
              }
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
              ${sxe ? `<div class="absolute top-2 left-2 bg-blue-600/90 backdrop-blur-md text-white text-[10px] font-black px-2 py-0.5 rounded-full shadow-lg border border-blue-500/30">${esc(sxe)}</div>` : ''}
              <div class="absolute bottom-0 left-0 right-0 p-3">
                ${item.show_title ? `<p class="text-[11px] font-bold text-white/70 truncate leading-tight">${esc(item.show_title)}</p>` : ''}
                <h3 class="text-sm font-bold text-white truncate group-hover:text-blue-300 transition-colors leading-tight">${esc(item.title)}</h3>
              </div>
            </div>
          </a>`;
        }

        async function loadSection(url, gridId, renderFn, limit) {
          const grid = document.getElementById(gridId);
          if (!grid) return;
          try {
            const res = await fetch(url, {
              headers: { 'Authorization': `Bearer ${token}` },
            });
            if (!res.ok) {
              grid.closest('section').remove();
              return;
            }
            const data = await res.json();
            const items = (data.results ?? []).slice(0, limit);
            if (items.length === 0) {
              grid.closest('section').remove();
              return;
            }
            grid.innerHTML = items.map(renderFn).join('');
          } catch {
            grid.closest('section').remove();
          }
        }

        loadSection('/api/proxy/media/trending/movies', 'grid-trending-movies', mediaCardHtml, 12);
        loadSection('/api/proxy/media/trending/shows', 'grid-trending-shows', mediaCardHtml, 12);
        loadSection('/api/proxy/media/airing-today/collected', 'grid-airing-today', episodeCardHtml, 12);

        // Continue watching dismiss
        document.addEventListener('click', async (e) => {
          const btn = e.target.closest('.dismiss-cw');
          if (!btn) return;
          e.preventDefault();
          e.stopPropagation();
          const mediaId = btn.dataset.mediaId;
          const card = btn.closest('.flex-shrink-0');
          if (card) card.style.opacity = '0.4';
          try {
            await fetch(`/api/proxy/history/continue-watching?media_id=${mediaId}`, {
              method: 'DELETE',
              headers: { 'Authorization': `Bearer ${token}` },
            });
            card?.remove();
            const section = document.getElementById('continue-watching-section');
            if (section && section.querySelectorAll('.dismiss-cw').length === 0) {
              section.remove();
            }
          } catch {
            if (card) card.style.opacity = '';
          }
        });
</script>
