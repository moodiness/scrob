  // ── MDBList progress tracking ─────────────────────────────────────────────
  let mdblistPoller: ReturnType<typeof setTimeout> | null = null;
  let mdblistHideTimer: ReturnType<typeof setTimeout> | null = null;
  // The job id we last observed as pending/running. If that exact job later shows
  // up as completed/failed, we show it regardless of how much wall-clock time has
  // passed — comparing against job.updated_at alone is unreliable because browsers
  // throttle setTimeout in backgrounded tabs (e.g. the user switching away to check
  // mdblist.com while the push runs), which can delay the next poll well past any
  // fixed "recently completed" window and make the job look stale when it isn't.
  let mdblistTrackedJobId: number | null = null;

  function renderMdblistProgress(job: any) {
    const strip = document.getElementById('mdblist-progress');
    const bar = document.getElementById('mdblist-job-bar');
    const pctEl = document.getElementById('mdblist-job-pct');
    const label = document.getElementById('mdblist-job-label');
    const items = document.getElementById('mdblist-job-items');
    if (!strip) return;
    if (!job) { strip.classList.add('hidden'); return; }
    strip.classList.remove('hidden');

    const isPush = job.job_type === 'push';
    const isFailed = job.status === 'failed';
    const isCompleted = job.status === 'completed';
    const isPending = job.status === 'pending';

    if (isFailed) {
      if (bar) { bar.className = 'h-1.5 rounded-full transition-all duration-500 bg-red-500'; bar.style.width = '100%'; }
      if (label) label.textContent = isPush ? 'Push failed' : 'Pull failed';
      if (pctEl) pctEl.textContent = '';
      if (items) items.textContent = esc(job.error_message || 'Unknown error');
      return;
    }
    if (isCompleted) {
      if (bar) { bar.className = 'h-1.5 rounded-full transition-all duration-500 bg-violet-500'; bar.style.width = '100%'; }
      if (label) label.textContent = isPush ? 'Push complete' : 'Pull complete';
      if (pctEl) pctEl.textContent = '100%';
      if (items) items.textContent = `${job.processed_items ?? 0} items`;
      return;
    }

    const pct = job.total_items > 0 ? Math.min(100, Math.round((job.processed_items / job.total_items) * 100)) : 0;
    const indeterminate = isPending || pct === 0;
    if (bar) {
      bar.className = `h-1.5 rounded-full transition-all duration-500 bg-violet-500${indeterminate ? ' animate-pulse' : ''}`;
      bar.style.width = indeterminate ? '100%' : `${pct}%`;
    }
    if (label) label.textContent = isPush ? (isPending ? 'Push queued…' : 'Pushing…') : (isPending ? 'Pull queued…' : 'Pulling…');
    if (pctEl) pctEl.textContent = pct > 0 ? `${pct}%` : '';
    if (items) items.textContent = job.total_items > 0 ? `${job.processed_items} / ${job.total_items} items` : 'Loading…';
  }

  async function pollMdblistJob() {
    try {
      const res = await fetch('/api/proxy/sync/status', { headers: { 'Authorization': `Bearer ${token}` } });
      if (!res.ok) return;
      const jobs: any[] = await res.json();
      const job = jobs.find(j => j.source === 'mdblist');
      const isActive = job && (job.status === 'pending' || job.status === 'running');
      const isDone = job && (job.status === 'completed' || job.status === 'failed');
      const isFresh = job && new Date(job.updated_at).getTime() > Date.now() - 8000;
      const isTrackedJobDone = isDone && job.id === mdblistTrackedJobId;

      if (isActive) {
        mdblistTrackedJobId = job.id;
        renderMdblistProgress(job);
        mdblistPoller = setTimeout(pollMdblistJob, 2000);
        return;
      }

      if (isDone && (isTrackedJobDone || isFresh)) {
        renderMdblistProgress(job);
        if (mdblistHideTimer != null) clearTimeout(mdblistHideTimer);
        mdblistHideTimer = setTimeout(() => { renderMdblistProgress(null); mdblistHideTimer = null; }, 8000);
      } else {
        renderMdblistProgress(null);
      }
      mdblistTrackedJobId = null;
      mdblistPoller = null;
    } catch {
      mdblistPoller = null;
    }
  }

  function startMdblistPoller() {
    if (mdblistPoller != null) clearTimeout(mdblistPoller);
    pollMdblistJob();
  }

  document.addEventListener('visibilitychange', () => {
    // Backgrounded tabs get their setTimeout throttled, which can delay the next
    // poll long enough that a completed push silently disappears (see note above).
    // Re-check immediately when the user comes back so they get the real state
    // right away instead of whatever the delayed timer eventually catches.
    if (document.visibilityState === 'visible' && mdblistTrackedJobId != null) {
      if (mdblistPoller != null) clearTimeout(mdblistPoller);
      pollMdblistJob();
    }
  });

  // ── Heal progress tracking ────────────────────────────────────────────────
  let healPoller: ReturnType<typeof setTimeout> | null = null;

  function renderHealProgress(job: any) {
    const strip = document.getElementById('heal-progress');
    const bar   = document.getElementById('heal-job-bar');
    const pctEl = document.getElementById('heal-job-pct');
    const label = document.getElementById('heal-job-label');
    const items = document.getElementById('heal-job-items');
    if (!strip) return;

    if (!job) { strip.classList.add('hidden'); return; }
    strip.classList.remove('hidden');

    const isFailed    = job.status === 'failed';
    const isCompleted = job.status === 'completed';
    const isPending   = job.status === 'pending';

    if (isFailed) {
      if (bar) { bar.className = 'h-1.5 rounded-full transition-all duration-500 bg-red-500'; bar.style.width = '100%'; }
      if (label) label.textContent = 'Heal failed';
      if (pctEl) pctEl.textContent = '';
      if (items) items.textContent = esc(job.error_message || 'Unknown error');
      return;
    }

    if (isCompleted) {
      if (bar) { bar.className = 'h-1.5 rounded-full transition-all duration-500 bg-blue-600'; bar.style.width = '100%'; }
      if (label) label.textContent = 'Heal complete';
      if (pctEl) pctEl.textContent = '100%';
      if (items) items.textContent = `${job.processed_items} item${job.processed_items !== 1 ? 's' : ''} healed`;
      return;
    }

    const pct = job.total_items > 0 ? Math.min(100, Math.round((job.processed_items / job.total_items) * 100)) : 0;
    const indeterminate = isPending || pct === 0;
    if (bar) {
      bar.className = `h-1.5 rounded-full transition-all duration-500 bg-blue-600${indeterminate ? ' animate-pulse' : ''}`;
      bar.style.width = indeterminate ? '100%' : `${pct}%`;
    }
    if (label) label.textContent = isPending ? 'Heal queued…' : 'Healing…';
    if (pctEl) pctEl.textContent = pct > 0 ? `${pct}%` : '';
    if (items) items.textContent = job.total_items > 0 ? `${job.processed_items} / ${job.total_items} items` : 'Loading…';
  }

  async function pollHealJob() {
    try {
      const res = await fetch('/api/proxy/sync/status', { headers: { 'Authorization': `Bearer ${token}` } });
      if (!res.ok) return;
      const jobs: any[] = await res.json();
      const job = jobs.find((j: any) => j.source === 'tmdb' && j.job_type === 'heal');
      const isActive = job && (job.status === 'pending' || job.status === 'running');
      const isRecentDone = job && (job.status === 'completed' || job.status === 'failed')
        && new Date(job.updated_at).getTime() > Date.now() - 8000;
      renderHealProgress((isActive || isRecentDone) ? job : null);
      if (isActive) {
        healPoller = setTimeout(pollHealJob, 2000);
      } else if (isRecentDone) {
        healPoller = setTimeout(() => { renderHealProgress(null); healPoller = null; }, 4000);
      } else {
        healPoller = null;
      }
    } catch {
      healPoller = null;
    }
  }

  function startHealPoller() {
    if (healPoller != null) clearTimeout(healPoller);
    pollHealJob();
  }

  // On page load, resume any in-progress jobs
  (async () => {
    try {
      const res = await fetch('/api/proxy/sync/status', {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (!res.ok) return;
      const jobs: any[] = await res.json();
      for (const job of jobs) {
        if (job.connection_id && (job.status === 'pending' || job.status === 'running')) {
          startConnPoller(String(job.connection_id));
        }
        if (job.source === 'simkl' && (job.status === 'pending' || job.status === 'running')) {
          startSimklPoller();
        }
        if (job.source === 'trakt' && (job.status === 'pending' || job.status === 'running')) {
          startTraktPoller();
        }
        if (job.source === 'mdblist' && (job.status === 'pending' || job.status === 'running')) {
          startMdblistPoller();
        }
        if (job.source === 'tmdb' && job.job_type === 'heal' && (job.status === 'pending' || job.status === 'running')) {
          startHealPoller();
        }
      }
    } catch { /* non-fatal */ }
  })();
  // ── End progress tracking ─────────────────────────────────────────────────

  function formatList(items: string[]): string {
    if (items.length === 0) return '';
    if (items.length === 1) return items[0];
    if (items.length === 2) return `${items[0]} and ${items[1]}`;
    return `${items.slice(0, -1).join(', ')}, and ${items[items.length - 1]}`;
  }

  function showConfirmModal(title: string, body: string, confirmLabel: string, infoOnly = false): Promise<boolean> {
    return new Promise(resolve => {
      const modal = document.getElementById('confirm-action-modal');
      const titleEl = document.getElementById('confirm-action-title');
      const bodyEl = document.getElementById('confirm-action-body');
      const confirmBtn = document.getElementById('confirm-action') as HTMLButtonElement | null;
      const cancelBtn = document.getElementById('cancel-action') as HTMLButtonElement | null;
      if (!modal || !titleEl || !bodyEl || !confirmBtn || !cancelBtn) { resolve(false); return; }
      titleEl.textContent = title;
      bodyEl.textContent = body;
      confirmBtn.textContent = confirmLabel;
      cancelBtn.classList.toggle('hidden', infoOnly);
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      const cleanup = (result: boolean) => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        cancelBtn.classList.remove('hidden');
        confirmBtn.removeEventListener('click', onConfirm);
        cancelBtn.removeEventListener('click', onCancel);
        resolve(result);
      };
      const onConfirm = () => cleanup(infoOnly ? false : true);
      const onCancel = () => cleanup(false);
      confirmBtn.addEventListener('click', onConfirm, { once: true });
      cancelBtn.addEventListener('click', onCancel, { once: true });
    });
  }

  function setConnStatus(id, state) {
    const el = document.getElementById(id);
    if (!el) return;
    el.classList.remove('hidden');
    if (state === 'checking') {
      el.textContent = 'Checking…';
      el.className = 'text-xs font-normal px-1.5 py-0.5 rounded bg-zinc-700 text-zinc-400';
    } else if (state === 'connected') {
      el.textContent = '● Connected';
      el.className = 'text-xs font-normal px-1.5 py-0.5 rounded bg-green-500/15 text-green-400';
    } else if (state === 'disconnected') {
      el.textContent = '● Disconnected';
      el.className = 'text-xs font-normal px-1.5 py-0.5 rounded bg-red-500/15 text-red-400';
    }
  }

  function populateSelect(selectId, options, currentValue) {
    const sel = document.getElementById(selectId);
    if (!sel) return;
    sel.innerHTML = '<option value="">-- Select --</option>' + options.map(o => {
      const val = String(o.value ?? o.path ?? o.id ?? '');
      const label = o.label ?? o.name ?? o.path ?? val;
      const selected = val === String(currentValue ?? '') ? 'selected' : '';
      return `<option value="${esc(val)}" ${selected}>${esc(label)}</option>`;
    }).join('');
  }

  async function checkConnections() {
    if (!token) return;
    const traktConnected = !!document.getElementById('trakt-disconnect-btn');
    const simklConnected = !!document.getElementById('simkl-disconnect-btn');
    const mdblistConfigured = !!document.getElementById('mdblist_api_key')?.value;
    const radarrConfigured = !!document.getElementById('radarr_url')?.value;
    const sonarrConfigured = !!document.getElementById('sonarr_url')?.value;
    const mediaServerIds = Array.from(document.querySelectorAll<HTMLElement>('[data-connection-id]'))
      .map(el => el.getAttribute('data-connection-id'))
      .filter(Boolean) as string[];
    if (!radarrConfigured && !sonarrConfigured && !traktConnected && !simklConnected && !mdblistConfigured && mediaServerIds.length === 0) return;

    if (radarrConfigured) setConnStatus('radarr-conn-status', 'checking');
    if (sonarrConfigured) setConnStatus('sonarr-conn-status', 'checking');
    if (traktConnected) setConnStatus('trakt-conn-status', 'checking');
    if (simklConnected) setConnStatus('simkl-conn-status', 'checking');
    if (mdblistConfigured) setConnStatus('mdblist-conn-status', 'checking');
    for (const id of mediaServerIds) setConnStatus(`conn-status-${id}`, 'checking');

    try {
      const res = await fetch('/api/proxy/auth/connection-status', {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (!res.ok) return;
      const data = await res.json();

      if (data.radarr?.configured) {
        setConnStatus('radarr-conn-status', data.radarr.connected ? 'connected' : 'disconnected');
        if (data.radarr.connected) {
          const currentFolder = document.getElementById('radarr_root_folder')?.value;
          const currentProfile = document.getElementById('radarr_quality_profile')?.value;
          populateSelect('radarr_root_folder', (data.radarr.root_folders ?? []).map(f => ({
            value: f.path,
            label: `${f.path} (${(f.freeSpace / 1024 ** 3).toFixed(1)} GB free)`
          })), currentFolder);
          populateSelect('radarr_quality_profile', data.radarr.quality_profiles ?? [], currentProfile);
          const tagContainer = document.getElementById('radarr_tags_list');
          const selectedTags = Array.from(tagContainer?.querySelectorAll('input[name="radarr_tags"]') ?? []).map(i => parseInt(i.value));
          renderTags('radarr_tags_list', data.radarr.tags, selectedTags, 'radarr');
        }
      }
      if (data.sonarr?.configured) {
        setConnStatus('sonarr-conn-status', data.sonarr.connected ? 'connected' : 'disconnected');
        if (data.sonarr.connected) {
          const currentFolder = document.getElementById('sonarr_root_folder')?.value;
          const currentProfile = document.getElementById('sonarr_quality_profile')?.value;
          populateSelect('sonarr_root_folder', (data.sonarr.root_folders ?? []).map(f => ({
            value: f.path,
            label: `${f.path} (${(f.freeSpace / 1024 ** 3).toFixed(1)} GB free)`
          })), currentFolder);
          populateSelect('sonarr_quality_profile', data.sonarr.quality_profiles ?? [], currentProfile);
          const tagContainer = document.getElementById('sonarr_tags_list');
          const selectedTags = Array.from(tagContainer?.querySelectorAll('input[name="sonarr_tags"]') ?? []).map(i => parseInt(i.value));
          renderTags('sonarr_tags_list', data.sonarr.tags, selectedTags, 'sonarr');
        }
      }
      if (data.trakt?.configured) {
        setConnStatus('trakt-conn-status', data.trakt.connected ? 'connected' : 'disconnected');
      }
      if (data.simkl?.configured) {
        setConnStatus('simkl-conn-status', data.simkl.connected ? 'connected' : 'disconnected');
      }
      if (data.mdblist?.configured) {
        setConnStatus('mdblist-conn-status', data.mdblist.connected ? 'connected' : 'disconnected');
      }
      for (const cs of (data.connections ?? [])) {
        setConnStatus(`conn-status-${cs.id}`, cs.connected ? 'connected' : 'disconnected');
        if (cs.token) {
          const card = document.querySelector(`[data-connection-id="${cs.id}"]`);
          const tokenInput = card?.querySelector('.conn-token-input') as HTMLInputElement | null;
          if (tokenInput) tokenInput.value = cs.token;
        }
        if (cs.profiles?.length) {
          const card = document.querySelector(`[data-connection-id="${cs.id}"]`);
          const profileSelect = card?.querySelector('.conn-user-id-input') as HTMLSelectElement | null;
          if (profileSelect) {
            const selectedProfile = profileSelect.value;
            profileSelect.innerHTML = cs.profiles.map((profile: any) =>
              `<option value="${esc(String(profile.profile_index))}">${esc(profile.name || `Profile ${profile.profile_index}`)} (#${esc(String(profile.profile_index))})</option>`
            ).join('');
            if ([...profileSelect.options].some(option => option.value === selectedProfile)) {
              profileSelect.value = selectedProfile;
            }
          }
        }
        if (cs.connected) loadLibraries(String(cs.id));
      }
    } catch {
      // Non-fatal — status badges stay hidden
    }
  }

  async function loadLibraries(connId: string) {
    const card = document.querySelector(`[data-connection-id="${connId}"]`);
    const picker = card?.querySelector('.conn-library-picker');
    const connType = picker?.getAttribute('data-conn-type') ?? '';
    const listEl = card?.querySelector('.conn-libraries-list') as HTMLElement | null;
    if (!listEl) return;
    listEl.textContent = 'Loading…';
    listEl.classList.add('italic', 'text-zinc-500');
    try {
      const res = await fetch(`/api/proxy/sync/connection/${connId}/libraries`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.ok) {
        const data = await res.json();
        const idKey = connType === 'plex' ? 'key' : 'id';
        listEl.classList.remove('italic', 'text-zinc-500');
        if (!data.libraries?.length) {
          listEl.innerHTML = '<span class="not-italic text-zinc-500 text-sm">No supported libraries found.</span>';
          return;
        }
        listEl.innerHTML = data.libraries.map((lib: any) => `
          <label class="flex items-center gap-2 cursor-pointer group px-2 py-1.5 rounded-lg border border-transparent hover:bg-zinc-800/50 transition-colors">
            <input type="checkbox" class="library-checkbox w-4 h-4 rounded accent-blue-500 cursor-pointer" data-id="${esc(String(lib[idKey]))}" ${lib.selected ? 'checked' : ''} />
            <span class="text-zinc-300 group-hover:text-zinc-100 transition-colors not-italic">
              ${esc(lib.name)}
              <span class="text-zinc-400 text-xs ml-1">${lib.type === 'movies' || lib.type === 'movie' ? 'Movies' : 'Shows'}</span>
            </span>
          </label>
        `).join('');
        listEl.querySelectorAll('label').forEach(label => {
          const cb = label.querySelector('input') as HTMLInputElement;
          const updateStyle = () => {
            label.classList.toggle('bg-blue-500/10', cb.checked);
            label.classList.toggle('border-blue-500/30', cb.checked);
            label.classList.toggle('hover:bg-zinc-800/50', !cb.checked);
            label.classList.toggle('border-transparent', !cb.checked);
          };
          cb.addEventListener('change', updateStyle);
          updateStyle();
        });
      } else {
        listEl.classList.remove('italic');
        listEl.textContent = 'Could not load libraries.';
      }
    } catch {
      listEl.classList.remove('italic');
      listEl.textContent = 'Could not reach server.';
    }
  }

  function renderTags(containerId, tags, selectedIds, prefix) {
    const container = document.getElementById(containerId);
    if (!container) return;
    
    if (!tags || tags.length === 0) {
      container.innerHTML = '<span class="text-xs text-zinc-500 italic px-2 py-1">No tags found</span>';
      return;
    }

    container.innerHTML = tags.map(tag => {
      const isSelected = selectedIds.includes(tag.id);
      return `
        <label class="group relative flex items-center gap-1.5 px-2 py-1 bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 rounded-md cursor-pointer transition-colors ${isSelected ? 'ring-1 ring-blue-500 border-blue-500/50 bg-blue-500/10' : ''}">
          <input type="checkbox" name="${prefix}_tags" value="${esc(String(tag.id))}" ${isSelected ? 'checked' : ''} class="hidden tag-checkbox" />
          <span class="text-xs font-medium text-zinc-300 group-hover:text-zinc-100">${esc(tag.label)}</span>
        </label>
      `;
    }).join('');

    // Add click listeners to update styling
    container.querySelectorAll('label').forEach(label => {
      const cb = label.querySelector('input');
      cb.addEventListener('change', () => {
        if (cb.checked) {
          label.classList.add('ring-1', 'ring-blue-500', 'border-blue-500/50', 'bg-blue-500/10');
        } else {
          label.classList.remove('ring-1', 'ring-blue-500', 'border-blue-500/50', 'bg-blue-500/10');
        }
      });
    });
  }

  async function persistMdblistPreferences(keys: string[]) {
    const preferences = Object.fromEntries(keys.map(key => {
      const input = document.querySelector<HTMLInputElement>(`input[name="${key}"]`);
      return [key, input?.checked ?? false];
    }));
    const res = await fetch('/api/proxy/auth/settings', {
      method: 'PATCH',
      headers: {
        'Authorization': `Bearer ${token}`,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify(preferences),
    });
    if (!res.ok) {
      const data = await res.json().catch(() => ({}));
      throw new Error(data.detail || 'Failed to save MDBList options');
    }
  }


  function setupActions() {
    const btns = document.querySelectorAll('.js-action-btn');
    btns.forEach(btn => {
      // Clean up previous listeners if any (important for Astro View Transitions)
      const newBtn = btn.cloneNode(true);
      if (btn.parentNode) {
        btn.parentNode.replaceChild(newBtn, btn);
      }
      
      newBtn.addEventListener('click', async () => {
        const action = newBtn.getAttribute('data-action');
        newBtn.disabled = true;
        const originalHTML = newBtn.innerHTML;
        newBtn.textContent = '...';

        try {
          let url = '';
          let method = 'POST';
          let syncConnId: string | null = null; // set for sync/push actions to start progress poller

          if (action === 'test_tmdb') {
            const val = (document.getElementById('tmdb_api_key') as HTMLInputElement).value;
            url = `/api/proxy/auth/test-tmdb?key=${encodeURIComponent(val)}`;
          } else if (action === 'test_tvdb') {
            const val = (document.getElementById('tvdb_api_key') as HTMLInputElement).value;
            url = `/api/proxy/auth/test-tvdb?key=${encodeURIComponent(val)}`;
          } else if (action === 'test_connection') {
            const connId = newBtn.getAttribute('data-conn-id');
            const connType = newBtn.getAttribute('data-conn-type');
            const card = document.querySelector(`[data-connection-id="${connId}"]`);
            const u = (card?.querySelector('.conn-url-input') as HTMLInputElement)?.value || '';
            const t = (card?.querySelector('.conn-token-input') as HTMLInputElement)?.value || '';
            const ui = (card?.querySelector('.conn-user-id-input') as HTMLInputElement)?.value || '';
            let testRes: Response;
            if (connType === 'nuvio') {
              testRes = await fetch('/api/proxy/auth/test-nuvio', {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                body: JSON.stringify({ url: u, token: t, profile_id: parseInt(ui) }),
              });
            } else {
              let testEndpoint: string;
              if (connType === 'plex') {
                testEndpoint = `/api/proxy/auth/test-plex?url=${encodeURIComponent(u)}&token=${encodeURIComponent(t)}`;
              } else if (connType === 'emby') {
                testEndpoint = `/api/proxy/auth/test-emby?url=${encodeURIComponent(u)}&token=${encodeURIComponent(t)}&user_id=${encodeURIComponent(ui)}`;
              } else {
                testEndpoint = `/api/proxy/auth/test-jellyfin?url=${encodeURIComponent(u)}&token=${encodeURIComponent(t)}&user_id=${encodeURIComponent(ui)}`;
              }
              testRes = await fetch(testEndpoint, { method: 'POST', headers: { 'Authorization': `Bearer ${token}` } });
            }
            const testData = await testRes.json();
            if (testRes.ok) {
              showMessage(testData.message || 'Connection successful!');
              if (connId) setConnStatus(`conn-status-${connId}`, 'connected');
              if (connType === 'nuvio' && connId) {
                const saveTokenRes = await fetch(`/api/proxy/auth/connections/${connId}`, {
                  method: 'PATCH',
                  headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                  body: JSON.stringify({ token: testData.refresh_token }),
                });
                if (!saveTokenRes.ok) throw new Error('Nuvio session was validated but could not be saved');
                const savedConnection = await saveTokenRes.json();
                const tokenInput = card?.querySelector('.conn-token-input') as HTMLInputElement | null;
                if (tokenInput) tokenInput.value = savedConnection.token;
              }
            } else {
              if (connId) setConnStatus(`conn-status-${connId}`, 'disconnected');
              throw new Error(testData.detail || 'Connection test failed');
            }
            return;
          } else if (action === 'save_connection') {
            const connId = newBtn.getAttribute('data-conn-id');
            const card = document.querySelector(`[data-connection-id="${connId}"]`);
            const body: Record<string, any> = {
              url: (card?.querySelector('.conn-url-input') as HTMLInputElement)?.value || undefined,
              token: (card?.querySelector('.conn-token-input') as HTMLInputElement)?.value || undefined,
              server_user_id: (card?.querySelector('.conn-user-id-input') as HTMLInputElement)?.value || null,
              server_username: (card?.querySelector('.conn-username-input') as HTMLInputElement)?.value || null,
              auto_sync_interval: (() => {
                const v = (card?.querySelector('.conn-auto-sync') as HTMLSelectElement)?.value;
                return v ? parseFloat(v) : null;
              })(),
            };
            card?.querySelectorAll('.conn-pref-checkbox').forEach((cb: any) => {
              body[cb.getAttribute('data-pref')] = cb.checked;
            });
            // Collect selected Plex monitored users
            const userPicker = card?.querySelector('.plex-user-picker');
            if (userPicker) {
              const selected = [...userPicker.querySelectorAll('.plex-user-checkbox:checked')].map((cb: any) => cb.getAttribute('data-user-id'));
              body.watchlist_monitored_users = selected;
            }
            const saveRes = await fetch(`/api/proxy/auth/connections/${connId}`, {
              method: 'PATCH',
              headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
              body: JSON.stringify(body),
            });
            if (!saveRes.ok) {
              const err = await saveRes.json();
              throw new Error(err.detail || 'Failed to save connection');
            }
            const savedConnection = await saveRes.json();
            const savedTokenInput = card?.querySelector('.conn-token-input') as HTMLInputElement | null;
            if (savedTokenInput && savedConnection.token) savedTokenInput.value = savedConnection.token;
            // Save libraries if they've been loaded
            const libList = card?.querySelector('.conn-libraries-list');
            if (libList && libList.querySelector('.library-checkbox')) {
