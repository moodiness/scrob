          } else if (action === 'push_mdblist') {
            const labels: Record<string, string> = {
              mdblist_push_watched: 'watched history',
              mdblist_push_ratings: 'ratings',
              mdblist_push_watchlist: 'watchlist',
              mdblist_push_collection: 'collection',
            };
            const selected = Array.from(document.querySelectorAll<HTMLInputElement>('.sync-pref-checkbox'))
              .filter(el => el.checked && labels[el.name])
              .map(el => labels[el.name]);
            const empty = selected.length === 0;
            const ok = await showConfirmModal(
              empty ? 'Nothing to push' : 'Push to MDBList?',
              empty
                ? 'Enable at least one option in the "Scrob → MDBList" section.'
                : `This will add or update your ${formatList(selected)} on MDBList. Existing remote items are retained.`,
              empty ? 'Got it' : 'Push',
              empty
            );
            if (!ok) return;
            await persistMdblistPreferences(Object.keys(labels));
            url = '/api/proxy/mdblist/push';
          }

          const res = await fetch(url, {
            method,
            headers: { 'Authorization': `Bearer ${token}` }
          });
          const data = await res.json();

          if (res.ok) {
            const showsProgressBar = !!syncConnId || [
              'sync_trakt', 'push_trakt', 'sync_simkl', 'push_simkl', 'sync_mdblist', 'push_mdblist',
            ].includes(action);
            showMessage(data.message || 'Action successful!', 'success', { scroll: !showsProgressBar });
            if (syncConnId) startConnPoller(syncConnId);
            if (action === 'sync_simkl' || action === 'push_simkl') startSimklPoller();
            if (action === 'sync_trakt' || action === 'push_trakt') startTraktPoller();
            if (action === 'sync_mdblist' || action === 'push_mdblist') startMdblistPoller();
          } else {
            if (syncConnId) renderConnProgress(syncConnId, null);
            throw new Error(data.detail || 'Action failed');
          }
        } catch (e) {
          showMessage(e.message, 'error');
        } finally {
          newBtn.disabled = false;
          newBtn.innerHTML = originalHTML;
        }
      });
    });

    // Trakt Device Auth
    function setupTraktAuth() {
      const connectBtn = document.getElementById('trakt-connect-btn');
      const disconnectBtn = document.getElementById('trakt-disconnect-btn');

      if (connectBtn) {
        connectBtn.onclick = async () => {
          connectBtn.disabled = true;
          connectBtn.textContent = 'Starting…';
          try {
            // If credentials aren't saved yet, save them from the input fields first
            const clientIdInput = document.getElementById('trakt_client_id') as HTMLInputElement | null;
            const clientSecretInput = document.getElementById('trakt_client_secret') as HTMLInputElement | null;
            const clientId = clientIdInput?.value.trim() || '';
            const clientSecret = clientSecretInput?.value.trim() || '';
            if (clientId && clientSecret) {
              const saveRes = await fetch('/api/proxy/auth/settings', {
                method: 'PATCH',
                headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                body: JSON.stringify({ trakt_client_id: clientId, trakt_client_secret: clientSecret }),
              });
              if (!saveRes.ok) {
                const err = await saveRes.json();
                throw new Error(err.detail || 'Failed to save Trakt credentials');
              }
            }

            const res = await fetch('/api/proxy/trakt/auth/device/start', {
              method: 'POST',
              headers: { 'Authorization': `Bearer ${token}` },
            });
            if (!res.ok) {
              const err = await res.json();
              throw new Error(err.detail || 'Failed to start Trakt auth');
            }
            const data = await res.json();

            const panel = document.getElementById('trakt-auth-panel');
            const urlEl = document.getElementById('trakt-verify-url');
            const codeEl = document.getElementById('trakt-user-code');
            const statusEl = document.getElementById('trakt-auth-status');
            if (panel) panel.classList.remove('hidden');
            if (urlEl) urlEl.textContent = data.verification_url;
            if (codeEl) codeEl.textContent = data.user_code;
            connectBtn.textContent = 'Waiting…';

            // Poll for token
            const interval = (data.interval || 5) * 1000;
            const deadline = Date.now() + data.expires_in * 1000;
            const poll = async () => {
              if (Date.now() > deadline) {
                if (statusEl) statusEl.textContent = 'Authorization timed out. Please try again.';
                connectBtn.disabled = false;
                connectBtn.textContent = 'Connect Trakt';
                return;
              }
              try {
                const pollRes = await fetch('/api/proxy/trakt/auth/device/poll', {
                  method: 'POST',
                  headers: { 'Authorization': `Bearer ${token}` },
                });
                if (pollRes.ok) {
                  const pollData = await pollRes.json();
                  if (pollData.status === 'connected') {
                    if (statusEl) statusEl.textContent = 'Connected! Reloading…';
                    window.location.reload();
                    return;
                  }
                } else {
                  const err = await pollRes.json();
                  if (statusEl) statusEl.textContent = `Error: ${err.detail || 'Authorization failed'}`;
                  connectBtn.disabled = false;
                  connectBtn.textContent = 'Connect Trakt';
                  return;
                }
              } catch (e) {}
              setTimeout(poll, interval);
            };
            setTimeout(poll, interval);
          } catch (e) {
            showMessage(e.message, 'error');
            connectBtn.disabled = false;
            connectBtn.textContent = 'Connect Trakt';
          }
        };
      }

      if (disconnectBtn) {
        disconnectBtn.onclick = async () => {
          if (!confirm('Disconnect Trakt? This will remove your Trakt tokens from Scrob.')) return;
          disconnectBtn.disabled = true;
          disconnectBtn.textContent = 'Disconnecting…';
          try {
            await fetch('/api/proxy/trakt/auth/disconnect', {
              method: 'DELETE',
              headers: { 'Authorization': `Bearer ${token}` },
            });
            window.location.reload();
          } catch (e) {
            showMessage('Failed to disconnect Trakt', 'error');
            disconnectBtn.disabled = false;
            disconnectBtn.textContent = 'Disconnect';
          }
        };
      }
    }
    setupTraktAuth();

