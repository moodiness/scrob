  function setupSettingsForm() {
    const form = document.getElementById('settings-form');
    const saveBtn = document.getElementById('save-settings-btn');
    if (!form || !saveBtn) return;

    // Plex "Also monitor users" — toggle picker visibility and lazy-load friends
    async function loadPlexFriends(picker: HTMLElement, token: string) {
      const connId = picker.getAttribute('data-conn-id');
      const monitored: string[] = JSON.parse(picker.getAttribute('data-monitored') || '[]');
      const list = picker.querySelector('.plex-user-list') as HTMLElement;
      if (!list || list.querySelector('.plex-user-checkbox')) return; // already loaded
      list.innerHTML = '<p class="text-xs text-zinc-500 italic">Loading users…</p>';
      try {
        const res = await fetch(`/api/proxy/sync/connection/${connId}/plex-friends`, {
          headers: { 'Authorization': `Bearer ${token}` },
        });
        if (!res.ok) throw new Error('Failed to load users');
        const data = await res.json();
        if (!data.friends?.length) {
          list.innerHTML = '<p class="text-xs text-zinc-500 italic">No friends found.</p>';
          return;
        }
        list.innerHTML = data.friends.map((f: any) => `
          <label class="flex items-center gap-3 cursor-pointer group">
            <input type="checkbox" class="plex-user-checkbox w-4 h-4 rounded cursor-pointer"
              data-user-id="${f.watchlist_id}"
              ${monitored.includes(f.watchlist_id) ? 'checked' : ''}
            />
            <span class="text-sm text-zinc-300 group-hover:text-zinc-100 transition-colors">
              ${f.display_name || f.username}
            </span>
          </label>
        `).join('');
      } catch {
        list.innerHTML = '<p class="text-xs text-red-400 italic">Could not load users.</p>';
      }
    }

    document.querySelectorAll('.plex-user-picker-toggle').forEach((btn) => {
      const connId = btn.getAttribute('data-conn-id');
      const picker = document.querySelector(`.plex-user-picker[data-conn-id="${connId}"]`) as HTMLElement | null;
      const chevron = btn.querySelector('.plex-user-picker-chevron') as HTMLElement | null;
      if (!picker) return;

      btn.addEventListener('click', () => {
        const open = !picker.classList.contains('hidden');
        picker.classList.toggle('hidden', open);
        if (chevron) chevron.style.transform = open ? '' : 'rotate(180deg)';
        if (!open) loadPlexFriends(picker, token);
      });
    });

    // Show/hide the watchlist split sub-option based on the Lists checkbox
    const syncListsCb = document.getElementById('trakt_sync_lists') as HTMLInputElement | null;
    const splitRow = document.getElementById('trakt-watchlist-split-row');
    if (syncListsCb && splitRow) {
      syncListsCb.addEventListener('change', () => {
        splitRow.classList.toggle('hidden', !syncListsCb.checked);
      });
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      saveBtn.disabled = true;
      const originalText = saveBtn.textContent;
      saveBtn.textContent = 'Saving...';

      try {
        const saves = [];

        // Gather general settings
        const formData = new FormData(form);
        const settings = {
          tmdb_api_key: formData.get('tmdb_api_key') || null,
          tvdb_api_key: formData.get('tvdb_api_key') || null,

          radarr_url: formData.get('radarr_url') || null,
          radarr_token: formData.get('radarr_token') || null,
          radarr_root_folder: formData.get('radarr_root_folder') || null,
          radarr_quality_profile: formData.get('radarr_quality_profile') ? parseInt(formData.get('radarr_quality_profile')) : null,
          radarr_tags: formData.getAll('radarr_tags').map(id => parseInt(id)),

          sonarr_url: formData.get('sonarr_url') || null,
          sonarr_token: formData.get('sonarr_token') || null,
          sonarr_root_folder: formData.get('sonarr_root_folder') || null,
          sonarr_quality_profile: formData.get('sonarr_quality_profile') ? parseInt(formData.get('sonarr_quality_profile')) : null,
          sonarr_tags: formData.getAll('sonarr_tags').map(id => parseInt(id)),
          sonarr_season_folder: formData.get('sonarr_season_folder') === 'true',

          trakt_client_id: formData.get('trakt_client_id') || null,
          trakt_client_secret: formData.get('trakt_client_secret') || null,

          simkl_client_id: formData.get('simkl_client_id') || null,
          mdblist_api_key: formData.get('mdblist_api_key') || null,
        };

        // Collect boolean checkboxes (cloud sync preferences + app preferences)
        const syncKeys = [
          'trakt_sync_watched', 'trakt_sync_ratings', 'trakt_sync_lists', 'trakt_watchlist_split',
          'trakt_push_watched', 'trakt_push_ratings', 'trakt_push_collection', 'trakt_push_lists', 'trakt_scrobble',
          'simkl_sync_watched', 'simkl_sync_ratings', 'simkl_sync_lists',
          'simkl_push_watched', 'simkl_push_ratings', 'simkl_scrobble',
          'mdblist_sync_watched', 'mdblist_sync_ratings', 'mdblist_sync_watchlist',
          'mdblist_push_watched', 'mdblist_push_ratings', 'mdblist_push_watchlist', 'mdblist_push_collection', 'mdblist_scrobble',
          'blur_explicit',
          'time_format_24h',
          'use_hls_player',
        ] as const;
        const syncPrefs: Record<string, boolean> = {};
        for (const key of syncKeys) {
          const el = form.querySelector<HTMLInputElement>(`[name="${key}"]`);
          if (el) syncPrefs[key] = el.checked;
        }

        // Sync blur_explicit to a cookie (read server-side by Base.astro) and apply immediately
        const blurEl = form.querySelector<HTMLInputElement>('[name="blur_explicit"]');
        if (blurEl) {
          const val = blurEl.checked ? 'true' : 'false';
          document.cookie = `blur_explicit=${val}; path=/; SameSite=Lax; Max-Age=31536000`;
          document.documentElement.classList.toggle('blur-explicit', blurEl.checked);
        }

        const timeFormatEl = form.querySelector<HTMLInputElement>('[name="time_format_24h"]');
        if (timeFormatEl) {
          document.cookie = `time_format_24h=${timeFormatEl.checked ? 'true' : 'false'}; path=/; SameSite=Lax; Max-Age=31536000`;
        }

        saves.push(fetch(`/api/proxy/auth/settings`, {
          method: 'PATCH',
          headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ ...settings, ...syncPrefs }),
        }));

        const results = await Promise.all(saves);
        const failed = results.find(r => !r.ok);
        
        if (failed) {
          const data = await failed.json();
          throw new Error(data.detail || 'Failed to update settings');
        }

        showMessage('Settings updated successfully!');
      } catch (e) {
        showMessage(e.message, 'error');
      } finally {
        saveBtn.disabled = false;
        saveBtn.textContent = originalText;
      }
    });
  }

