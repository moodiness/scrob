  async function copyToClipboard(text: string): Promise<void> {
    if (navigator.clipboard && window.isSecureContext) {
      await navigator.clipboard.writeText(text);
      return;
    }
    // Fallback for HTTP (non-secure context) — works in all browsers
    const el = document.createElement('textarea');
    el.value = text;
    el.style.cssText = 'position:fixed;top:-9999px;left:-9999px;opacity:0';
    document.body.appendChild(el);
    el.focus();
    el.select();
    const ok = document.execCommand('copy');
    document.body.removeChild(el);
    if (!ok) throw new Error('execCommand copy failed');
  }

  function flashCopied(btn: HTMLElement): void {
    btn.innerHTML = CHECK_ICON;
    btn.classList.add('bg-green-900', 'border-green-700', 'text-green-400');
    btn.classList.remove('bg-zinc-800', 'hover:bg-zinc-700', 'border-zinc-700', 'text-zinc-300');
    setTimeout(() => {
      btn.innerHTML = COPY_ICON;
      btn.classList.remove('bg-green-900', 'border-green-700', 'text-green-400');
      btn.classList.add('bg-zinc-800', 'hover:bg-zinc-700', 'border-zinc-700', 'text-zinc-300');
    }, 2000);
  }

  function setupApiKey() {
    const copyBtn = document.getElementById('copy-api-key-btn');
    const regenBtn = document.getElementById('regenerate-api-key-btn');
    const keyInput = document.getElementById('scrob_api_key');

    if (copyBtn && keyInput) {
      copyBtn.addEventListener('click', async () => {
        try {
          await copyToClipboard((keyInput as HTMLInputElement).value);
          flashCopied(copyBtn as HTMLElement);
        } catch {
          showMessage('Could not copy to clipboard', 'error');
        }
      });
    }

    if (regenBtn && keyInput) {
      regenBtn.addEventListener('click', async () => {
        if (!confirm('Are you sure you want to regenerate your API key? The old key will stop working immediately.')) return;

        regenBtn.disabled = true;
        const originalText = regenBtn.textContent;
        regenBtn.textContent = 'Regenerating...';

        try {
          const res = await fetch(`/api/proxy/auth/api-key/regenerate`, {
            method: 'POST',
            headers: { 'Authorization': `Bearer ${token}` },
          });
          if (!res.ok) {
            const data = await res.json();
            throw new Error(data.detail || 'Failed to regenerate key');
          }
          const data = await res.json();
          keyInput.value = data.api_key;
          showMessage('API key regenerated successfully!');
        } catch (e) {
          showMessage(e.message, 'error');
        } finally {
          regenBtn.disabled = false;
          regenBtn.textContent = originalText;
        }
      });
    }
  }

