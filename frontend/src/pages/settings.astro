  async function loadLastSynced() {
    const appData = document.getElementById('app-data') as HTMLElement | null;
    const token = appData?.dataset.token ?? '';
    if (!token) return;

    try {
      const res = await fetch('/api/proxy/sync/status', {
        headers: { 'Authorization': `Bearer ${token}` },
      });
      if (!res.ok) return;
      const jobs: any[] = await res.json();

      function parseUTC(dateStr: string): Date {
        return new Date(dateStr.endsWith('Z') || dateStr.includes('+') ? dateStr : dateStr + 'Z');
      }
      function timeAgo(dateStr: string): string {
        const diff = Math.floor((Date.now() - parseUTC(dateStr).getTime()) / 1000);
        if (diff < 60) return 'just now';
        if (diff < 3600) return `${Math.floor(diff / 60)}m ago`;
        if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
        return `${Math.floor(diff / 86400)}d ago`;
      }

      for (const source of ['jellyfin', 'emby', 'plex', 'nuvio'] as const) {
        const el = document.getElementById(`${source}-last-sync`);
        if (!el) continue;
        const job = jobs.find(j => j.source === source && (j.status === 'completed' || j.status === 'failed'));
        if (!job) continue;
        const label = job.status === 'failed' ? `failed ${timeAgo(job.updated_at)}` : `synced ${timeAgo(job.updated_at)}`;
        el.textContent = label;
        el.classList.remove('hidden');
      }
    } catch {
      // non-fatal
    }
  }

  function escapeHtml(s: string): string {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  async function loadSyncWarnings() {
    const appData = document.getElementById('app-data') as HTMLElement | null;
    const token = appData?.dataset.token ?? '';
    if (!token) return;

    try {
      // Remember which warning detail panes are currently open so we can restore them after rebuild
      const expandedDetails = new Set<string>();
      document.querySelectorAll('[id^="conn-warnings-details-"]').forEach(el => {
        if (!el.classList.contains('hidden')) expandedDetails.add(el.id);
      });

      const [statusRes, overridesRes, matchedRes] = await Promise.all([
        fetch('/api/proxy/sync/status', { headers: { 'Authorization': `Bearer ${token}` } }),
        fetch('/api/proxy/sync/season-overrides', { headers: { 'Authorization': `Bearer ${token}` } }),
        fetch('/api/proxy/sync/matched-shows', { headers: { 'Authorization': `Bearer ${token}` } }),
      ]);
      if (!statusRes.ok) return;
      const jobs: any[] = await statusRes.json();
      const overrides: any[] = overridesRes.ok ? await overridesRes.json() : [];
      const matchedShows: any[] = matchedRes.ok ? await matchedRes.json() : [];

      // Build a lookup: lowercase show_title → matched show info
      // Used to overlay matched state onto SyncJob warnings that lack matched:true stamps
      const matchedShowMap = new Map<string, any>();
      for (const m of matchedShows) {
        if (m.show_title) matchedShowMap.set(m.show_title.toLowerCase(), m);
      }

      const overrideMap = new Map<string, any>();
      for (const o of overrides) {
        overrideMap.set(`${o.source_show_tmdb_id}:${o.source_season_number}`, o);
      }

      // Find all connection warning containers on the page
      const containers = document.querySelectorAll<HTMLElement>('[id^="conn-warnings-"]');
      containers.forEach(container => {
        const connId = container.id.replace('conn-warnings-', '');
        const job = jobs.find(j => String(j.connection_id) === connId && j.status === 'completed' && j.warnings?.length > 0);
        if (!job) { container.classList.add('hidden'); container.innerHTML = ''; return; }

        const warnings: any[] = job.warnings;
        const _updatedAt = job.updated_at.endsWith('Z') || job.updated_at.includes('+') ? job.updated_at : job.updated_at + 'Z';
        const date = new Date(_updatedAt).toLocaleString(undefined, { dateStyle: 'short', timeStyle: 'short' });
        const detailsId = `conn-warnings-details-${connId}`;

        const enrichmentWarnings = warnings.filter((w: any) => w.tmdb_id !== undefined && w.season !== undefined);
        const unmatchedWarnings = warnings.filter((w: any) => w.title !== undefined);

        const renderEnrichment = enrichmentWarnings.length > 0 ? `
          <div class="space-y-1">
            <p class="text-xs text-zinc-500 mb-2">These seasons weren't found on TMDB — the show may be split into separate series there. Use "Remap" to point each season to the correct TMDB show.</p>
            ${enrichmentWarnings.map((w: any) => {
              const key = `${w.tmdb_id}:${w.season}`;
              const existing = overrideMap.get(key);
              const remapAttr = `data-src-tmdb="${w.tmdb_id}" data-src-season="${w.season}" data-src-title="${escapeHtml(w.show)}"`;
              return `
              <div class="flex items-center gap-3 py-1.5 border-b border-zinc-800/60 last:border-0">
                <div class="flex-1 min-w-0">
                  <span class="text-sm text-zinc-200 font-medium">${escapeHtml(w.show)}</span>
                  <span class="ml-2 text-xs text-zinc-500">Season ${w.season}</span>
                  ${existing ? `<span class="ml-2 text-xs text-green-500">→ remapped</span>` : ''}
                </div>
                <span class="text-xs text-zinc-600 shrink-0 mr-2">${w.affected_episodes} ep${w.affected_episodes !== 1 ? 's' : ''}</span>
                <button type="button" class="remap-season-btn text-xs px-2.5 py-1 rounded-lg border cursor-pointer transition-colors shrink-0 ${existing ? 'border-green-700/50 text-green-400 hover:bg-green-900/20' : 'bg-amber-500/15 border-amber-500/40 text-amber-500 hover:bg-amber-500/25 hover:border-amber-500/60'}" ${remapAttr}>
                  ${existing ? 'Edit remap' : 'Remap'}
                </button>
              </div>`;
            }).join('')}
          </div>
        ` : '';

        // Group episode warnings by series_name to avoid N identical rows for the same show.
        // Series-level warnings for the same show are merged in (to carry their GUIDs) rather
        // than rendered as a separate row. Matched state is read directly from warning entries,
        // with a fallback to matchedShowMap for warnings created before auto-stamping existed.
        type GroupEntry = {count: number, reason: string, plex_guids: string[], matched: boolean, matched_tvdb_id?: number, matched_show_id?: number, matched_show_title?: string};
        const groupedEpisodeWarnings: Map<string, GroupEntry> = new Map();
        const standaloneUnmatched: any[] = [];
        for (const w of unmatchedWarnings) {
          if (w.media_type === 'episode' && w.series_name) {
            // Always overlay DB state — it reflects the current show linkage regardless of stamp age
            const dbMatch = matchedShowMap.get((w.series_name ?? '').toLowerCase());
            const isMatched = !!w.matched || !!dbMatch;
            const existing = groupedEpisodeWarnings.get(w.series_name);
            if (existing) {
              existing.count++;
              if (isMatched) {
                existing.matched = true;
                // Prefer tvdb_id: DB > stamp (stamps from old `already_linked` runs may have null tvdb_id)
                existing.matched_tvdb_id = dbMatch?.tvdb_id ?? w.matched_tvdb_id ?? existing.matched_tvdb_id;
                existing.matched_show_id = dbMatch?.show_id ?? w.matched_show_id ?? existing.matched_show_id;
                existing.matched_show_title = dbMatch?.show_title_matched ?? w.matched_show_title ?? existing.matched_show_title;
              }
            } else {
              groupedEpisodeWarnings.set(w.series_name, {
                count: 1,
                reason: w.reason ?? 'unknown reason',
                plex_guids: w.plex_guids ?? [],
                matched: isMatched,
                matched_tvdb_id: dbMatch?.tvdb_id ?? w.matched_tvdb_id,
                matched_show_id: dbMatch?.show_id ?? w.matched_show_id,
                matched_show_title: dbMatch?.show_title_matched ?? w.matched_show_title,
              });
            }
          } else {
            standaloneUnmatched.push(w);
          }
        }

        // Merge series-level standalone warnings into grouped episode entries where the title
        // matches, absorbing their GUIDs. Suppress the standalone row to avoid duplication.
        // Also apply matchedShowMap overlay to standalone series-level warnings.
        const trueStandaloneUnmatched = standaloneUnmatched.filter((w: any) => {
          const grouped = groupedEpisodeWarnings.get(w.title);
          if (grouped) {
            if (w.plex_guids?.length && !grouped.plex_guids.length) {
              grouped.plex_guids = w.plex_guids;
            }
            return false; // suppress — already shown in grouped section
          }
          // Apply matchedShowMap overlay for series-type standalone warnings
          if (!w.matched && (w.media_type === 'series' || w.media_type === 'episode')) {
            const dbMatch = matchedShowMap.get((w.title ?? '').toLowerCase());
            if (dbMatch) {
              w.matched = true;
              w.matched_tvdb_id = dbMatch.tvdb_id;
              w.matched_show_id = dbMatch.show_id;
              w.matched_show_title = dbMatch.show_title_matched;
            }
          }
          return true;
        });

        const hasUnmatched = groupedEpisodeWarnings.size > 0 || trueStandaloneUnmatched.length > 0;
        const displayCount = enrichmentWarnings.length + groupedEpisodeWarnings.size + trueStandaloneUnmatched.length;
        const renderUnmatched = hasUnmatched ? `
          <div class="space-y-1 ${enrichmentWarnings.length > 0 ? 'mt-4 pt-4 border-t border-zinc-800/60' : ''}">
            <p class="text-xs text-zinc-500 mb-2">Items that couldn't be matched to TMDB:</p>
            ${[...groupedEpisodeWarnings.entries()].map(([seriesName, {count, reason, plex_guids, matched, matched_tvdb_id, matched_show_id, matched_show_title}]) => {
              const isMatched = matched;
              const matchedTitle = matched_show_title ?? '';
              const matchHref = matched_tvdb_id ? `/show/tvdb/${matched_tvdb_id}` : (matched_show_id ? `/show/${matched_show_id}` : '');
              return `
              <div class="flex items-center gap-3 py-1.5 border-b border-zinc-800/60 last:border-0">
                <div class="flex-1 min-w-0">
                  <span class="text-sm text-zinc-200 font-medium">${escapeHtml(seriesName)}</span>
                  <span class="ml-2 text-xs text-zinc-600">${count} episode${count !== 1 ? 's' : ''}</span>
                  ${isMatched
                    ? `<span class="ml-2 text-xs text-green-500">→ matched${matchedTitle && matchedTitle.toLowerCase() !== seriesName.toLowerCase() ? ` as "${escapeHtml(matchedTitle)}"` : ''}</span>`
                    : `<p class="text-xs text-zinc-500 mt-0.5">${escapeHtml(reason)}</p>`
                  }
                  ${plex_guids.length ? `<p class="text-xs text-zinc-600 font-mono mt-0.5">${plex_guids.map((g: string) => escapeHtml(g)).join(' · ')}</p>` : ''}
                </div>
                <div class="flex items-center gap-1.5 shrink-0">
                  ${isMatched && matchHref ? `<a href="${escapeHtml(matchHref)}" class="text-xs px-2.5 py-1 rounded-lg border border-green-700/40 text-green-400 hover:bg-green-900/20 transition-colors">View</a>` : ''}
                  ${isMatched
                    ? `<button type="button" class="unmatch-show-btn text-xs px-2.5 py-1 rounded-lg border border-zinc-700 text-zinc-400 hover:bg-zinc-800 cursor-pointer transition-colors"
                        data-series-name="${escapeHtml(seriesName)}">Unmatch</button>`
                    : `<button type="button" class="match-show-btn text-xs px-2.5 py-1 rounded-lg border bg-amber-500/15 border-amber-500/40 text-amber-500 hover:bg-amber-500/25 hover:border-amber-500/60 cursor-pointer transition-colors"
                        data-series-name="${escapeHtml(seriesName)}">Match</button>`
                  }
                </div>
              </div>`;
            }).join('')}
            ${trueStandaloneUnmatched.map((w: any) => {
              const wMatched = !!w.matched;
              const wMatchedTitle = w.matched_movie_title ?? w.matched_show_title ?? '';
              const wMatchHref = w.media_type === 'movie' && w.matched_tmdb_id
                ? `/movie/${w.matched_tmdb_id}`
                : (w.matched_tvdb_id ? `/show/tvdb/${w.matched_tvdb_id}` : (w.matched_show_id ? `/show/${w.matched_show_id}` : ''));
              return `
              <div class="flex items-center gap-3 py-1.5 border-b border-zinc-800/60 last:border-0">
                <div class="flex-1 min-w-0">
                  <span class="text-sm text-zinc-200 font-medium">${escapeHtml(w.title)}</span>
                  ${w.media_type ? `<span class="ml-2 text-xs text-zinc-600">${escapeHtml(w.media_type)}</span>` : ''}
                  ${wMatched
                    ? `<span class="ml-2 text-xs text-green-500">→ matched${wMatchedTitle && wMatchedTitle.toLowerCase() !== (w.title ?? '').toLowerCase() ? ` as "${escapeHtml(wMatchedTitle)}"` : ''}</span>`
                    : `<p class="text-xs text-zinc-500 mt-0.5">${escapeHtml(w.reason ?? 'unknown reason')}</p>`
                  }
                  ${w.plex_guids?.length ? `<p class="text-xs text-zinc-600 font-mono mt-0.5">${w.plex_guids.map((g: string) => escapeHtml(g)).join(' · ')}</p>` : ''}
                </div>
                <div class="flex items-center gap-1.5 shrink-0">
                  ${wMatched && wMatchHref ? `<a href="${escapeHtml(wMatchHref)}" class="text-xs px-2.5 py-1 rounded-lg border border-green-700/40 text-green-400 hover:bg-green-900/20 transition-colors">View</a>` : ''}
                  ${wMatched
                    ? `<button type="button" class="unmatch-show-btn text-xs px-2.5 py-1 rounded-lg border border-zinc-700 text-zinc-400 hover:bg-zinc-800 cursor-pointer transition-colors"
                        data-series-name="${escapeHtml(w.title)}" data-media-type="${escapeHtml(w.media_type ?? '')}">Unmatch</button>`
                    : `<button type="button" class="match-show-btn text-xs px-2.5 py-1 rounded-lg border bg-amber-500/15 border-amber-500/40 text-amber-500 hover:bg-amber-500/25 hover:border-amber-500/60 cursor-pointer transition-colors shrink-0"
                        data-series-name="${escapeHtml(w.title)}" data-media-type="${escapeHtml(w.media_type ?? '')}">Match</button>`
                  }
                </div>
              </div>`;
            }).join('')}
          </div>
        ` : '';

        container.classList.remove('hidden');
        container.innerHTML = `
          <div class="rounded-xl border border-amber-500/20 bg-amber-500/5 overflow-hidden">
            <button
              type="button"
              class="w-full flex items-center justify-between px-4 py-3 text-left hover:bg-amber-500/10 transition-colors cursor-pointer"
              onclick="const d=document.getElementById('${detailsId}');const c=this.querySelector('.warn-chevron');d.classList.toggle('hidden');c.classList.toggle('rotate-180');"
            >
              <div class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-400 shrink-0"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
                <span class="text-xs font-semibold uppercase tracking-wider text-amber-400">${displayCount} item${displayCount > 1 ? 's' : ''} couldn't be fully synced</span>
                <span class="text-xs text-zinc-500">· ${escapeHtml(date)}</span>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="warn-chevron w-4 h-4 text-amber-500/60 transition-transform shrink-0">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </button>
            <div id="${detailsId}" class="hidden border-t border-amber-500/15 px-4 py-3">
              ${renderEnrichment}
              ${renderUnmatched}
            </div>
          </div>
        `;

        // Restore expanded state if this pane was open before the rebuild
        if (expandedDetails.has(detailsId)) {
          document.getElementById(detailsId)?.classList.remove('hidden');
          container.querySelector('.warn-chevron')?.classList.add('rotate-180');
        }

        container.querySelectorAll('.remap-season-btn').forEach((btn) => {
          btn.addEventListener('click', () => {
            const el = btn as HTMLElement;
            (window as any).openRemapModal(
              parseInt(el.dataset.srcTmdb ?? '0'),
              parseInt(el.dataset.srcSeason ?? '0'),
              el.dataset.srcTitle ?? '',
            );
          });
        });

        container.querySelectorAll('.match-show-btn').forEach((btn) => {
          btn.addEventListener('click', () => {
            const el = btn as HTMLElement;
            const mediaType = el.dataset.mediaType ?? '';
            if (mediaType === 'movie') {
              (window as any).openMatchMovieModal(el.dataset.seriesName ?? '');
            } else {
              (window as any).openMatchModal(el.dataset.seriesName ?? '');
            }
          });
        });

        container.querySelectorAll('.unmatch-show-btn').forEach((btn) => {
          btn.addEventListener('click', async () => {
            const el = btn as HTMLButtonElement;
            const seriesName = el.dataset.seriesName ?? '';
            const mediaType = el.dataset.mediaType ?? '';
            if (!seriesName) return;
            el.disabled = true;
            el.textContent = 'Removing…';
            try {
              const isMovie = mediaType === 'movie';
              const res = await fetch(`/api/proxy/sync/${isMovie ? 'unmatch-movie' : 'unmatch-show'}`, {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
                body: JSON.stringify(isMovie ? { movie_title: seriesName } : { show_title: seriesName }),
              });
              if (!res.ok) throw new Error(await res.text());
              loadSyncWarnings();
            } catch (e: any) {
              el.disabled = false;
              el.textContent = 'Unmatch';
              alert(`Failed to unmatch: ${e.message ?? 'Unknown error'}`);
            }
          });
        });
      });

      // Wire up static (SSR-rendered) season remap rows in the active remaps panel
      document.querySelectorAll<HTMLElement>('#season-remaps-list .remap-season-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          (window as any).openRemapModal(
            parseInt(btn.dataset.srcTmdb ?? '0'),
            parseInt(btn.dataset.srcSeason ?? '0'),
            btn.dataset.srcTitle ?? '',
          );
        });
      });
      document.querySelectorAll<HTMLButtonElement>('#season-remaps-list .delete-override-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const overrideId = btn.dataset.overrideId;
          if (!overrideId || !confirm('Remove this season remap?')) return;
          btn.disabled = true;
          btn.textContent = 'Removing…';
          try {
            const res = await fetch(`/api/proxy/sync/season-overrides/${overrideId}`, {
              method: 'DELETE',
              headers: { 'Authorization': `Bearer ${token}` },
            });
            if (res.ok) {
              btn.closest('[data-override-id]')?.remove();
              const list = document.getElementById('season-remaps-list');
              if (list && list.children.length === 0) {
                document.getElementById('season-remaps-panel')?.remove();
              }
            } else {
              btn.disabled = false;
              btn.textContent = 'Remove';
            }
          } catch (_) {
            btn.disabled = false;
            btn.textContent = 'Remove';
          }
        });
      });
    } catch (_) { /* non-critical */ }
  }

  // ── Season remap modal ────────────────────────────────────────────────────

  function setupSeasonRemap() {
    const appData = document.getElementById('app-data') as HTMLElement | null;
    const token = appData?.dataset.token ?? '';
    const modal = document.getElementById('season-remap-modal') as HTMLElement;
    if (!modal) return;

    let srcTmdbId = 0;
    let srcSeason = 0;
    let targetTmdbId = 0;
    let targetTvdbId = 0;
    let targetSeasonNumber = 0;
    let modalMode: 'remap' | 'match' | 'match-movie' = 'remap';
    let matchSeriesName = '';
    let matchMovieTitle = '';

    const closeModal = () => {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      (document.getElementById('remap-search-input') as HTMLInputElement).value = '';
      (document.getElementById('remap-tvdb-input') as HTMLInputElement).value = '';
      (document.getElementById('remap-search-results') as HTMLElement).innerHTML = '';
      (document.getElementById('remap-tvdb-results') as HTMLElement).innerHTML = '';
      (document.getElementById('remap-seasons-list') as HTMLElement).innerHTML = '';
      (document.getElementById('remap-selected-area') as HTMLElement).classList.add('hidden');
      (document.getElementById('match-tab-bar') as HTMLElement).classList.add('hidden');
      (document.getElementById('remap-save') as HTMLButtonElement).disabled = true;
      (document.getElementById('remap-error') as HTMLElement).classList.add('hidden');
      targetTmdbId = 0;
      targetTvdbId = 0;
      targetSeasonNumber = 0;
      modalMode = 'remap';
      matchSeriesName = '';
      matchMovieTitle = '';
    };

    const setMatchTab = (tab: 'tvdb' | 'tmdb') => {
      const tvdbBtn = document.getElementById('match-tab-tvdb') as HTMLElement;
      const tmdbBtn = document.getElementById('match-tab-tmdb') as HTMLElement;
      const tvdbSection = document.getElementById('remap-tvdb-section') as HTMLElement;
      const tmdbSection = document.getElementById('remap-tmdb-section') as HTMLElement;
      const selectedArea = document.getElementById('remap-selected-area') as HTMLElement;
      const saveBtn = document.getElementById('remap-save') as HTMLButtonElement;
      // Reset selection
      selectedArea.classList.add('hidden');
      saveBtn.disabled = true;
      targetTmdbId = 0;
      targetTvdbId = 0;
      if (tab === 'tvdb') {
        tvdbBtn.className = 'flex-1 px-3 py-1.5 text-sm font-medium rounded-lg transition-colors cursor-pointer bg-zinc-800 text-zinc-100';
        tmdbBtn.className = 'flex-1 px-3 py-1.5 text-sm font-medium rounded-lg transition-colors cursor-pointer text-zinc-400 hover:text-zinc-200';
        tvdbSection.classList.remove('hidden');
        tmdbSection.classList.add('hidden');
        (document.getElementById('remap-tvdb-results') as HTMLElement).innerHTML = '';
        const tvdbInput = document.getElementById('remap-tvdb-input') as HTMLInputElement;
        tvdbInput.focus();
        if (tvdbInput.value.trim()) doTvdbSearch();
      } else {
        tmdbBtn.className = 'flex-1 px-3 py-1.5 text-sm font-medium rounded-lg transition-colors cursor-pointer bg-zinc-800 text-zinc-100';
        tvdbBtn.className = 'flex-1 px-3 py-1.5 text-sm font-medium rounded-lg transition-colors cursor-pointer text-zinc-400 hover:text-zinc-200';
        tmdbSection.classList.remove('hidden');
        tvdbSection.classList.add('hidden');
        (document.getElementById('remap-search-results') as HTMLElement).innerHTML = '';
        const tmdbInput = document.getElementById('remap-search-input') as HTMLInputElement;
        tmdbInput.focus();
        if (tmdbInput.value.trim()) doSearch();
      }
    };

    document.getElementById('match-tab-tvdb')?.addEventListener('click', () => setMatchTab('tvdb'));
    document.getElementById('match-tab-tmdb')?.addEventListener('click', () => setMatchTab('tmdb'));

    document.getElementById('remap-close')?.addEventListener('click', closeModal);
    document.getElementById('remap-cancel')?.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });

    document.getElementById('remap-clear-selection')?.addEventListener('click', () => {
      (document.getElementById('remap-selected-area') as HTMLElement).classList.add('hidden');
      (document.getElementById('remap-seasons-list') as HTMLElement).innerHTML = '';
      (document.getElementById('remap-save') as HTMLButtonElement).disabled = true;
      targetTmdbId = 0;
      targetTvdbId = 0;
      targetSeasonNumber = 0;
    });

    const searchInput = document.getElementById('remap-search-input') as HTMLInputElement;
    const searchBtn = document.getElementById('remap-search-btn') as HTMLButtonElement;

    const renderSearchResult = (r: any, resultsEl: HTMLElement) => {
      resultsEl.innerHTML = '';
      const year = String(r.first_air_date ?? r.release_date ?? '').slice(0, 4);
      resultsEl.innerHTML = `
        <button type="button" class="remap-result w-full flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-zinc-800 transition-colors cursor-pointer text-left"
          data-tmdb="${r.tmdb_id}" data-title="${escapeHtml(r.title ?? '')}" data-year="${escapeHtml(year)}" data-poster="${escapeHtml(r.poster_path ?? '')}">
          <img src="${escapeHtml(r.poster_path ?? '')}" alt="" class="w-8 h-11 object-cover rounded bg-zinc-700 shrink-0" onerror="this.style.display='none'" />
          <div class="flex-1 min-w-0">
            <p class="text-sm text-zinc-100 truncate">${escapeHtml(r.title ?? '')}</p>
            <p class="text-xs text-zinc-500">${escapeHtml(year)}</p>
          </div>
        </button>`;
      resultsEl.querySelectorAll('.remap-result').forEach(btn => wireResultClick(btn as HTMLElement));
    };

    const wireResultClick = (btn: HTMLElement) => {
      btn.addEventListener('click', async () => {
        const tmdbId = parseInt(btn.dataset.tmdb ?? '0');
        const tvdbId = parseInt(btn.dataset.tvdb ?? '0');
        if (tvdbId) {
          targetTvdbId = tvdbId;
          targetTmdbId = 0;
        } else {
          targetTmdbId = tmdbId;
          targetTvdbId = 0;
        }
        targetSeasonNumber = 0;
        (document.getElementById('remap-selected-poster') as HTMLImageElement).src = btn.dataset.poster ?? '';
        (document.getElementById('remap-selected-title') as HTMLElement).textContent = btn.dataset.title ?? '';
        (document.getElementById('remap-selected-year') as HTMLElement).textContent = btn.dataset.year ?? '';
        (document.getElementById('remap-selected-area') as HTMLElement).classList.remove('hidden');
        (document.getElementById('remap-search-results') as HTMLElement).innerHTML = '';
        (document.getElementById('remap-tvdb-results') as HTMLElement).innerHTML = '';
        searchInput.value = '';

        const saveBtn = document.getElementById('remap-save') as HTMLButtonElement;
        const seasonsArea = document.getElementById('remap-seasons-area') as HTMLElement;

        if (modalMode === 'match' || modalMode === 'match-movie') {
          // No season selection needed for show/movie matching — enable save immediately
          seasonsArea.classList.add('hidden');
          saveBtn.disabled = false;
          return;
        }

        // Remap mode: fetch and render season list
        saveBtn.disabled = true;
        seasonsArea.classList.remove('hidden');
        const seasonsList = document.getElementById('remap-seasons-list') as HTMLElement;
        const seasonsLoading = document.getElementById('remap-seasons-loading') as HTMLElement;
        seasonsList.innerHTML = '';
        seasonsLoading.classList.remove('hidden');
        try {
          const showRes = await fetch(`/api/proxy/shows/${tmdbId}`, {
            headers: { 'Authorization': `Bearer ${token}` },
          });
          const showData = showRes.ok ? await showRes.json() : null;
          const seasons: any[] = (showData?.seasons_meta ?? []).filter((s: any) => s.season_number > 0);
          seasonsLoading.classList.add('hidden');
          if (!seasons.length) {
            seasonsList.innerHTML = '<p class="text-xs text-zinc-500 py-1">No seasons found.</p>';
            return;
          }
          seasons.forEach((s: any) => {
            const seasonBtn = document.createElement('button');
            seasonBtn.type = 'button';
            seasonBtn.className = 'remap-season-pick w-full flex items-center gap-3 px-3 py-2 rounded-lg border border-transparent hover:border-blue-600/50 hover:bg-blue-600/10 transition-colors cursor-pointer text-left';
            seasonBtn.dataset.season = String(s.season_number);
            seasonBtn.innerHTML = `
              <img src="${escapeHtml(s.poster_path ?? '')}" alt="" class="w-8 h-11 object-cover rounded bg-zinc-700 shrink-0" onerror="this.style.display='none'" />
              <div class="flex-1 min-w-0">
                <p class="text-sm text-zinc-100">${escapeHtml(s.name ?? `Season ${s.season_number}`)}</p>
                <p class="text-xs text-zinc-500">Season ${s.season_number}${s.episode_count ? ` · ${s.episode_count} eps` : ''}</p>
              </div>`;
            seasonBtn.addEventListener('click', () => {
              targetSeasonNumber = s.season_number;
              seasonsList.querySelectorAll('.remap-season-pick').forEach(b => {
                b.classList.remove('border-blue-600/50', 'bg-blue-600/10');
                b.classList.add('border-transparent');
              });
              seasonBtn.classList.add('border-blue-600/50', 'bg-blue-600/10');
              seasonBtn.classList.remove('border-transparent');
              saveBtn.disabled = false;
            });
            seasonsList.appendChild(seasonBtn);
          });
        } catch (_) {
          seasonsLoading.classList.add('hidden');
          seasonsList.innerHTML = '<p class="text-xs text-red-400 py-1">Could not load seasons.</p>';
        }
      });
    };

    const doSearch = async () => {
      const q = searchInput.value.trim();
      if (!q) return;
      const resultsEl = document.getElementById('remap-search-results') as HTMLElement;
      resultsEl.innerHTML = '<p class="text-xs text-zinc-500 py-2">Searching…</p>';
      try {
        const searchType = modalMode === 'match-movie' ? 'movie' : 'series';
        const res = await fetch(`/api/proxy/media/search?q=${encodeURIComponent(q)}&type=${searchType}`, {
          headers: { 'Authorization': `Bearer ${token}` },
        });
        if (!res.ok) throw new Error('Search failed');
        const data = await res.json();
        const results: any[] = data.results?.slice(0, 8) ?? [];
        if (!results.length) {
          resultsEl.innerHTML = '<p class="text-xs text-zinc-500 py-2">No results.</p>';
          return;
        }
        resultsEl.innerHTML = results.map((r: any) => {
          const year = escapeHtml(String(r.release_date ?? r.first_air_date ?? '').slice(0, 4));
          return `
          <button type="button" class="remap-result w-full flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-zinc-800 transition-colors cursor-pointer text-left"
            data-tmdb="${r.tmdb_id}" data-title="${escapeHtml(r.title ?? '')}" data-year="${year}" data-poster="${escapeHtml(r.poster_path ?? '')}">
            <img src="${escapeHtml(r.poster_path ?? '')}" alt="" class="w-8 h-11 object-cover rounded bg-zinc-700 shrink-0" onerror="this.style.display='none'" />
            <div class="flex-1 min-w-0">
              <p class="text-sm text-zinc-100 truncate">${escapeHtml(r.title ?? '')}</p>
              <p class="text-xs text-zinc-500">${year}</p>
            </div>
          </button>`;
        }).join('');
        resultsEl.querySelectorAll('.remap-result').forEach(btn => wireResultClick(btn as HTMLElement));
      } catch (_) {
        resultsEl.innerHTML = '<p class="text-xs text-red-400 py-2">Search failed.</p>';
      }
    };

    const doTvdbSearch = async () => {
      const q = (document.getElementById('remap-tvdb-input') as HTMLInputElement).value.trim();
      if (!q) return;
      const resultsEl = document.getElementById('remap-tvdb-results') as HTMLElement;
      resultsEl.innerHTML = '<p class="text-xs text-zinc-500 py-2">Searching…</p>';
      try {
        const res = await fetch(`/api/proxy/media/search-tvdb?q=${encodeURIComponent(q)}`, {
          headers: { 'Authorization': `Bearer ${token}` },
        });
        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          const detail: string = err.detail ?? 'Search failed';
          if (detail.toLowerCase().includes('api key')) {
            resultsEl.innerHTML = `<div class="py-2 space-y-1">
              <p class="text-xs text-amber-400">A TVDB API key is required to search. Set one in <a href="/settings" class="underline hover:text-amber-300">Settings</a> or ask your admin to configure a global key.</p>
            </div>`;
          } else {
            resultsEl.innerHTML = `<p class="text-xs text-red-400 py-2">${escapeHtml(detail)}</p>`;
          }
          return;
        }
        const results: any[] = await res.json();
        if (!results.length) {
          resultsEl.innerHTML = '<p class="text-xs text-zinc-500 py-2">No results found on TVDB.</p>';
          return;
        }
        resultsEl.innerHTML = results.slice(0, 8).map((r: any) => `
          <button type="button" class="remap-result w-full flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-zinc-800 transition-colors cursor-pointer text-left"
            data-tvdb="${r.tvdb_id}" data-title="${escapeHtml(r.title ?? '')}" data-year="${escapeHtml(String(r.year ?? ''))}" data-poster="${escapeHtml(r.image_url ?? '')}">
            <img src="${escapeHtml(r.image_url ?? '')}" alt="" class="w-8 h-11 object-cover rounded bg-zinc-700 shrink-0" onerror="this.style.display='none'" />
            <div class="flex-1 min-w-0">
              <p class="text-sm text-zinc-100 truncate">${escapeHtml(r.title ?? '')}</p>
              <p class="text-xs text-zinc-500">${escapeHtml(String(r.year ?? ''))}${r.network ? ` · ${escapeHtml(r.network)}` : ''}</p>
            </div>
          </button>`).join('');
        resultsEl.querySelectorAll('.remap-result').forEach(btn => wireResultClick(btn as HTMLElement));
      } catch (e: any) {
        resultsEl.innerHTML = `<p class="text-xs text-red-400 py-2">Search failed: ${escapeHtml(e.message ?? '')}</p>`;
      }
    };

    searchBtn.addEventListener('click', doSearch);
    searchInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') doSearch(); });
    document.getElementById('remap-tvdb-search-btn')?.addEventListener('click', doTvdbSearch);
    (document.getElementById('remap-tvdb-input') as HTMLInputElement)?.addEventListener('keydown', (e) => { if (e.key === 'Enter') doTvdbSearch(); });

    document.getElementById('remap-save')?.addEventListener('click', async () => {
      const saveBtn = document.getElementById('remap-save') as HTMLButtonElement;
      const errEl = document.getElementById('remap-error') as HTMLElement;
      errEl.classList.add('hidden');
      saveBtn.disabled = true;

      if (modalMode === 'match') {
        if (!targetTvdbId && !targetTmdbId) return;
        saveBtn.textContent = 'Matching…';
        try {
          const body: any = { show_title: matchSeriesName };
          if (targetTvdbId) body.tvdb_id = targetTvdbId;
          else body.tmdb_id = targetTmdbId;
          const res = await fetch('/api/proxy/sync/match-unmatched-show', {
            method: 'POST',
            headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });
          if (!res.ok) throw new Error(await res.text());
          closeModal();
          loadSyncWarnings();
        } catch (e: any) {
          errEl.textContent = `Error: ${e.message ?? 'Unknown error'}`;
          errEl.classList.remove('hidden');
          saveBtn.disabled = false;
          saveBtn.textContent = 'Match & Apply';
        }
        return;
      }

      if (modalMode === 'match-movie') {
        if (!targetTmdbId) return;
        saveBtn.textContent = 'Matching…';
        try {
          const res = await fetch('/api/proxy/sync/match-unmatched-movie', {
            method: 'POST',
            headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
            body: JSON.stringify({ movie_title: matchMovieTitle, tmdb_id: targetTmdbId }),
          });
          if (!res.ok) throw new Error(await res.text());
          closeModal();
          loadSyncWarnings();
        } catch (e: any) {
          errEl.textContent = `Error: ${e.message ?? 'Unknown error'}`;
          errEl.classList.remove('hidden');
          saveBtn.disabled = false;
          saveBtn.textContent = 'Match & Apply';
        }
        return;
      }

      // Remap mode
      if (!targetTmdbId || !targetSeasonNumber) return;
      saveBtn.textContent = 'Saving…';
      try {
        const createRes = await fetch('/api/proxy/sync/season-overrides', {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({
            source_show_tmdb_id: srcTmdbId,
            source_season_number: srcSeason,
            target_show_tmdb_id: targetTmdbId,
            target_season_number: targetSeasonNumber,
          }),
        });
        if (!createRes.ok) throw new Error(await createRes.text());
        const override = await createRes.json();

        saveBtn.textContent = 'Applying…';
        const applyRes = await fetch(`/api/proxy/sync/season-overrides/${override.id}/apply`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}` },
        });
        if (!applyRes.ok) throw new Error(await applyRes.text());

        closeModal();
        loadSyncWarnings();
      } catch (e: any) {
        errEl.textContent = `Error: ${e.message ?? 'Unknown error'}`;
        errEl.classList.remove('hidden');
        saveBtn.disabled = false;
        saveBtn.textContent = 'Save & Apply';
      }
    });

    (window as any).openRemapModal = (tmdbId: number, season: number, title: string) => {
      modalMode = 'remap';
      srcTmdbId = tmdbId;
      srcSeason = season;
      (document.getElementById('remap-modal-title') as HTMLElement).textContent = 'Remap Season';
      (document.getElementById('remap-source-label') as HTMLElement).textContent = `"${title}" — Season ${season}`;
      (document.getElementById('remap-tmdb-label') as HTMLElement).textContent = 'Search for the correct TMDB show';
      (document.getElementById('remap-tmdb-section') as HTMLElement).classList.remove('hidden');
      (document.getElementById('remap-tvdb-section') as HTMLElement).classList.add('hidden');
      (document.getElementById('remap-seasons-area') as HTMLElement).classList.remove('hidden');
      (document.getElementById('remap-save') as HTMLButtonElement).textContent = 'Save & Apply';
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      searchInput.focus();
    };

    (window as any).openMatchModal = (seriesName: string) => {
      modalMode = 'match';
      matchSeriesName = seriesName;
      (document.getElementById('remap-modal-title') as HTMLElement).textContent = 'Match Show';
      (document.getElementById('remap-source-label') as HTMLElement).textContent = `"${seriesName}"`;
      (document.getElementById('remap-seasons-area') as HTMLElement).classList.add('hidden');
      (document.getElementById('remap-save') as HTMLButtonElement).textContent = 'Match & Apply';
      (document.getElementById('remap-tmdb-label') as HTMLElement).textContent = 'Search for the correct TMDB show';
      (document.getElementById('match-tab-bar') as HTMLElement).classList.remove('hidden');
      const tvdbInput = document.getElementById('remap-tvdb-input') as HTMLInputElement;
      tvdbInput.value = seriesName;
      (document.getElementById('remap-search-input') as HTMLInputElement).value = seriesName;
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      // Default to TVDB tab and auto-search
      setMatchTab('tvdb');
      doTvdbSearch();
    };

    (window as any).openMatchMovieModal = (movieTitle: string) => {
      modalMode = 'match-movie';
      matchMovieTitle = movieTitle;
      (document.getElementById('remap-modal-title') as HTMLElement).textContent = 'Match Movie on TMDB';
      (document.getElementById('remap-source-label') as HTMLElement).textContent = `"${movieTitle}"`;
      (document.getElementById('remap-tmdb-label') as HTMLElement).textContent = 'Search for the correct TMDB movie';
      (document.getElementById('remap-tmdb-section') as HTMLElement).classList.remove('hidden');
      (document.getElementById('remap-tvdb-section') as HTMLElement).classList.add('hidden');
      (document.getElementById('remap-seasons-area') as HTMLElement).classList.add('hidden');
      (document.getElementById('remap-save') as HTMLButtonElement).textContent = 'Match & Apply';
      searchInput.value = movieTitle;
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      searchInput.focus();
      // Auto-search immediately so results appear right away
      doSearch();
    };
  }
</script>

<script>
  import QRCode from 'qrcode';

  const appData = document.getElementById('app-data') as HTMLElement | null;
  const token: string = appData?.dataset.token ?? '';

  let pendingTotpSecret = '';

  function show2faSetupError(msg: string) {
    const el = document.getElementById('2fa-setup-error');
    if (!el) return;
    el.textContent = msg;
    el.classList.remove('hidden');
  }

  function hide2faSetupError() {
    document.getElementById('2fa-setup-error')?.classList.add('hidden');
  }

  function show2faDisableError(msg: string) {
    const el = document.getElementById('2fa-disable-error');
    if (!el) return;
    el.textContent = msg;
    el.classList.remove('hidden');
  }

  function setup2fa() {
    // Enable flow
    const enableBtn = document.getElementById('enable-2fa-btn');
    const setupPanel = document.getElementById('2fa-setup-panel');
    const cancelSetupBtn = document.getElementById('cancel-2fa-setup-btn');
    const confirmEnableBtn = document.getElementById('confirm-enable-2fa-btn') as HTMLButtonElement | null;
    const verifyInput = document.getElementById('totp-verify-code') as HTMLInputElement | null;
    const secretDisplay = document.getElementById('totp-secret-display');
    const qrCanvas = document.getElementById('totp-qr-canvas') as HTMLCanvasElement | null;
    const newCodesPanel = document.getElementById('2fa-new-codes-panel');
    const newCodesGrid = document.getElementById('2fa-new-codes-grid');
    const newCodesDoneBtn = document.getElementById('2fa-new-codes-done-btn');

    enableBtn?.addEventListener('click', async () => {
      enableBtn.textContent = 'Loading...';
      (enableBtn as HTMLButtonElement).disabled = true;
      hide2faSetupError();

      try {
        const res = await fetch(`/api/proxy/auth/2fa/setup`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}` },
        });
        if (!res.ok) {
          const data = await res.json();
          throw new Error(data.detail || 'Failed to start 2FA setup');
        }
        const data = await res.json() as { provisioning_uri: string; secret: string };
        pendingTotpSecret = data.secret;

        if (secretDisplay) secretDisplay.textContent = data.secret;

        if (qrCanvas) {
          await QRCode.toCanvas(qrCanvas, data.provisioning_uri, {
            width: 160,
            margin: 1,
            color: { dark: '#000000', light: '#ffffff' },
          });
        }

        setupPanel?.classList.remove('hidden');
      } catch (e: unknown) {
        show2faSetupError(e instanceof Error ? e.message : 'Setup failed');
      } finally {
        enableBtn.textContent = 'Enable 2FA';
        (enableBtn as HTMLButtonElement).disabled = false;
      }
    });

    cancelSetupBtn?.addEventListener('click', () => {
      setupPanel?.classList.add('hidden');
      pendingTotpSecret = '';
      hide2faSetupError();
      if (verifyInput) verifyInput.value = '';
    });

    confirmEnableBtn?.addEventListener('click', async () => {
      const code = verifyInput?.value.trim() ?? '';
      if (!code || !pendingTotpSecret) return;

      confirmEnableBtn.disabled = true;
      const orig = confirmEnableBtn.textContent;
      confirmEnableBtn.textContent = 'Verifying...';
      hide2faSetupError();

      try {
        const res = await fetch(`/api/proxy/auth/2fa/enable`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ secret: pendingTotpSecret, code }),
        });
        if (!res.ok) {
          const data = await res.json();
          throw new Error(data.detail || 'Invalid code');
        }
        const data = await res.json() as { codes: { id: number; code: string; used: boolean }[] };

        setupPanel?.classList.add('hidden');

        if (newCodesGrid) {
          newCodesGrid.innerHTML = data.codes
            .map(bc => `<span class="font-mono text-sm px-3 py-1.5 rounded-lg border border-zinc-700 bg-zinc-900 text-zinc-300">${escapeHtml(bc.code)}</span>`)
            .join('');
        }
        newCodesPanel?.classList.remove('hidden');
      } catch (e: unknown) {
        show2faSetupError(e instanceof Error ? e.message : 'Failed to enable 2FA');
      } finally {
        confirmEnableBtn.disabled = false;
        confirmEnableBtn.textContent = orig;
      }
    });

    newCodesDoneBtn?.addEventListener('click', () => {
      window.location.reload();
    });

    // Disable flow
    const disableBtn = document.getElementById('disable-2fa-btn');
    const disablePanel = document.getElementById('2fa-disable-panel');
    const cancelDisableBtn = document.getElementById('cancel-disable-2fa-btn');
    const confirmDisableBtn = document.getElementById('confirm-disable-2fa-btn') as HTMLButtonElement | null;
    const disableCodeInput = document.getElementById('totp-disable-code') as HTMLInputElement | null;

    disableBtn?.addEventListener('click', () => {
      disablePanel?.classList.remove('hidden');
      disableBtn.classList.add('hidden');
    });

    cancelDisableBtn?.addEventListener('click', () => {
      disablePanel?.classList.add('hidden');
      disableBtn?.classList.remove('hidden');
      if (disableCodeInput) disableCodeInput.value = '';
      document.getElementById('2fa-disable-error')?.classList.add('hidden');
    });

    confirmDisableBtn?.addEventListener('click', async () => {
      const code = disableCodeInput?.value.trim() ?? '';
      if (!code) return;

      confirmDisableBtn.disabled = true;
      const orig = confirmDisableBtn.textContent;
      confirmDisableBtn.textContent = 'Disabling...';
      document.getElementById('2fa-disable-error')?.classList.add('hidden');

      try {
        const res = await fetch(`/api/proxy/auth/2fa/disable`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ code }),
        });
        if (!res.ok) {
          const data = await res.json();
          throw new Error(data.detail || 'Failed to disable 2FA');
        }
        window.location.reload();
      } catch (e: unknown) {
        show2faDisableError(e instanceof Error ? e.message : 'Failed to disable 2FA');
        confirmDisableBtn.disabled = false;
        confirmDisableBtn.textContent = orig;
      }
    });
  }

  setup2fa();
  document.addEventListener('astro:after-swap', setup2fa);
</script>
