<script>
  const appData = document.getElementById('app-data');
  const token = appData?.dataset.token ?? '';

  function esc(s) {
    if (s == null) return '';
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function showMessage(text, type = 'success', opts: { scroll?: boolean } = {}) {
    const msg = document.getElementById('js-message');
    if (!msg) return;
    msg.textContent = text;
    msg.className = `p-4 rounded-lg mb-8 ${
      type === 'success'
        ? 'bg-green-500/10 border border-green-500 text-green-500'
        : 'bg-red-500/10 border border-red-500 text-red-500'
    }`;
    msg.classList.remove('hidden');
    // Skip the scroll for actions that already show their own progress bar
    // (pull/push/sync) — scrolling to top there just hides the progress the
    // user is meant to watch and forces them to scroll back down to see it.
    if (opts.scroll !== false) {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // Always hide after 4 seconds
    if (window._messageTimeout) clearTimeout(window._messageTimeout);
    window._messageTimeout = setTimeout(() => msg.classList.add('hidden'), 4000);
  }

  // ── Per-connection progress tracking ─────────────────────────────────────
  const connPollers = new Map<string, ReturnType<typeof setTimeout>>();

  function renderConnProgress(connId: string, job: any) {
    const strip = document.getElementById(`conn-progress-${connId}`);
    const bar   = document.getElementById(`conn-job-bar-${connId}`);
    const pctEl = document.getElementById(`conn-job-pct-${connId}`);
    const label = document.getElementById(`conn-job-label-${connId}`);
    const items = document.getElementById(`conn-job-items-${connId}`);
    const statusEl = document.getElementById(`conn-job-status-${connId}`);
    if (!strip) return;

    if (!job) { strip.classList.add('hidden'); return; }

    strip.classList.remove('hidden');

    const isPush = job.job_type === 'push';
    const isFailed = job.status === 'failed';
    const isCompleted = job.status === 'completed';
    const isPending = job.status === 'pending';

    if (isFailed) {
      if (bar) { bar.className = 'h-1.5 rounded-full transition-all duration-500 bg-red-500'; bar.style.width = '100%'; }
      if (label) label.textContent = isPush ? 'Push failed' : 'Pull failed';
      if (pctEl) pctEl.textContent = '';
      if (items) items.textContent = esc(job.error_message || 'Unknown error');
      if (statusEl) statusEl.textContent = '';
      return;
    }

    if (isCompleted) {
      if (bar) { bar.className = `h-1.5 rounded-full transition-all duration-500 ${isPush ? 'bg-amber-500' : 'bg-blue-600'}`; bar.style.width = '100%'; }
      if (label) label.textContent = isPush ? 'Push complete' : 'Pull complete';
      if (pctEl) pctEl.textContent = '100%';
      const s = job.stats;
      if (items) items.textContent = s ? `${s.succeeded ?? 0} ok, ${s.failed ?? 0} failed` : `${job.processed_items} items`;
      if (statusEl) statusEl.textContent = '';
      return;
    }

    // pending / running
    const pct = job.total_items > 0
      ? Math.min(100, Math.round((job.processed_items / job.total_items) * 100))
      : 0;
    const barColor = isPush ? 'bg-amber-500' : 'bg-blue-600';

    if (bar) {
      bar.className = `h-1.5 rounded-full transition-all duration-500 ${barColor}${isPending || job.total_items === 0 ? ' animate-pulse' : ''}`;
      bar.style.width = isPending || job.total_items === 0 ? '100%' : `${pct}%`;
    }
    if (label) label.textContent = isPush
      ? (isPending ? 'Push queued…' : 'Pushing…')
      : (isPending ? 'Pull queued…' : 'Pulling…');
    if (pctEl) pctEl.textContent = job.total_items > 0 ? `${pct}%` : '';
    if (items) items.textContent = job.total_items > 0
      ? `${job.processed_items} / ${job.total_items} items`
      : 'Loading…';
    if (statusEl) statusEl.textContent = '';
  }

  async function pollConnJob(connId: string) {
    try {
      const res = await fetch('/api/proxy/sync/status', {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (!res.ok) return;
      const jobs: any[] = await res.json();

      // Most-recent job for this connection
      const job = jobs.find(j => String(j.connection_id) === connId);

      const isActive = job && (job.status === 'pending' || job.status === 'running');
      const isRecentDone = job && (job.status === 'completed' || job.status === 'failed')
        && new Date(job.updated_at).getTime() > Date.now() - 8000;

      renderConnProgress(connId, (isActive || isRecentDone) ? job : null);

      if (isActive) {
        connPollers.set(connId, setTimeout(() => pollConnJob(connId), 2000));
      } else if (isRecentDone) {
        // Refresh warnings/last-synced now that the job finished
        loadSyncWarnings();
        loadLastSynced();
        // Show completion state briefly then hide
        connPollers.set(connId, setTimeout(() => {
          renderConnProgress(connId, null);
          connPollers.delete(connId);
        }, 4000));
      } else {
        connPollers.delete(connId);
      }
    } catch {
      connPollers.delete(connId);
    }
  }

  function startConnPoller(connId: string) {
    const existing = connPollers.get(connId);
    if (existing != null) clearTimeout(existing);
    pollConnJob(connId);
  }

  // ── Simkl progress tracking ───────────────────────────────────────────────
  let simklPoller: ReturnType<typeof setTimeout> | null = null;

  function renderSimklProgress(job: any) {
    const strip  = document.getElementById('simkl-progress');
    const bar    = document.getElementById('simkl-job-bar');
    const pctEl  = document.getElementById('simkl-job-pct');
    const label  = document.getElementById('simkl-job-label');
    const items  = document.getElementById('simkl-job-items');
    if (!strip) return;

    if (!job) { strip.classList.add('hidden'); return; }
    strip.classList.remove('hidden');

    const isPush     = job.job_type === 'push';
    const isFailed   = job.status === 'failed';
    const isCompleted = job.status === 'completed';
    const isPending  = job.status === 'pending';

    if (isFailed) {
      if (bar) { bar.className = 'h-1.5 rounded-full transition-all duration-500 bg-red-500'; bar.style.width = '100%'; }
      if (label) label.textContent = isPush ? 'Push failed' : 'Pull failed';
      if (pctEl) pctEl.textContent = '';
      if (items) items.textContent = esc(job.error_message || 'Unknown error');
      return;
    }

    if (isCompleted) {
      if (bar) { bar.className = `h-1.5 rounded-full transition-all duration-500 ${isPush ? 'bg-amber-500' : 'bg-blue-600'}`; bar.style.width = '100%'; }
      if (label) label.textContent = isPush ? 'Push complete' : 'Pull complete';
      if (pctEl) pctEl.textContent = '100%';
      const s = job.stats;
      if (items) items.textContent = s
        ? `${s.movies ?? 0} movies, ${s.episodes ?? 0} episodes, ${s.ratings ?? 0} ratings`
        : `${job.processed_items} items`;
      return;
    }

    const pct = job.total_items > 0 ? Math.min(100, Math.round((job.processed_items / job.total_items) * 100)) : 0;
    const barColor = isPush ? 'bg-amber-500' : 'bg-blue-600';
    const indeterminate = isPending || pct === 0;
    if (bar) {
      bar.className = `h-1.5 rounded-full transition-all duration-500 ${barColor}${indeterminate ? ' animate-pulse' : ''}`;
      bar.style.width = indeterminate ? '100%' : `${pct}%`;
    }
    if (label) label.textContent = isPush ? (isPending ? 'Push queued…' : 'Pushing…') : (isPending ? 'Pull queued…' : 'Pulling…');
    if (pctEl) pctEl.textContent = pct > 0 ? `${pct}%` : '';
    if (items) items.textContent = job.total_items > 0 ? `${job.processed_items} / ${job.total_items} items` : 'Loading…';
  }

  async function pollSimklJob() {
    try {
      const res = await fetch('/api/proxy/sync/status', { headers: { 'Authorization': `Bearer ${token}` } });
      if (!res.ok) return;
      const jobs: any[] = await res.json();
      const job = jobs.find(j => j.source === 'simkl');
      const isActive = job && (job.status === 'pending' || job.status === 'running');
      const isRecentDone = job && (job.status === 'completed' || job.status === 'failed')
        && new Date(job.updated_at).getTime() > Date.now() - 8000;
      renderSimklProgress((isActive || isRecentDone) ? job : null);
      if (isActive) {
        simklPoller = setTimeout(pollSimklJob, 2000);
      } else if (isRecentDone) {
        simklPoller = setTimeout(() => { renderSimklProgress(null); simklPoller = null; }, 4000);
      } else {
        simklPoller = null;
      }
    } catch {
      simklPoller = null;
    }
  }

  function startSimklPoller() {
    if (simklPoller != null) clearTimeout(simklPoller);
    pollSimklJob();
  }

  // ── Trakt progress tracking ───────────────────────────────────────────────
  let traktPoller: ReturnType<typeof setTimeout> | null = null;

  function renderTraktProgress(job: any) {
    const strip  = document.getElementById('trakt-progress');
    const bar    = document.getElementById('trakt-job-bar');
    const pctEl  = document.getElementById('trakt-job-pct');
