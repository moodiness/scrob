---
import Base from "../../../../../../layouts/Base.astro";
import ActionBar from "../../../../../../components/ActionBar.astro";
import CommentsSection from "../../../../../../components/CommentsSection.astro";
import ManualScrobble from "../../../../../../components/ManualScrobble.astro";
import VideoPlayer from "../../../../../../components/VideoPlayer.astro";
import { api, type TvdbEpisodeDetail } from "../../../../../../lib/api";
export const prerender = false;

const { id, season_number, episode_number } = Astro.params;
const { token } = Astro.locals;
Astro.response.headers.set("Cache-Control", "no-store");

let episode: TvdbEpisodeDetail | null = null;
let error = "";

try {
  episode = await api.shows.getTvdbEpisode(Number(id), Number(season_number), Number(episode_number), token);
} catch (e: any) {
  error = e.message;
}

if (!episode && !error) {
  return Astro.redirect("/404");
}

const show = episode?.show;
const season = episode?.season;
const thumbnail = episode?.image_url || show?.poster_path || null;
---

<Base title={episode ? `${show?.title} — ${episode.name ?? `Episode ${episode_number}`}` : "Episode Details"}>
  {error && !episode && (
    <div class="max-w-md mx-auto mt-20 text-center">
      <div class="bg-red-500/10 border border-red-500/20 text-red-500 p-6 rounded-2xl mb-6">
        <p class="font-bold text-lg mb-2">Oops!</p>
        <p class="text-sm opacity-80">{error}</p>
      </div>
      <a href="/" class="text-blue-500 hover:underline">Return to Dashboard</a>
    </div>
  )}

  {episode && (
    <div class="relative">
      {show?.backdrop_path && (
        <div class="absolute -top-8 left-1/2 -translate-x-1/2 w-screen h-[500px] overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/60 to-transparent z-10"></div>
          <img src={show.backdrop_path} alt="" class="w-full h-full object-cover opacity-30 blur-[1px]" />
        </div>
      )}

      <div class="relative z-20">
        <nav class="flex items-center gap-2 text-sm text-zinc-400 mb-8 overflow-hidden whitespace-nowrap">
          <a href="/shows" class="hover:text-zinc-100 transition shrink-0">Shows</a>
          <span class="text-zinc-700">/</span>
          <a href={`/show/tvdb/${id}`} class="hover:text-zinc-100 transition truncate">{show?.title}</a>
          <span class="text-zinc-700 shrink-0">/</span>
          <a href={`/show/tvdb/${id}/season/${season_number}`} class="hover:text-zinc-100 transition shrink-0">{season?.name ?? `Season ${season_number}`}</a>
          <span class="text-zinc-700 shrink-0">/</span>
          <span class="text-zinc-100 font-bold shrink-0">Episode {episode_number}</span>
        </nav>

        <div class="flex flex-col md:flex-row gap-8 lg:gap-12 mb-16">
          <!-- Thumbnail -->
          <div class="w-full md:w-80 shrink-0">
            <div class="aspect-video rounded-2xl overflow-hidden shadow-2xl border border-zinc-800 bg-zinc-900 ring-1 ring-white/10 relative">
              {thumbnail ? (
                <button id="poster-zoom-btn" class="w-full h-full group/poster block cursor-zoom-in" aria-label={`Enlarge thumbnail`}>
                  <img
                    src={thumbnail}
                    alt={episode.name ?? ""}
                    class="w-full h-full object-cover transition-transform duration-300 group-hover/poster:scale-105"
                    loading="eager"
                    decoding="async"
                  />
                  <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover/poster:opacity-100 transition-opacity duration-200 bg-black/30">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-8 h-8 text-white drop-shadow-lg">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607ZM10.5 7.5v6m3-3h-6" />
                    </svg>
                  </div>
                </button>
              ) : (
                <div class="w-full h-full flex flex-col items-center justify-center text-zinc-400 p-4 text-center">
                  <span class="text-4xl mb-2">📺</span>
                  <span class="text-sm font-medium">No Thumbnail</span>
                </div>
              )}
            </div>
          </div>

          <!-- Info -->
          <div class="flex-1 min-w-0 pt-2">
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-2">
              <div class="min-w-0">
                <h1 class="text-3xl md:text-5xl font-black text-zinc-100 mb-2 tracking-tight leading-tight">
                  {episode.name ?? `Episode ${episode_number}`}
                </h1>
                <div class="flex flex-wrap items-center gap-3">
                  <p class="text-lg text-blue-400 font-bold tracking-wide uppercase">{show?.title}</p>
                  <span class="px-3 py-1 bg-blue-600/20 border border-blue-600/30 text-blue-400 text-[10px] font-black rounded-full uppercase tracking-widest">
                    S{String(season_number).padStart(2, "0")}E{String(episode_number).padStart(2, "0")}
                  </span>
                </div>
              </div>

              {episode.episodes && episode.episodes.length > 1 && (
                <div class="flex items-center gap-2 shrink-0">
                  {(() => {
                    const currentEp = Number(episode_number);
                    const sorted = [...episode.episodes].sort((a, b) => a.episode_number - b.episode_number);
                    const idx = sorted.findIndex((e) => e.episode_number === currentEp);
                    const prev = idx > 0 ? sorted[idx - 1] : null;
                    const next = idx < sorted.length - 1 ? sorted[idx + 1] : null;
                    return (
                      <>
                        {prev && (
                          <a href={`/show/tvdb/${id}/season/${season_number}/${prev.episode_number}`} class="flex items-center gap-1.5 px-3 py-2 bg-zinc-900/60 border border-zinc-800/50 rounded-xl text-zinc-400 hover:text-zinc-100 hover:border-blue-500/50 hover:bg-zinc-800/60 active:scale-95 active:opacity-70 transition-all text-sm font-bold">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12 15.75 4.5" />
                            </svg>
                            <span class="hidden sm:inline">E{prev.episode_number}</span>
                          </a>
                        )}
                        <span class="px-3 py-2 bg-blue-600/20 border border-blue-500/30 rounded-xl text-blue-400 text-sm font-black">
                          E{currentEp}
                        </span>
                        {next && (
                          <a href={`/show/tvdb/${id}/season/${season_number}/${next.episode_number}`} class="flex items-center gap-1.5 px-3 py-2 bg-zinc-900/60 border border-zinc-800/50 rounded-xl text-zinc-400 hover:text-zinc-100 hover:border-blue-500/50 hover:bg-zinc-800/60 active:scale-95 active:opacity-70 transition-all text-sm font-bold">
                            <span class="hidden sm:inline">E{next.episode_number}</span>
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                              <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                            </svg>
                          </a>
                        )}
                      </>
                    );
                  })()}
                </div>
              )}
            </div>

            <div class="flex flex-wrap items-center gap-4 text-zinc-300 text-sm mb-8 bg-zinc-900/40 p-3 rounded-xl border border-zinc-800/50 backdrop-blur-sm inline-flex">
              {episode.air_date && (
                <span class="font-bold">
                  {new Date(episode.air_date).toLocaleDateString(undefined, { year: "numeric", month: "long", day: "numeric" })}
                </span>
              )}
              {episode.runtime && (
                <span class="flex items-center gap-1.5 font-medium">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 text-zinc-500">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                  </svg>
                  {episode.runtime} min
                </span>
              )}
            </div>

            <div class="mb-4">
              <ActionBar
                tmdbId={episode.tmdb_id ?? episode.tvdb_id ?? Number(id)}
                mediaType="episode"
                watched={episode.watched}
                inLists={episode.in_lists}
                inLibrary={episode.in_library}
                collectionPct={episode.in_library ? 100 : 0}
                showTmdbId={episode.show_tmdb_id ?? episode.show.tmdb_id ?? undefined}
                seasonNumber={episode.tmdb_season_number}
                episodeNumber={episode.tmdb_episode_number}
                displaySeasonNumber={Number(season_number)}
                episodeOrder="tvdb"
                tvdbId={Number(id)}
                mediaId={episode.id}
                hideRequest={true}
                userRating={episode.user_rating}
              />
            </div>

            <ManualScrobble
              tmdbId={episode.tmdb_id}
              mediaId={episode.id}
              mediaType="episode"
              runtime={episode.runtime}
              title={episode.name ?? `Episode ${episode_number}`}
              showTmdbId={episode.show_tmdb_id ?? episode.show.tmdb_id ?? undefined}
              seasonNumber={episode.tmdb_season_number}
              episodeNumber={episode.tmdb_episode_number}
            />

            <!-- Library info -->
            {episode.library && (
              <div class="mb-4 flex flex-wrap gap-2">
                {!!episode.play_count && (
                  <span class="inline-flex items-center px-3 py-1.5 bg-zinc-900 border border-zinc-800 text-zinc-400 text-xs rounded-lg font-bold">
                    {episode.play_count} {episode.play_count === 1 ? 'Play' : 'Plays'}
                  </span>
                )}
                {[
                  episode.library.resolution,
                  episode.library.video_codec,
                  episode.library.audio_codec,
                  episode.library.audio_channels,
                ].filter(Boolean).map(tag => (
                  <span class="px-3 py-1.5 bg-zinc-900 border border-zinc-800 text-zinc-400 text-xs rounded-lg font-mono font-bold">
                    {tag}
                  </span>
                ))}
                {episode.library.audio_languages?.map((lang: string) => (
                  <span class="px-3 py-1.5 bg-zinc-900 border border-zinc-800 text-zinc-400 text-xs rounded-lg font-mono font-bold flex items-center gap-1.5">
                    <span class="opacity-50">🔊</span> {lang}
                  </span>
                ))}
                {episode.library.subtitle_languages?.map((lang: string) => (
                  <span class="px-3 py-1.5 bg-zinc-900 border border-zinc-800 text-zinc-400 text-xs rounded-lg font-mono font-bold flex items-center gap-1.5">
                    <span class="opacity-50">💬</span> {lang}
                  </span>
                ))}
              </div>
            )}

            {episode.in_library && (
              <div class="mb-8 flex flex-wrap gap-3 items-start">
                <button
                  id="refresh-metadata-btn"
                  class="flex items-center gap-2 px-4 py-2 text-sm font-bold leading-none text-zinc-300 bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 rounded-lg transition-colors cursor-pointer"
                >
                  <svg id="refresh-icon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
                    <path d="M21 3v5h-5"/>
                    <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
                    <path d="M8 16H3v5"/>
                  </svg>
                  <span id="refresh-label">Refresh Metadata</span>
                </button>
                <VideoPlayer
                  tmdbId={episode.tmdb_id ?? episode.tvdb_id ?? Number(id)}
                  mediaId={episode.id}
                  mediaType="episode"
                  inLibrary={episode.in_library}
                  title={`${show?.title} — ${episode.name ?? `Episode ${episode_number}`}`}
                  token={token}
                  secondary
                />
              </div>
            )}

            {episode.overview && (
              <div>
                <h2 class="text-xl font-black text-zinc-100 mb-4 flex items-center gap-2 uppercase tracking-tight">
                  <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
                  Overview
                </h2>
                <p class="text-zinc-300 leading-relaxed text-lg max-w-3xl font-medium opacity-90">
                  {episode.overview}
                </p>
              </div>
            )}
          </div>
        </div>

        <CommentsSection
          mediaType="series"
          tmdbId={episode.show_tmdb_id ?? episode.show.tmdb_id ?? Number(id)}
          seasonNumber={episode.tmdb_season_number}
          episodeNumber={episode.tmdb_episode_number}
        />

        <!-- Cast -->
        {episode.cast?.length > 0 && (
          <div class="mt-8 border-t border-zinc-900 pt-16">
            <h2 class="text-3xl font-black text-zinc-100 tracking-tighter uppercase mb-10">Top Cast</h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
              {episode.cast.map((person) => (
                <div class="bg-zinc-900/20 border border-zinc-800/40 p-4 rounded-3xl">
                  <div class="aspect-square w-full rounded-2xl overflow-hidden mb-5 ring-2 ring-zinc-800/50 shadow-lg">
                    {person.profile_path ? (
                      <img
                        src={person.profile_path}
                        alt={person.name}
                        class="w-full h-full object-cover"
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <div class="w-full h-full bg-zinc-800 flex items-center justify-center text-zinc-400 text-4xl">👤</div>
                    )}
                  </div>
                  <div class="space-y-1.5 text-center">
                    <p class="text-sm font-black text-zinc-100 line-clamp-1 leading-tight">{person.name}</p>
                    <p class="text-[11px] text-zinc-500 font-bold uppercase tracking-wider line-clamp-1 opacity-80">{person.character}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

      </div>
    </div>
  )}
</Base>

<script define:vars={{ tvdbId: id, token: Astro.locals.token }}>
  const btn = document.getElementById('refresh-metadata-btn');
  if (btn) {
    btn.addEventListener('click', async () => {
      const icon = document.getElementById('refresh-icon');
      const label = document.getElementById('refresh-label');
      if (!label || !icon) return;

      btn.setAttribute('disabled', 'true');
      btn.classList.add('opacity-60', 'cursor-not-allowed');
      icon.classList.add('animate-spin');
      label.textContent = 'Refreshing...';

      try {
        const res = await fetch(`/api/proxy/shows/tvdb/${tvdbId}/refresh`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}` },
        });
        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.detail || 'Refresh failed');
        }
        label.textContent = 'Done!';
        icon.classList.remove('animate-spin');
        setTimeout(() => { window.location.reload(); }, 800);
      } catch (err) {
        icon.classList.remove('animate-spin');
        label.textContent = 'Refresh failed';
        btn.removeAttribute('disabled');
        btn.classList.remove('opacity-60', 'cursor-not-allowed');
        setTimeout(() => { label.textContent = 'Refresh Metadata'; }, 3000);
      }
    });
  }
</script>

{thumbnail && (
  <div id="poster-modal" class="fixed inset-0 z-[999] flex items-center justify-center hidden" role="dialog" aria-modal="true">
    <div id="poster-modal-backdrop" class="absolute inset-0 bg-black/90 backdrop-blur-sm cursor-pointer"></div>
    <img
      src={thumbnail}
      alt={episode?.name ?? ""}
      class="relative max-h-[90vh] max-w-[90vw] md:max-w-[70vw] object-contain rounded-2xl shadow-2xl ring-1 ring-white/10"
    />
    <button
      id="poster-modal-close"
      class="absolute top-4 right-4 p-2 rounded-full bg-black/60 hover:bg-black/80 text-white/70 hover:text-white transition-all duration-200 cursor-pointer"
      aria-label="Close"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
)}

<script>
  const zoomBtn = document.getElementById("poster-zoom-btn");
  const modal = document.getElementById("poster-modal");
  const backdrop = document.getElementById("poster-modal-backdrop");
  const closeBtn = document.getElementById("poster-modal-close");
  if (zoomBtn && modal) {
    function openModal() { modal.classList.remove("hidden"); document.body.style.overflow = "hidden"; }
    function closeModal() { modal.classList.add("hidden"); document.body.style.overflow = ""; }
    zoomBtn.addEventListener("click", openModal);
    backdrop?.addEventListener("click", closeModal);
    closeBtn?.addEventListener("click", closeModal);
    document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeModal(); });
  }
</script>
